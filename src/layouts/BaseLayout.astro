---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SkyBackground from '../components/SkyBackground.astro';
import CookieBanner from '../components/CookieBanner.astro';
import siteContent from '../data/siteContent.json';
import { sanitizeUrl } from '../lib/sanitize-url';
import '../styles/globals.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, ogType = 'website' } = Astro.props as Props;

const SITE_FALLBACK = 'https://florentinapanaofficial.ro';
const site = Astro.site?.toString().replace(/\/$/, '') ?? SITE_FALLBACK;
const canonical = new URL(Astro.url.pathname, site).toString();

// OG image: transformă calea relativă în URL absolut
// TODO: creează fișierul fizic public/images/og-default-1200x630.jpg (1200×630px)
const rawOgImage = Astro.props.ogImage ?? '/images/og-default-1200x630.jpg';
const ogImage = rawOgImage.startsWith('http') ? rawOgImage : `${site}${rawOgImage}`;

const ga4Id = import.meta.env.PUBLIC_GA4_ID;

const { navigation } = siteContent;

const socialLinks = {
  youtube:   sanitizeUrl(siteContent.socialLinks?.youtube),
  facebook:  sanitizeUrl(siteContent.socialLinks?.facebook),
  instagram: sanitizeUrl(siteContent.socialLinks?.instagram),
  tiktok:    sanitizeUrl(siteContent.socialLinks?.tiktok),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['MusicGroup', 'LocalBusiness'],
  name: siteContent.brand.name,
  description: siteContent.seo.description,
  url: site || '',
  logo: `${site}/images/logo-fp-stage.svg`,
  telephone: siteContent.contact.phoneRaw,
  email: siteContent.contact.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Pitești',
    addressRegion: 'Argeș',
    addressCountry: 'RO',
  },
  sameAs: [
    siteContent.socialLinks?.youtube,
    siteContent.socialLinks?.facebook,
    siteContent.socialLinks?.instagram,
  ].filter(Boolean),
  genre: ['Muzică populară', 'Muzică de petrecere', 'Muzică live', 'Muzică ușoară'],
  performerIn: {
    '@type': 'MusicEvent',
    name: 'Nunți, botezuri și evenimente corporate',
  },
  foundingDate: '2014',
  areaServed: {
    '@type': 'Country',
    name: 'România',
  },
};

const isHomePage = Astro.url.pathname === '/';
const sectionLink = (anchor: string) => (isHomePage ? anchor : `/${anchor}`);

const sideMenuTopItems = [
  { href: '/', label: 'Acasă', color: 'cyan' },
  { href: '/galerie-video', label: 'Galerie Video', color: 'cyan' },
  { href: '/galerie-foto', label: 'Galerie Foto', color: 'cyan' },
  { href: '/membri', label: 'Membri', color: 'cyan' },
  { href: '/despre', label: 'Despre', color: 'cyan' },
  { href: '/contact', label: 'Contact', color: 'cyan' },
];

const sideMenuBottomItems = [];

// Linkuri extra din navigation (cele din header desktop care nu sunt deja în sidebar)
const sideHrefs = new Set(sideMenuTopItems.map(i => i.href));
const extraNavItems = navigation
  .map(item => ({ href: item.href.startsWith('/') || item.href.startsWith('#') || item.href.startsWith('http') ? item.href : `/${item.href}`, label: item.label }))
  .filter(item => !sideHrefs.has(item.href));

// Lista completă pentru nav-ul mobil
const mobileNavAllItems = [
  ...sideMenuTopItems,
  ...extraNavItems,
];
---

<!DOCTYPE html>
<html lang="ro" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0c0f1f" />
    <meta name="author" content="Formația Florentina Pană" />
    <!-- SEO local: județ Argeș, codul ISO RO-AG recunoscut de Google Maps -->
    <meta name="geo.region" content="RO-AG" />
    <meta name="geo.placename" content="Pitești, Argeș" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${title} – Formația Florentina Pană`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:site_name" content={siteContent.brand.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- [DE_COMPLETAT] Înlocuiește @florentinapana cu contul real X/Twitter -->
    <meta name="twitter:site" content="@florentinapana" />
    <!-- Fonturi Google — doar Inter + Oswald (singurele folosite în CSS)
         Cormorant Garamond și Playfair Display eliminate: zero utilizări font-family în cod -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@300;400;500;600;700&display=swap" /></noscript>
    <link rel="icon" type="image/svg+xml" href="/images/logo-fp-stage.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
    {/* GA4 NU se încarcă în <head> — se injectează dinamic DUPĂ consimțământul
        utilizatorului prin CookieBanner, conform Rec. 30 & 32 RGPD / ePrivacy */}
  </head>
  <body class={`page-shell${isHomePage ? ' is-homepage' : ''}`}>
    <a href="#continut" class="skip-link">Sari la conținut</a>
    <SkyBackground />
    <Header />

    <!-- ══ MOBIL: nav plutitor (ascuns pe desktop via CSS) ══ -->
    <nav class="mob-nav" aria-label="Navigare mobilă">
      <div class="mob-nav-track">
        {mobileNavAllItems.map((item) => (
          <a href={item.href} class="mob-nav-btn" data-mb={item.href}>{item.label}</a>
        ))}

        <!-- Separator -->
        <span class="mob-nav-sep" aria-hidden="true"></span>

        <!-- Social icons -->
        {socialLinks.youtube && (
          <a href={socialLinks.youtube} class="mob-social-btn" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
            style="background:#FF0000;box-shadow:0 1px 8px rgba(255,0,0,0.55);">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
              <rect x="2" y="6" width="20" height="13" rx="4" fill="#fff"/>
              <polygon points="9.5,9.5 9.5,15.5 16.5,12.5" fill="#FF0000"/>
            </svg>
          </a>
        )}
        {socialLinks.facebook && (
          <a href={socialLinks.facebook} class="mob-social-btn" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
            style="background:#1877F2;box-shadow:0 1px 8px rgba(24,119,242,0.55);">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
              <path d="M13.5 21V14.3H16l.4-2.85H13.5V9.7c0-.82.38-1.2 1.38-1.2H16.5V5.85C16.05 5.77 15.1 5.7 14 5.7c-2.65 0-4.05 1.4-4.05 4.15v1.6H8v2.85h1.95V21H13.5z" fill="#fff"/>
            </svg>
          </a>
        )}
        {socialLinks.instagram && (
          <a href={socialLinks.instagram} class="mob-social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            style="background:radial-gradient(circle at 30% 110%,#ffd676 0%,#f46f30 25%,#e1306c 55%,#833ab4 80%,#405de6 100%);box-shadow:0 1px 8px rgba(225,48,108,0.55);">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
              <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="#fff" stroke-width="2.1"/>
              <circle cx="12" cy="12" r="4.3" stroke="#fff" stroke-width="2"/>
              <circle cx="17.5" cy="6.6" r="1.4" fill="#fff"/>
            </svg>
          </a>
        )}
        {socialLinks.tiktok && (
          <a href={socialLinks.tiktok} class="mob-social-btn" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
            style="background:#010101;border:1.5px solid rgba(255,255,255,0.45);box-shadow:0 1px 8px rgba(254,44,85,0.45);">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
              <path transform="translate(-0.5,-0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#25f4ee"/>
              <path transform="translate(0.5,0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fe2c55"/>
              <path d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fff"/>
            </svg>
          </a>
        )}
      </div>
    </nav>

    <div class="layout-content-shell">
      <aside class="left-side-menu" aria-label="Acces rapid">
        {sideMenuTopItems.map((item) => (
          <a href={item.href} class={`left-side-link nav-btn-${item.color}`} data-nav-link>{item.label}</a>
        ))}

        {sideMenuBottomItems.map((item) => (
          <a href={item.href} class={`left-side-link nav-btn-${item.color}`} data-nav-link>{item.label}</a>
        ))}
      </aside>

      <main id="continut" class="flex-1 min-w-0 pt-40 sm:pt-44">
        <slot />
      </main>
    </div>
    <Footer />

    {/* Banner consimțământ cookie – GA4 pornit doar după accept */}
    <CookieBanner ga4Id={ga4Id} />

    <script is:inline src="/js/scroll-progress.js" defer></script>

    <script is:inline src="/js/scroll-spy.js" defer></script>

    <!-- ══ MOBIL: săgeți hint swipe (ascunse pe desktop via CSS) ══ -->
    <div class="mob-swipe-hints" aria-hidden="true">
      <button type="button" class="mob-arrow mob-arrow--prev" id="mob-arrow-prev" aria-label="Secțiunea anterioară">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button type="button" class="mob-arrow mob-arrow--next" id="mob-arrow-next" aria-label="Secțiunea următoare">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <script is:inline src="/js/mobile-swipe.js" defer></script>
  </body>
</html>

