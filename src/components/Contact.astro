---
---

<section
  id="contact"
  class="section-container pb-16 pt-6 sm:pb-20 sm:pt-8"
>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:items-start">
    <div class="space-y-4 animate-fade-up">
      <p class="section-kicker">Contact</p>
      <h2 class="section-title">
        Spune-mi câteva detalii despre proiectul tău.
      </h2>
      <p class="section-description">
        Completează formularul de mai jos și vei primi un răspuns cu idei concrete de
        structură, conținut și estimare de timp pentru landing page-ul tău.
      </p>
      <ul class="mt-4 space-y-2 text-sm" style="color: var(--body);">
        <li>• Răspuns în cel mult 1–2 zile lucrătoare.</li>
        <li>• Fără spam, doar discuții legate de eveniment.</li>
      </ul>
    </div>

    <form
      class="card-soft space-y-4 p-5 sm:p-6 animate-fade-up"
      method="post"
      action="#"
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-1.5">
          <label for="name" class="text-xs font-medium" style="color: var(--body);">
            Nume
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            aria-required="true"
            aria-invalid="false"
            autocomplete="name"
            class="w-full rounded-xl border px-3 py-2 text-sm shadow-sm outline-none transition placeholder:opacity-50 focus:ring-2"
            style="border-color: var(--line); background: rgba(255,255,255,0.05); color: var(--title); focus:border-color: var(--accent-gold);"
            placeholder="Numele tău"
          />
        </div>
        <div class="space-y-1.5">
          <label for="email" class="text-xs font-medium" style="color: var(--body);">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            aria-required="true"
            aria-invalid="false"
            autocomplete="email"
            class="w-full rounded-xl border px-3 py-2 text-sm shadow-sm outline-none transition placeholder:opacity-50 focus:ring-2"
            style="border-color: var(--line); background: rgba(255,255,255,0.05); color: var(--title);"
            placeholder="tu@exemplu.com"
          />
        </div>
      </div>

      <div class="space-y-1.5">
        <label for="subject" class="text-xs font-medium" style="color: var(--body);">
          Subiect
        </label>
        <input
          id="subject"
          name="subject"
          type="text"
          class="w-full rounded-xl border px-3 py-2 text-sm shadow-sm outline-none transition placeholder:opacity-50 focus:ring-2"
          style="border-color: var(--line); background: rgba(255,255,255,0.05); color: var(--title);"
          placeholder="Eveniment, nuntă, petrecere..."
        />
      </div>

      <div class="space-y-1.5">
        <label for="message" class="text-xs font-medium" style="color: var(--body);">
          Detalii despre eveniment
        </label>
        <textarea
          id="message"
          name="message"
          required
          aria-required="true"
          aria-invalid="false"
          rows={4}
          class="w-full resize-none rounded-xl border px-3 py-2 text-sm shadow-sm outline-none transition placeholder:opacity-50 focus:ring-2"
          style="border-color: var(--line); background: rgba(255,255,255,0.05); color: var(--title);"
          placeholder="Data, locația, tipul evenimentului și orice alte detalii relevante."
        />
      </div>

      <button type="submit" class="btn-primary w-full sm:w-auto">
        Trimite mesajul
      </button>

      <p class="text-[11px] leading-relaxed" style="color: var(--muted);">
        Trimițând acest formular, ești de acord ca datele tale să fie folosite pentru a
        răspunde la mesaj. Nu vor fi partajate cu terți.
      </p>
    </form>
  </div>
</section>

