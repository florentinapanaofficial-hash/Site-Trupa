---
import siteContent from '../data/siteContent.json';
import { sanitizeUrl } from '../lib/sanitize-url';

const year = new Date().getFullYear();
const { brand, contact } = siteContent;
const socialLinks = {
  youtube: sanitizeUrl(siteContent.socialLinks?.youtube, 'https://www.youtube.com/'),
  facebook: sanitizeUrl(siteContent.socialLinks?.facebook, 'https://www.facebook.com/'),
  instagram: sanitizeUrl(siteContent.socialLinks?.instagram, 'https://www.instagram.com/'),
  tiktok: sanitizeUrl(siteContent.socialLinks?.tiktok, 'https://www.tiktok.com/'),
};
const isHomePage = Astro.url.pathname === '/';
---

<footer class="border-t border-white/10 bg-[#0C080F] text-white/90">
  <div class="section-container grid gap-4 py-8 text-sm md:grid-cols-3 md:items-center">
    <div class="inline-flex items-center gap-3">
      <img
        src="/images/logo-fp-stage.svg"
        alt="Logo Formația Florentina Pană"
        class="h-10 w-10 rounded-xl border border-white/20 bg-white/5 p-1"
        loading="lazy"
        decoding="async"
      />
      <p class="text-muted-theme">© {year} {brand.name}. Toate drepturile rezervate.</p>
    </div>

    <div class="flex flex-col items-start gap-3 md:items-center">
      <a href={isHomePage ? '#acasa' : '/#acasa'} class="transition hover:text-[#F5A623] text-body">
        Înapoi sus
      </a>
      <div class="flex items-center gap-2">
        <a href={socialLinks.youtube}
          class="inline-grid h-8 w-8 place-items-center rounded-lg transition-opacity hover:opacity-80 social-btn-yt"
          target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
            <rect x="2" y="6" width="20" height="13" rx="4" fill="#fff"/>
            <polygon points="9.5,9.5 9.5,15.5 16.5,12.5" fill="#FF0000"/>
          </svg>
        </a>
        <a href={socialLinks.facebook}
          class="inline-grid h-8 w-8 place-items-center rounded-lg transition-opacity hover:opacity-80 social-btn-fb"
          target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
            <path d="M13.5 21V14.3H16l.4-2.85H13.5V9.7c0-.82.38-1.2 1.38-1.2H16.5V5.85C16.05 5.77 15.1 5.7 14 5.7c-2.65 0-4.05 1.4-4.05 4.15v1.6H8v2.85h1.95V21H13.5z" fill="#fff"/>
          </svg>
        </a>
        <a href={socialLinks.instagram}
          class="inline-grid h-8 w-8 place-items-center rounded-lg transition-opacity hover:opacity-80 social-btn-ig"
          target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
            <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="#fff" stroke-width="2.1"/>
            <circle cx="12" cy="12" r="4.2" stroke="#fff" stroke-width="2"/>
            <circle cx="17.2" cy="6.8" r="1.1" fill="#fff"/>
          </svg>
        </a>
        <a href={socialLinks.tiktok}
          class="inline-grid h-8 w-8 place-items-center rounded-lg transition-opacity hover:opacity-80 social-btn-tt"
          target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
            <path d="M16.5 3h-2.8v11.8a2.7 2.7 0 1 1-2.7-2.7c.25 0 .49.03.72.09V9.3a5.5 5.5 0 1 0 4.78 5.5V8.5a7.9 7.9 0 0 0 4.6 1.47V7.18A4.62 4.62 0 0 1 16.5 3z" fill="#fff"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="justify-self-start md:justify-self-end text-right text-body">
      <span id="footer-email-js" class="transition hover:text-[#F5A623]"></span>
      <span aria-hidden="true" class="text-muted-theme"> | </span>
      <a href={`tel:${contact.phoneRaw}`} class="transition hover:text-[#F5A623]">{contact.phoneDisplay}</a>
      <div class="mt-2 flex flex-wrap justify-end gap-x-3 gap-y-1" style="font-size:0.75rem;color:var(--muted);">
        <a href="/politica-confidentialitate" class="transition hover:text-white/80">Politică confidențialitate</a>
        <span aria-hidden="true">·</span>
        <a href="/politica-cookie" class="transition hover:text-white/80">Politică cookie</a>
        <span aria-hidden="true">·</span>
        <button
          id="cookie-prefs-btn"
          type="button"
          class="transition hover:text-white/80 cursor-pointer"
          style="background:none;border:0;padding:0;font-size:inherit;color:inherit;"
          aria-label="Gestionează preferințele de cookie-uri"
        >Preferințe cookie</button>
      </div>
    </div>
  </div>
</footer>

<script>
  (function () {
    var btn = document.getElementById('cookie-prefs-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      try { localStorage.removeItem('cookie_consent'); } catch (_) {}
      var banner = document.getElementById('cookie-banner');
      if (banner) {
        banner.hidden = false;
        banner.removeAttribute('hidden');
        banner.removeAttribute('aria-hidden');
      }
    });
  })();
</script>

<script>
  (function () {
    var el = document.getElementById('footer-email-js');
    if (!el) return;
    var u = 'florentinapanaofficial';
    var d = 'gmail.com';
    var addr = u + '@' + d;
    el.innerHTML = '<a href="mai' + 'lto:' + addr + '" class="transition hover:text-[#F5A623]">' + addr + '</a>';
  })();
</script>

