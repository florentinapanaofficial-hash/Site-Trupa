---
import siteContent from '../data/siteContent.json';

const year = new Date().getFullYear();
const { brand, contact } = siteContent;
const isHomePage = Astro.url.pathname === '/';
---

<footer class="border-t border-white/10 bg-[#0C080F] text-white/90">
  <div class="section-container grid gap-4 py-8 text-sm md:grid-cols-3 md:items-center">
    <div class="inline-flex items-center gap-3">
      <img
        src="/images/logo-fp-stage.svg"
        alt="Logo Formația Florentina Pană"
        class="h-10 w-10 rounded-xl border border-white/20 bg-white/5 p-1"
        loading="lazy"
        decoding="async"
      />
      <p style="color:var(--muted)">© {year} {brand.name}. Toate drepturile rezervate.</p>
    </div>

    <a href={isHomePage ? '#acasa' : '/#acasa'} class="justify-self-start transition hover:text-[#F5A623] md:justify-self-center" style="color: var(--body);">
      Înapoi sus
    </a>

    <div class="justify-self-start md:justify-self-end" style="color: var(--body);">
      <a href={`mailto:${contact.email}`} class="transition hover:text-[#F5A623]">{contact.email}</a>
      <span aria-hidden="true" style="color:var(--muted)"> | </span>
      <a href={`tel:${contact.phoneRaw}`} class="transition hover:text-[#F5A623]">{contact.phoneDisplay}</a>
    </div>
  </div>
</footer>

