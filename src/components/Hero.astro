---
---

<section
  id="hero"
  class="section-container grid gap-10 py-16 sm:py-20 md:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] md:items-center"
>
  <div class="space-y-6 animate-fade-up">
    <div class="chip-pill max-w-max">
      <span class="h-1.5 w-1.5 rounded-full bg-pastel-mint" aria-hidden="true" />
      <span>Landing page modern în pastel</span>
    </div>

    <div class="space-y-4">
      <h1 class="text-balance text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Transformă-ți ideea într-o prezență online memorabilă.
      </h1>
      <p class="max-w-xl text-sm leading-relaxed text-slate-600 sm:text-base">
        Creează o primă impresie impecabilă cu un landing page modern, optimizat pentru
        conversii, performanță și SEO — construit cu Astro și TailwindCSS.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <a
        href="#contact"
        class="btn-primary"
        aria-describedby="hero-visual-note"
      >
        Începe o discuție
      </a>
      <a href="#features" class="btn-ghost">
        Vezi beneficiile
      </a>
    </div>

    <p
      id="hero-visual-note"
      class="text-xs text-slate-500"
    >
      Fără imagini reale, doar exemplu vizual.
    </p>

    <dl class="mt-4 grid gap-4 text-xs text-slate-600 sm:grid-cols-3 sm:text-sm">
      <div>
        <dt class="font-semibold text-slate-900">Performanță</dt>
        <dd>Lighthouse score excelent datorită Astro.</dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-900">SEO complet</dt>
        <dd>Meta, OG tags, sitemap &amp; robots.txt.</dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-900">Design pastel</dt>
        <dd>Inter local, animații discrete, layout curat.</dd>
      </div>
    </dl>
  </div>

  <div class="animate-fade-up-delayed">
    <div
      class="relative mx-auto aspect-[16/9] w-full max-w-xl overflow-hidden rounded-2xl bg-gradient-to-br from-purple-100 via-pink-100 to-white shadow-soft"
      aria-hidden="true"
    >
      <div class="absolute inset-0 bg-white/40 mix-blend-screen" />
      <div class="relative flex h-full w-full items-center justify-center">
        <div class="flex h-32 w-56 -rotate-3 items-center justify-center rounded-[2rem] bg-white/80 shadow-soft">
          <div class="grid grid-cols-3 gap-2">
            <div class="h-16 w-16 rounded-2xl bg-pastel-pink/70" />
            <div class="h-16 w-16 rounded-2xl bg-pastel-blue/70" />
            <div class="h-16 w-16 rounded-2xl bg-pastel-mint/70" />
            <div class="h-10 w-16 rounded-xl bg-pastel-purple/60 col-span-2" />
            <div class="h-10 w-16 rounded-xl bg-pastel-cream/80" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

