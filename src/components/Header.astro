---
import siteContent from '../data/siteContent.json';

const { brand, navigation } = siteContent;
const socialLinks = {
  youtube: siteContent.socialLinks?.youtube || 'https://www.youtube.com/',
  facebook: siteContent.socialLinks?.facebook || 'https://www.facebook.com/',
  instagram: siteContent.socialLinks?.instagram || 'https://www.instagram.com/',
  tiktok: siteContent.socialLinks?.tiktok || 'https://www.tiktok.com/',
};
const leftRailHrefs = new Set(['#acasa', '#noutati', '#video', '#aparitii-tv', '#galerie', '#contact']);
const leftRailLabelTokens = ['acasa', 'noutati', 'video', 'aparitii', 'galerie', 'contact'];
const isHomePage = Astro.url.pathname === '/';
const normalizedNavigation = navigation.map((item) => ({
  ...item,
  href: isHomePage ? item.href : `/${item.href}`,
}));
const normalizeText = (value) =>
  String(value)
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

const topNavigation = normalizedNavigation.filter((item) => {
  const normalizedHref = item.href.replace(/^\//, '');
  const normalizedLabel = normalizeText(item.label);
  const isLeftRailHref = leftRailHrefs.has(normalizedHref);
  const isLeftRailLabel = leftRailLabelTokens.some((token) => normalizedLabel.includes(token));

  return !isLeftRailHref && !isLeftRailLabel;
});
const desktopNavigation = topNavigation;
const mobileNavigation = topNavigation;
const hasExpandableTopMenu = mobileNavigation.length > 1;
---

<header class="top-header fixed inset-x-0 top-0 z-40 border-b border-white/20 bg-ink" data-top-header>
  <div class="section-container flex items-center justify-between gap-3 py-3">
    <a href="#acasa" class="inline-flex items-center gap-3" aria-label="Mergi la începutul paginii">
      <img
        src="/images/logo-fp-stage.svg"
        alt="Logo Formația Florentina Pană"
        class="h-10 w-10 rounded-xl border border-white/25 bg-white/5 p-1 shadow-[0_8px_24px_rgba(94,238,255,0.22)]"
        loading="eager"
        decoding="async"
      />
      <span class="leading-tight">
        <span class="block text-sm font-bold tracking-tight text-white sm:text-base">{brand.name}</span>
        <span class="hidden text-xs text-white/85 sm:block">Live Band Premium</span>
      </span>
    </a>

    <div class="flex items-center gap-2">
      {hasExpandableTopMenu && (
        <button
          type="button"
          class="btn-outline top-menu-toggle"
          data-top-menu-toggle
          aria-expanded="false"
          aria-controls="top-menu-panel"
          aria-label="Deschide meniul principal"
        >
          <span class="hamburger-lines" aria-hidden="true">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </span>
          <span class="top-menu-toggle-label">Meniu</span>
        </button>
      )}

      <a href={socialLinks.youtube} class="inline-grid h-10 w-10 place-items-center rounded-xl border border-white/25 bg-white/10 text-white/90 transition-all duration-200 hover:-translate-y-0.5 hover:border-red-300/70 hover:bg-red-500/20" target="_blank" rel="noopener noreferrer" aria-label="Deschide YouTube">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <path d="M22 12C22 9.35 21.77 7.91 21.53 7.02C21.34 6.3 20.78 5.74 20.06 5.55C18.75 5.2 12 5.2 12 5.2C12 5.2 5.25 5.2 3.94 5.55C3.22 5.74 2.66 6.3 2.47 7.02C2.23 7.91 2 9.35 2 12C2 14.65 2.23 16.09 2.47 16.98C2.66 17.7 3.22 18.26 3.94 18.45C5.25 18.8 12 18.8 12 18.8C12 18.8 18.75 18.8 20.06 18.45C20.78 18.26 21.34 17.7 21.53 16.98C21.77 16.09 22 14.65 22 12Z" fill="currentColor"/>
          <path d="M10 15.5V8.5L16 12L10 15.5Z" fill="#ffffff"/>
        </svg>
      </a>

      <a href={socialLinks.facebook} class="inline-grid h-10 w-10 place-items-center rounded-xl border border-white/25 bg-white/10 text-white/90 transition-all duration-200 hover:-translate-y-0.5 hover:border-blue-300/70 hover:bg-blue-500/20" target="_blank" rel="noopener noreferrer" aria-label="Deschide Facebook">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <path d="M24 12.07C24 5.4 18.63 0 12 0C5.37 0 0 5.4 0 12.07C0 18.09 4.39 23.08 10.12 24V15.56H7.08V12.07H10.12V9.41C10.12 6.39 11.91 4.72 14.66 4.72C15.98 4.72 17.37 4.96 17.37 4.96V7.93H15.84C14.34 7.93 13.88 8.87 13.88 9.84V12.07H17.23L16.69 15.56H13.88V24C19.61 23.08 24 18.09 24 12.07Z" fill="currentColor"/>
        </svg>
      </a>

      <a href={socialLinks.instagram} class="inline-grid h-10 w-10 place-items-center rounded-xl border border-white/25 bg-white/10 text-white/90 transition-all duration-200 hover:-translate-y-0.5 hover:border-pink-300/70 hover:bg-pink-500/20" target="_blank" rel="noopener noreferrer" aria-label="Deschide Instagram">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <rect x="2.3" y="2.3" width="19.4" height="19.4" rx="6" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="17.45" cy="6.55" r="1.2" fill="currentColor"/>
        </svg>
      </a>

      <a href={socialLinks.tiktok} class="inline-grid h-10 w-10 place-items-center rounded-xl border border-white/25 bg-white/10 text-white/90 transition-all duration-200 hover:-translate-y-0.5 hover:border-cyan-300/70 hover:bg-cyan-500/20" target="_blank" rel="noopener noreferrer" aria-label="Deschide TikTok">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" role="img" aria-hidden="true">
          <path d="M14.5 3.2c.5 1.5 1.4 2.8 2.7 3.7 1 .7 2.1 1.1 3.3 1.2v3.2c-1.7-.1-3.4-.6-4.8-1.4V16c0 3.1-2.5 5.6-5.6 5.6S4.5 19.1 4.5 16 7 10.4 10.1 10.4c.3 0 .6 0 .9.1v3.3c-.3-.1-.6-.2-.9-.2-1.3 0-2.4 1.1-2.4 2.4s1.1 2.4 2.4 2.4 2.4-1.1 2.4-2.4V3.2h2z"/>
        </svg>
      </a>
    </div>
  </div>

  {hasExpandableTopMenu && (
    <div id="top-menu-panel" class="top-menu-panel" data-top-menu-panel>
      <nav class="no-scrollbar section-container flex min-w-0 items-center justify-start gap-4 overflow-x-auto pb-3 text-sm font-medium text-white/90 xl:justify-center" aria-label="Navigație principală">
        {desktopNavigation.map((item) => (
          <a href={item.href} class="nav-link nav-link-desktop" data-nav-link>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
        {mobileNavigation.map((item) => (
          <a href={item.href} class="nav-link nav-link-mobile" data-nav-link>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
    </div>
  )}
</header>

<script>
  const initScrollSpy = () => {
    const headerEl = document.querySelector('[data-top-header]');
    const menuToggle = document.querySelector('[data-top-menu-toggle]');
    const isMobileViewport = () => window.matchMedia('(max-width: 767px)').matches;
    let lastScrollY = window.scrollY;

    const syncTopMenuBodyClass = (isOpen) => {
      document.body.classList.toggle('top-menu-expanded', Boolean(isOpen));
      document.body.classList.toggle('mobile-menu-open', Boolean(isOpen) && isMobileViewport());
    };

    syncTopMenuBodyClass(false);

    if (headerEl && menuToggle) {
      menuToggle.addEventListener('click', () => {
        const willOpen = !headerEl.classList.contains('menu-open');
        headerEl.classList.toggle('menu-open', willOpen);
        menuToggle.setAttribute('aria-expanded', String(willOpen));
        menuToggle.setAttribute('aria-label', willOpen ? 'Închide meniul principal' : 'Deschide meniul principal');
        syncTopMenuBodyClass(willOpen);
      });

      window.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (!headerEl.classList.contains('menu-open')) return;

        headerEl.classList.remove('menu-open');
        menuToggle.setAttribute('aria-expanded', 'false');
        menuToggle.setAttribute('aria-label', 'Deschide meniul principal');
        syncTopMenuBodyClass(false);
      });

      window.addEventListener('resize', () => {
        if (!headerEl.classList.contains('menu-open')) return;
        syncTopMenuBodyClass(true);
      });
    }

    const links = Array.from(document.querySelectorAll('[data-nav-link]'));
    if (links.length === 0) return;

    const sectionMap = links
      .map((link) => {
        const href = link.getAttribute('href') ?? '';
        if (!href.startsWith('#')) return null;
        const section = document.querySelector(href);
        if (!section) return null;
        return { link, href, section };
      })
      .filter(Boolean);

    if (sectionMap.length === 0) return;

    const uniqueSections = [];
    const seenSections = new Set();

    sectionMap.forEach((item) => {
      if (!seenSections.has(item.href)) {
        seenSections.add(item.href);
        uniqueSections.push({ href: item.href, section: item.section });
      }
    });

    let lastActiveHref = null;
    let ticking = false;

    const setActiveByHref = (activeHref) => {
      if (!activeHref) return;
      const changed = lastActiveHref !== activeHref;

      sectionMap.forEach(({ link, href }) => {
        const isActive = href === activeHref;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });

      if (changed) {
        sectionMap
          .filter((item) => item.href === activeHref)
          .forEach((item) => {
            item.link.classList.remove('just-activated');
            requestAnimationFrame(() => {
              item.link.classList.add('just-activated');
            });
          });
      }

      lastActiveHref = activeHref;
    };

    const getActiveByScroll = () => {
      const marker = window.scrollY + 160;
      const orderedSections = [...uniqueSections]
        .map((item) => ({
          ...item,
          top: item.section.getBoundingClientRect().top + window.scrollY,
        }))
        .sort((a, b) => a.top - b.top);

      let active = orderedSections[0];

      for (let index = 0; index < orderedSections.length; index += 1) {
        const current = orderedSections[index];
        const next = orderedSections[index + 1];
        const nextTop = next ? next.top : Number.POSITIVE_INFINITY;

        if (marker >= current.top && marker < nextTop) {
          active = current;
          break;
        }
      }

      const reachedBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 2;
      if (reachedBottom) {
        active = orderedSections[orderedSections.length - 1];
      }

      setActiveByHref(active?.href);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        getActiveByScroll();

        if (headerEl) {
          const currentY = window.scrollY;
          const scrollingDown = currentY > lastScrollY;
          const shouldHide = scrollingDown && currentY > 120 && !headerEl.classList.contains('menu-open');
          headerEl.classList.toggle('header-hidden', shouldHide);
          lastScrollY = currentY;
        }

        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);

    links.forEach((link) => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href') ?? '';
        if (href.startsWith('#')) {
          setActiveByHref(href);
        }

        if (headerEl?.classList.contains('menu-open')) {
          headerEl.classList.remove('menu-open');
          menuToggle?.setAttribute('aria-expanded', 'false');
          menuToggle?.setAttribute('aria-label', 'Deschide meniul principal');
          syncTopMenuBodyClass(false);
        }
      });
    });

    getActiveByScroll();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollSpy, { once: true });
  } else {
    initScrollSpy();
  }
</script>
