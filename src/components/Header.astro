---
import siteContent from '../data/siteContent.json';
import { sanitizeUrl } from '../lib/sanitize-url';

const { brand, navigation } = siteContent;
const socialLinks = {
  youtube: sanitizeUrl(siteContent.socialLinks?.youtube, 'https://www.youtube.com/'),
  facebook: sanitizeUrl(siteContent.socialLinks?.facebook, 'https://www.facebook.com/'),
  instagram: sanitizeUrl(siteContent.socialLinks?.instagram, 'https://www.instagram.com/'),
  tiktok: sanitizeUrl(siteContent.socialLinks?.tiktok, 'https://www.tiktok.com/'),
};
const isHomePage = Astro.url.pathname === '/';
const normalizeNavHref = (href) => {
  if (href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:') || href.startsWith('tel:')) {
    return href;
  }

  if (href.startsWith('/')) {
    return href;
  }

  if (href.startsWith('#')) {
    return isHomePage ? href : `/${href}`;
  }

  return `/${href}`;
};

const normalizedNavigation = navigation.map((item) => ({
  ...item,
  href: normalizeNavHref(item.href),
}));
const topNavigation = normalizedNavigation;
const desktopNavigation = topNavigation;
const mobileNavigation = topNavigation;
const hasExpandableTopMenu = mobileNavigation.length > 1;
---

<header class="top-header fixed inset-x-0 top-0 z-40 border-b border-white/20 bg-ink" data-top-header>
  <div class="section-container flex items-center justify-between gap-3 py-3">
    <a href={isHomePage ? '#acasa' : '/#acasa'} class="inline-flex items-center gap-3" aria-label="Mergi la începutul paginii">
      <img
        src="/images/logo-fp-stage.svg"
        alt="Logo Formația Florentina Pană"
        class="h-10 w-10 rounded-xl border border-white/20 bg-white/5 p-1 shadow-[0_8px_24px_rgba(245,166,35,0.22)]"
        loading="eager"
        decoding="async"
      />
      <span class="leading-tight">
        <span class="block text-sm font-bold tracking-tight text-white sm:text-base">{brand.name}</span>
        <span class="hidden text-xs text-white/85 sm:block">Live Band Premium</span>
      </span>
    </a>

    <div class="flex items-center gap-2">
      {hasExpandableTopMenu && (
        <button
          type="button"
          class="btn-outline top-menu-toggle"
          data-top-menu-toggle
          aria-expanded="false"
          aria-controls="top-menu-panel"
          aria-label="Deschide meniul principal"
        >
          <span class="hamburger-lines" aria-hidden="true">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </span>
          <span class="top-menu-toggle-label">Meniu</span>
        </button>
      )}

      <!-- YouTube — roșu brand oficial -->
      <a href={socialLinks.youtube}
        class="inline-grid h-10 w-10 flex-shrink-0 place-items-center rounded-xl transition-opacity duration-200 hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
        style="background:#FF0000;box-shadow:0 2px 14px rgba(255,0,0,0.55),0 1px 3px rgba(0,0,0,0.35);"
        target="_blank" rel="noopener noreferrer" aria-label="Deschide YouTube">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <rect x="2" y="6" width="20" height="13" rx="4" fill="#fff"/>
          <polygon points="9.5,9.5 9.5,15.5 16.5,12.5" fill="#FF0000"/>
        </svg>
      </a>

      <!-- Facebook — albastru brand oficial -->
      <a href={socialLinks.facebook}
        class="inline-grid h-10 w-10 flex-shrink-0 place-items-center rounded-xl transition-opacity duration-200 hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
        style="background:#1877F2;box-shadow:0 2px 14px rgba(24,119,242,0.55),0 1px 3px rgba(0,0,0,0.35);"
        target="_blank" rel="noopener noreferrer" aria-label="Deschide Facebook">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <path d="M13.5 21V14.3H16l.4-2.85H13.5V9.7c0-.82.38-1.2 1.38-1.2H16.5V5.85C16.05 5.77 15.1 5.7 14 5.7c-2.65 0-4.05 1.4-4.05 4.15v1.6H8v2.85h1.95V21H13.5z" fill="#fff"/>
        </svg>
      </a>

      <!-- Instagram — gradient brand oficial -->
      <a href={socialLinks.instagram}
        class="inline-grid h-10 w-10 flex-shrink-0 place-items-center rounded-xl transition-opacity duration-200 hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
        style="background:radial-gradient(circle at 30% 110%,#ffd676 0%,#f46f30 25%,#e1306c 55%,#833ab4 80%,#405de6 100%);box-shadow:0 2px 14px rgba(225,48,108,0.55),0 1px 3px rgba(0,0,0,0.35);"
        target="_blank" rel="noopener noreferrer" aria-label="Deschide Instagram">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" role="img" aria-hidden="true">
          <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="#fff" stroke-width="2.1"/>
          <circle cx="12" cy="12" r="4.3" stroke="#fff" stroke-width="2"/>
          <circle cx="17.5" cy="6.6" r="1.4" fill="#fff"/>
        </svg>
      </a>

      <!-- TikTok — negru brand + efect neon cyan/roșu -->
      <a href={socialLinks.tiktok}
        class="inline-grid h-10 w-10 flex-shrink-0 place-items-center rounded-xl transition-opacity duration-200 hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
        style="background:#010101;border:1.5px solid rgba(255,255,255,0.55);box-shadow:0 2px 14px rgba(254,44,85,0.45),0 1px 3px rgba(0,0,0,0.5);"
        target="_blank" rel="noopener noreferrer" aria-label="Deschide TikTok">
        <svg viewBox="0 0 24 24" class="h-5 w-5" role="img" aria-hidden="true" fill="none">
          <!-- strat cyan (umbra stânga-sus) -->
          <path transform="translate(-0.6,-0.5)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#25f4ee"/>
          <!-- strat roșu (umbra dreapta-jos) -->
          <path transform="translate(0.6,0.5)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fe2c55"/>
          <!-- strat alb (fața) -->
          <path d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fff"/>
        </svg>
      </a>
    </div>
  </div>

  {hasExpandableTopMenu && (
    <div id="top-menu-panel" class="top-menu-panel" data-top-menu-panel>
      <nav class="no-scrollbar section-container flex min-w-0 items-center justify-start gap-4 overflow-x-auto pb-3 text-sm font-medium text-white/90 xl:justify-center" aria-label="Navigație principală">
        {desktopNavigation.map((item) => (
          <a href={item.href} class={`left-side-link nav-link-desktop${item.color ? ` nav-btn-${item.color}` : ''}`} data-nav-link>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
        {mobileNavigation.map((item) => (
          <a href={item.href} class={`left-side-link nav-link-mobile${item.color ? ` nav-btn-${item.color}` : ''}`} data-nav-link>
            <span class="nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
    </div>
  )}
</header>

<script>
  const initScrollSpy = () => {
    const headerEl = document.querySelector('[data-top-header]');
    const menuToggle = document.querySelector('[data-top-menu-toggle]');
    const isMobileViewport = () => window.matchMedia('(max-width: 767px)').matches;
    let lastScrollY = window.scrollY;

    const syncTopMenuBodyClass = (isOpen) => {
      document.body.classList.toggle('top-menu-expanded', Boolean(isOpen));
      document.body.classList.toggle('mobile-menu-open', Boolean(isOpen) && isMobileViewport());
    };

    syncTopMenuBodyClass(false);

    // Restaurează starea meniului din sesiune anterioară (navigare între pagini)
    const MENU_KEY = 'top-menu-open';
    const wasOpen = sessionStorage.getItem(MENU_KEY) === 'true';

    if (headerEl && menuToggle) {
      if (wasOpen) {
        headerEl.classList.add('menu-open');
        menuToggle.setAttribute('aria-expanded', 'true');
        menuToggle.setAttribute('aria-label', 'Închide meniul principal');
        syncTopMenuBodyClass(true);
      }

      menuToggle.addEventListener('click', () => {
        const willOpen = !headerEl.classList.contains('menu-open');
        headerEl.classList.toggle('menu-open', willOpen);
        menuToggle.setAttribute('aria-expanded', String(willOpen));
        menuToggle.setAttribute('aria-label', willOpen ? 'Închide meniul principal' : 'Deschide meniul principal');
        syncTopMenuBodyClass(willOpen);
        sessionStorage.setItem(MENU_KEY, String(willOpen));
      });

      window.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (!headerEl.classList.contains('menu-open')) return;

        headerEl.classList.remove('menu-open');
        menuToggle.setAttribute('aria-expanded', 'false');
        menuToggle.setAttribute('aria-label', 'Deschide meniul principal');
        syncTopMenuBodyClass(false);
        sessionStorage.setItem(MENU_KEY, 'false');
      });

      window.addEventListener('resize', () => {
        if (!headerEl.classList.contains('menu-open')) return;
        syncTopMenuBodyClass(true);
      });
    }

    const links = Array.from(document.querySelectorAll('#top-menu-panel [data-nav-link]'));
    if (links.length === 0) return;

    const normalizePathnameFromHref = (href) => {
      if (!href || href.startsWith('#')) return null;
      if (href.startsWith('mailto:') || href.startsWith('tel:')) return null;

      const isHttp = href.startsWith('http://') || href.startsWith('https://');
      if (isHttp) {
        try {
          const url = new URL(href);
          if (url.origin !== window.location.origin) return null;
          return url.pathname.replace(/\/$/, '') || '/';
        } catch {
          return null;
        }
      }

      try {
        const url = new URL(href, window.location.origin);
        return url.pathname.replace(/\/$/, '') || '/';
      } catch {
        return null;
      }
    };

    const routeLinkMap = links
      .map((link) => {
        const href = link.getAttribute('href') ?? '';
        const pathname = normalizePathnameFromHref(href);
        if (!pathname) return null;
        return { link, href, pathname };
      })
      .filter(Boolean);

    const hashLinkMap = links
      .map((link) => {
        const href = link.getAttribute('href') ?? '';
        if (!href.startsWith('#')) return null;
        return { link, href };
      })
      .filter(Boolean);

    const setActiveByPathname = (pathname) => {
      if (!pathname) return;

      routeLinkMap.forEach((item) => {
        const isActive = item.pathname === pathname;
        item.link.classList.toggle('is-active', isActive);
        if (isActive) {
          item.link.setAttribute('aria-current', 'page');
        } else {
          item.link.removeAttribute('aria-current');
        }
      });

      // has-active pe containerul nav din top-menu-panel
      const topNav = document.querySelector('#top-menu-panel nav');
      if (topNav) {
        const anyActive = routeLinkMap.some((item) => item.pathname === pathname);
        topNav.classList.toggle('has-active', anyActive);
      }
    };

    const sectionMap = links
      .map((link) => {
        const href = link.getAttribute('href') ?? '';
        if (!href.startsWith('#')) return null;
        const section = document.querySelector(href);
        if (!section) return null;
        return { link, href, section };
      })
      .filter(Boolean);

    const hasSectionMap = sectionMap.length > 0;

    const uniqueSections = [];
    const seenSections = new Set();

    sectionMap.forEach((item) => {
      if (!seenSections.has(item.href)) {
        seenSections.add(item.href);
        uniqueSections.push({ href: item.href, section: item.section });
      }
    });

    let lastActiveHref = null;
    let pendingActiveHref = null;
    let ticking = false;

    const setActiveByHref = (activeHref) => {
      if (!activeHref) return;
      const changed = lastActiveHref !== activeHref;

      hashLinkMap.forEach(({ link, href }) => {
        const isActive = href === activeHref;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });

      if (changed) {
        hashLinkMap
          .filter((item) => item.href === activeHref)
          .forEach((item) => {
            item.link.classList.remove('just-activated');
            requestAnimationFrame(() => {
              item.link.classList.add('just-activated');
            });
          });
      }

      lastActiveHref = activeHref;

      // has-active pe containerul nav din top-menu-panel
      const topNav = document.querySelector('#top-menu-panel nav');
      if (topNav) topNav.classList.toggle('has-active', Boolean(activeHref));
    };

    const getHeaderSpyOffset = () => {
      const headerHeight = headerEl?.getBoundingClientRect().height ?? 0;
      return headerHeight + 8;
    };

    const hasReachedPendingSection = (marker, orderedSections, targetHref) => {
      const targetIndex = orderedSections.findIndex((item) => item.href === targetHref);
      if (targetIndex === -1) return null;

      const target = orderedSections[targetIndex];
      const next = orderedSections[targetIndex + 1];
      const nextTop = next ? next.top : Number.POSITIVE_INFINITY;

      return marker >= target.top && marker < nextTop;
    };

    const getActiveByScroll = () => {
      if (!hasSectionMap) return;

      const marker = window.scrollY + getHeaderSpyOffset();
      const orderedSections = [...uniqueSections]
        .map((item) => ({
          ...item,
          top: item.section.getBoundingClientRect().top + window.scrollY,
        }))
        .sort((a, b) => a.top - b.top);

      if (pendingActiveHref) {
        const reachedPending = hasReachedPendingSection(marker, orderedSections, pendingActiveHref);
        if (reachedPending === null) {
          pendingActiveHref = null;
        } else if (!reachedPending) {
          setActiveByHref(pendingActiveHref);
          return;
        } else {
          pendingActiveHref = null;
        }
      }

      let active = orderedSections[0];

      for (let index = 0; index < orderedSections.length; index += 1) {
        const current = orderedSections[index];
        const next = orderedSections[index + 1];
        const nextTop = next ? next.top : Number.POSITIVE_INFINITY;

        if (marker >= current.top && marker < nextTop) {
          active = current;
          break;
        }
      }

      setActiveByHref(active?.href);

    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        getActiveByScroll();

        if (headerEl) {
          const currentY = window.scrollY;
          headerEl.classList.remove('header-hidden');
          lastScrollY = currentY;
        }

        ticking = false;
      });
    };

    if (hasSectionMap) {
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    }

    links.forEach((link) => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href') ?? '';

        if (href.startsWith('#')) {
          const hasTargetSection = uniqueSections.some((item) => item.href === href);
          pendingActiveHref = hasTargetSection ? href : null;
          setActiveByHref(href);
        } else {
          const pathname = normalizePathnameFromHref(href);
          if (pathname) {
            setActiveByPathname(pathname);
          }
        }

      });
    });

    const currentPathname = window.location.pathname.replace(/\/$/, '') || '/';
    setActiveByPathname(currentPathname);

    if (hasSectionMap) {
      getActiveByScroll();
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollSpy, { once: true });
  } else {
    initScrollSpy();
  }
</script>
