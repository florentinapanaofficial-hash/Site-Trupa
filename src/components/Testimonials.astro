---
type Testimonial = {
  name: string;
  role: string;
  quote: string;
  avatarStyle: string;
  initials: string;
};

const testimonials: Testimonial[] = [
  {
    name: 'Familia Popescu',
    role: 'Nuntă — Iași, 2024',
    quote:
      'Formația a creat o atmosferă de neuitat. Toți invitații au dansat până dimineața. Recomandăm cu căldură!',
    avatarStyle: 'background: linear-gradient(135deg, #F5A623, #FFD700); box-shadow: 0 4px 14px rgba(245,166,35,0.45);',
    initials: 'FP',
  },
  {
    name: 'Familia Ionescu',
    role: 'Nuntă — Cluj-Napoca, 2024',
    quote:
      'Profesionalism desăvârșit. Muzica live a făcut diferența față de un DJ. Momentele cu mirii au fost emoționante.',
    avatarStyle: 'background: linear-gradient(135deg, #0BBCD6, #06d6ff); box-shadow: 0 4px 14px rgba(11,188,214,0.45);',
    initials: 'FI',
  },
  {
    name: 'Ana & Cristian',
    role: 'Petrecere privată — București, 2025',
    quote:
      'Au cântat toate piesele dorite de noi și au improvizat superb. Oaspeții au rămas uimiți de calitatea sunetului.',
    avatarStyle: 'background: linear-gradient(135deg, #E8325A, #ff6b8a); box-shadow: 0 4px 14px rgba(232,50,90,0.45);',
    initials: 'AC',
  },
];
---

<section id="testimonials" class="section-container py-14 sm:py-16">
  <header class="max-w-3xl animate-fade-up">
    <p class="section-kicker">Testimoniale</p>
    <h2 class="section-title">Clienți care își prezintă brandul cu încredere.</h2>
    <p class="section-description">
      Secțiunea de testimoniale consolidează încrederea și arată că soluția ta a fost
      deja validată de alții.
    </p>
  </header>

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    {testimonials.map((item) => (
      <figure class="card-soft flex h-full flex-col gap-4 p-5 sm:p-6 animate-fade-up">
        <div class="flex items-center gap-3">
          <div
            class="h-12 w-12 shrink-0 rounded-full inline-flex items-center justify-center text-sm font-bold text-white"
            style={item.avatarStyle}
            aria-hidden="true"
          >{item.initials}</div>
          <figcaption class="space-y-0.5">
            <div class="text-sm font-semibold" style="color: var(--title);">{item.name}</div>
            <div class="text-xs" style="color: var(--body); opacity: 0.7;">{item.role}</div>
          </figcaption>
        </div>
        <blockquote class="text-sm leading-relaxed" style="color: var(--body);">
          „{item.quote}”
        </blockquote>
      </figure>
    ))}
  </div>
</section>

