---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';
import { query as dbQuery } from '../lib/db.js';

const { seo, realMoments } = siteContent;
const isDevelopment = import.meta.env.DEV;

export const prerender = false;

let dbMomentPhotos: Array<{
  id: number;
  titlu: string;
  imagine_url: string;
  data_upload: string;
}> = [];

try {
  const rows = (await dbQuery(
    `SELECT id, titlu, imagine_url, data_upload
     FROM gallery
     WHERE imagine_url LIKE '/uploads/%'
     ORDER BY data_upload DESC, id DESC
     LIMIT 60`,
  )) as Array<{ id: number; titlu: string; imagine_url: string; data_upload: string }>;

  dbMomentPhotos = rows.filter((row) => typeof row.imagine_url === 'string' && row.imagine_url.startsWith('/uploads/'));
} catch (error) {
  console.error('Nu s-au putut citi pozele pentru galeria completă:', error);
}

const hasDbMomentPhotos = dbMomentPhotos.length > 0;

const deriveAudioUrlFromImage = (imageUrl: string) => {
  const cleanUrl = String(imageUrl || '').split('?')[0];
  const fileName = cleanUrl.split('/').pop() ?? '';
  const baseName = fileName.replace(/\.[^.]+$/, '');

  if (!baseName) return '';
  return `/uploads/audio/${baseName}.mp3`;
};

const albumSourcePhotos = hasDbMomentPhotos
  ? dbMomentPhotos.map((photo) => ({
      title: photo.titlu,
      image: photo.imagine_url,
      caption: `${photo.titlu} • ${new Date(photo.data_upload).toLocaleDateString('ro-RO')}`,
      audio: deriveAudioUrlFromImage(photo.imagine_url),
    }))
  : realMoments.events.map((item) => ({
      title: item.couple,
      image: item.image,
      caption: `${item.couple} • ${item.city} • ${item.date}`,
      audio: item.audioUrl ?? '',
    }));

const minimumPhotosForPreview = 12;
const demoPhotos = Array.from({ length: minimumPhotosForPreview }, (_, index) => {
  const photoNumber = index + 1;
  return {
    title: `Demo Album ${photoNumber}`,
    image: `https://placehold.co/900x1200/${photoNumber % 2 === 0 ? '1d2e5f' : '293d78'}/f1f7ff?text=Demo+${photoNumber}`,
    caption: `Cadru demo ${photoNumber} • verificare paginare`,
    audio: '',
  };
});

const paddedAlbumPhotos =
  albumSourcePhotos.length > 0
    ? albumSourcePhotos
    : [...realMoments.events.map((item) => ({
        title: item.couple,
        image: item.image,
        caption: `${item.couple} • ${item.city} • ${item.date}`,
        audio: item.audioUrl ?? '',
      })), ...demoPhotos];

const albumPhotos = paddedAlbumPhotos.slice(0, 60);
---

<BaseLayout title={`Povestea noastră rămâne în ecouri și imagini | ${seo.title}`} description="Galerie completă cu poze ale mirilor și trupei, cu upload drag-and-drop și redimensionare automată.">
  <section class="section-container py-16" id="momente-reale">
    <header class="section-head mx-auto text-center">
      <p class="kicker mx-auto">Galerie specială</p>
      <h1 class="section-title">Povestea noastră rămâne în ecouri și imagini</h1>
      <p class="section-copy">Album în format landscape, cu pagini stânga-dreapta ca o foaie A4 pe orizontală, ideal pentru cadre largi cu mirii și trupa.</p>
    </header>

    <div class="mt-5 flex flex-wrap justify-center gap-2">
      <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-cyan-100">
        {hasDbMomentPhotos ? `${dbMomentPhotos.length}+` : realMoments.stats.events} cadre
      </span>
      <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-lime-100">
        Upload drag and drop
      </span>
    </div>

    <section class="mx-auto mt-6 max-w-3xl rounded-2xl border border-white/20 bg-[#120722de] p-4 backdrop-blur">
      <div class="flex flex-wrap items-end gap-3">
        <label class="form-label m-0 flex-1 min-w-[220px]">
          Caută în galerie
          <input
            class="input-glass"
            type="search"
            data-album-search-input
            placeholder="Ex: Pitești, nuntă, Andreea și Florin"
            maxlength="120"
          />
        </label>
        <button type="button" class="btn-solid" data-album-search-button>Caută</button>
        <button type="button" class="btn-outline" data-album-search-clear>Resetează</button>
      </div>
      <p class="mt-2 text-xs font-semibold text-white/80" data-album-search-result>Se afișează toate fotografiile.</p>
    </section>

    <section class="mx-auto mt-6 max-w-3xl rounded-2xl border border-white/20 bg-[#140a2fe3] p-4 backdrop-blur">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-extrabold uppercase tracking-[0.08em] text-white">Upload poze miri + trupă</h2>
        <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/90">
          Redimensionare automată
        </span>
      </div>

      <form class="mt-3 grid gap-3" data-home-gallery-upload-form>
        <label class="form-label">
          Titlu fotografie
          <input
            class="input-glass"
            type="text"
            name="title"
            data-home-gallery-title
            placeholder="Ex: Mirii + formația - Pitești"
            minlength="2"
            maxlength="180"
            required
          />
        </label>

        <input id="home-gallery-photo-input" name="photo" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
        <input id="home-gallery-audio-input" name="audio" type="file" accept="audio/mpeg,.mp3" class="hidden" />

        <div
          class="rounded-xl border-2 border-dashed border-fuchsia-300/70 bg-fuchsia-500/10 p-4 text-center transition-all duration-200"
          data-home-gallery-dropzone
          role="button"
          tabindex="0"
          aria-label="Dropzone încărcare foto"
        >
          <p class="text-sm font-semibold text-white">Trage poza aici sau apasă pentru selecție</p>
          <p class="mt-1 text-xs text-white/90">Formate acceptate: JPG, PNG, WebP, max 5MB</p>
          <img data-home-gallery-preview class="mx-auto mt-3 hidden max-h-40 rounded-xl border border-white/20" alt="Preview fotografie" />
        </div>

        <div
          class="rounded-xl border-2 border-dashed border-cyan-300/70 bg-cyan-500/10 p-4 text-center transition-all duration-200"
          data-home-audio-dropzone
          role="button"
          tabindex="0"
          aria-label="Dropzone încărcare audio MP3"
        >
          <p class="text-sm font-semibold text-white">Trage MP3-ul testimonial aici sau apasă pentru selecție</p>
          <p class="mt-1 text-xs text-white/90">Opțional, dar recomandat pentru personalizare foto. Format: MP3, max 4MB</p>
          <p class="mt-2 text-xs font-semibold text-cyan-100" data-home-audio-file-name>Nu ai selectat audio.</p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <button type="button" class="btn-outline" data-home-gallery-dropzone-trigger>Selectează fișier</button>
          <button type="button" class="btn-outline" data-home-audio-dropzone-trigger>Selectează MP3</button>
          <button type="submit" class="btn-solid" data-home-gallery-submit>Optimizează și încarcă</button>
        </div>

        <input class="input-glass" type="text" readonly placeholder="URL imagine încărcată" data-home-gallery-url />

        <p class="hidden rounded-xl border px-3 py-2 text-xs" data-home-gallery-status aria-live="polite"></p>
      </form>
    </section>

    <div
      class="cinematic-album-wrap mt-10"
      data-home-gallery-grid
      data-home-gallery-source={hasDbMomentPhotos ? 'db' : 'fallback'}
      data-album-photos={JSON.stringify(albumPhotos)}
    >
      <div class="cinematic-album" role="region" aria-label="Album virtual cinematic">
        <div class="album-spine" aria-hidden="true"></div>
        <div class="album-flip-sheet" aria-hidden="true"></div>

        <article class="album-page album-page-left" data-album-page-left>
        </article>

        <article class="album-page album-page-right" data-album-page-right>
        </article>
      </div>

      <div class="album-controls" aria-label="Navigare album">
        <button type="button" class="album-nav-btn" data-album-prev aria-label="Pagina anterioară">Pagina anterioară</button>
        <p class="album-page-indicator" data-album-indicator>Pagina 1</p>
        <button type="button" class="album-nav-btn" data-album-next aria-label="Pagina următoare">Pagina următoare</button>
        <button type="button" class="album-sound-btn" data-album-sound-toggle aria-pressed="true" aria-label="Comută sunetul de întoarcere pagină">Sunet flip: ON</button>
      </div>
    </div>

    <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-white/85">{realMoments.consentNote}</p>

    <dialog id="photo-lightbox" class="photo-lightbox cinematic-lightbox">
      <div class="lightbox-balloons" aria-hidden="true">
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
        <span class="balloon-dot"></span>
      </div>
      <div class="lightbox-image-shell">
        <div class="lightbox-image-frame">
          <img id="photo-lightbox-image" src="" alt="" class="lightbox-image" />
        </div>
      </div>
      <p id="photo-lightbox-caption" class="lightbox-caption"></p>
      <div class="lightbox-frame-selector" aria-label="Alege stilul ramei">
        <button type="button" class="lightbox-frame-btn is-active" data-frame-theme-button="gold">Auriu</button>
        <button type="button" class="lightbox-frame-btn" data-frame-theme-button="silver">Argintiu</button>
        <button type="button" class="lightbox-frame-btn" data-frame-theme-button="wood">Lemn</button>
      </div>
      <div class="lightbox-size-selector" aria-label="Alege dimensiunea imaginii">
        <button type="button" class="lightbox-size-btn" data-lightbox-size-toggle>Preset: Normal</button>
      </div>
      <div class="lightbox-demo-sound-wrap">
        <button type="button" class="lightbox-demo-sound-btn" data-lightbox-demo-sound>Redă sunet demo</button>
      </div>
      <div class="lightbox-audio-wrap">
        <p id="photo-lightbox-audio-note" class="lightbox-audio-note hidden">Testimonial audio personalizat pentru această fotografie.</p>
        <button type="button" class="audio-play-btn" data-lightbox-audio-play aria-label="Redă testimonial audio">
          <span class="audio-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 9V15H7L12 20V4L7 9H3Z" fill="#eaf4ff"/>
              <path d="M16.5 12C16.5 13.1046 15.6046 14 14.5 14V10C15.6046 10 16.5 10.8954 16.5 12Z" fill="#eaf4ff"/>
              <path d="M19 12C19 15.3137 16.3137 18 13 18V16C15.2091 16 17 14.2091 17 12C17 9.79086 15.2091 8 13 8V6C16.3137 6 19 8.68629 19 12Z" fill="#eaf4ff"/>
            </svg>
          </span>
        </button>
        <audio id="photo-lightbox-audio" class="lightbox-audio hidden" controls preload="none"></audio>
      </div>
    </dialog>
  </section>

  <script>
    const lightbox = document.getElementById('photo-lightbox');
    const lightboxImage = document.getElementById('photo-lightbox-image');
    const lightboxCaption = document.getElementById('photo-lightbox-caption');
    const lightboxAudio = document.getElementById('photo-lightbox-audio');
    const lightboxAudioNote = document.getElementById('photo-lightbox-audio-note');
    const rootElement = document.documentElement;
    const frameThemeButtons = Array.from(document.querySelectorAll('[data-frame-theme-button]'));
    const lightboxDemoSoundButton = document.querySelector('[data-lightbox-demo-sound]');
    const lightboxSizeToggleButton = document.querySelector('[data-lightbox-size-toggle]');

    const albumRoot = document.querySelector('[data-home-gallery-grid]');
    const albumLeftPage = document.querySelector('[data-album-page-left]');
    const albumRightPage = document.querySelector('[data-album-page-right]');
    const cinematicAlbum = document.querySelector('.cinematic-album');
    const albumPrevButton = document.querySelector('[data-album-prev]');
    const albumNextButton = document.querySelector('[data-album-next]');
    const albumIndicator = document.querySelector('[data-album-indicator]');
    const albumSoundToggle = document.querySelector('[data-album-sound-toggle]');
    const albumSearchInput = document.querySelector('[data-album-search-input]');
    const albumSearchButton = document.querySelector('[data-album-search-button]');
    const albumSearchClearButton = document.querySelector('[data-album-search-clear]');
    const albumSearchResult = document.querySelector('[data-album-search-result]');

    const photosPerPage = 1;
    const photosPerSpread = photosPerPage * 2;
    const pageTurnDurationMs = 950;
    const pageTurnMidpointMs = Math.round(pageTurnDurationMs * 0.5);
    const soundStorageKey = 'fp-album-sound-enabled';
    const frameThemeStorageKey = 'fp-lightbox-frame-theme';
    const sizePresetStorageKey = 'fp-lightbox-size-preset';
    const rawAlbumPhotos = albumRoot?.getAttribute('data-album-photos') ?? '[]';
    let allAlbumPhotos = [];
    let albumPhotos = [];

    try {
      const parsed = JSON.parse(rawAlbumPhotos);
      allAlbumPhotos = Array.isArray(parsed) ? parsed : [];
      albumPhotos = [...allAlbumPhotos];
    } catch {
      allAlbumPhotos = [];
      albumPhotos = [];
    }

    let currentSpread = 0;
    let isTurningPage = false;
    let soundEnabled = window.localStorage.getItem(soundStorageKey) !== '0';
    let currentSearchTerm = '';
    let searchDebounceTimer = null;
    let currentFrameTheme = window.localStorage.getItem(frameThemeStorageKey) || 'gold';
    let currentSizePreset = window.localStorage.getItem(sizePresetStorageKey) || 'normal';
    let isClosingLightbox = false;

    const syncFrameThemeUi = () => {
      if (!(lightbox instanceof HTMLElement)) return;

      lightbox.setAttribute('data-frame-theme', currentFrameTheme);
      frameThemeButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        const isActive = button.getAttribute('data-frame-theme-button') === currentFrameTheme;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    };

    if (!['gold', 'silver', 'wood'].includes(currentFrameTheme)) {
      currentFrameTheme = 'gold';
    }

    syncFrameThemeUi();

    if (!['normal', 'large'].includes(currentSizePreset)) {
      currentSizePreset = 'normal';
    }

    const syncSizePresetUi = () => {
      if (!(lightbox instanceof HTMLElement)) return;

      lightbox.setAttribute('data-size-preset', currentSizePreset);

      if (!(lightboxSizeToggleButton instanceof HTMLButtonElement)) return;
      const isLarge = currentSizePreset === 'large';
      lightboxSizeToggleButton.textContent = isLarge ? 'Preset: Large (+10%)' : 'Preset: Normal';
      lightboxSizeToggleButton.setAttribute('aria-pressed', String(isLarge));
    };

    syncSizePresetUi();

    const updateSoundToggleUi = () => {
      if (!(albumSoundToggle instanceof HTMLButtonElement)) return;

      albumSoundToggle.textContent = soundEnabled ? 'Sunet flip: ON' : 'Sunet flip: OFF';
      albumSoundToggle.setAttribute('aria-pressed', String(soundEnabled));
    };

    updateSoundToggleUi();

    if (lightboxAudio instanceof HTMLAudioElement) {
      lightboxAudio.addEventListener('error', () => {
        lightboxAudio.classList.add('hidden');
        if (lightboxAudioNote instanceof HTMLElement) {
          lightboxAudioNote.classList.add('hidden');
        }
      });
    }

    const playPageFlipSound = () => {
      if (!soundEnabled) return;

      const AudioContextClass = window.AudioContext || window.webkitAudioContext;
      if (!AudioContextClass) return;

      const audioContext = new AudioContextClass();
      const masterGain = audioContext.createGain();
      masterGain.gain.setValueAtTime(0.75, audioContext.currentTime);
      masterGain.connect(audioContext.destination);

      const firstOsc = audioContext.createOscillator();
      const firstGain = audioContext.createGain();
      firstOsc.type = 'triangle';
      firstOsc.frequency.setValueAtTime(520, audioContext.currentTime);
      firstOsc.frequency.exponentialRampToValueAtTime(165, audioContext.currentTime + 0.21);
      firstGain.gain.setValueAtTime(0.0001, audioContext.currentTime);
      firstGain.gain.exponentialRampToValueAtTime(0.028, audioContext.currentTime + 0.03);
      firstGain.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.22);

      const secondOsc = audioContext.createOscillator();
      const secondGain = audioContext.createGain();
      secondOsc.type = 'sine';
      secondOsc.frequency.setValueAtTime(760, audioContext.currentTime + 0.09);
      secondOsc.frequency.exponentialRampToValueAtTime(240, audioContext.currentTime + 0.28);
      secondGain.gain.setValueAtTime(0.0001, audioContext.currentTime);
      secondGain.gain.exponentialRampToValueAtTime(0.016, audioContext.currentTime + 0.12);
      secondGain.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.3);

      firstOsc.connect(firstGain);
      secondOsc.connect(secondGain);
      firstGain.connect(masterGain);
      secondGain.connect(masterGain);

      firstOsc.start(audioContext.currentTime);
      firstOsc.stop(audioContext.currentTime + 0.24);

      secondOsc.start(audioContext.currentTime + 0.09);
      secondOsc.stop(audioContext.currentTime + 0.32);

      window.setTimeout(() => {
        audioContext.close().catch(() => {});
      }, 420);
    };

    const playDemoSound = () => {
      const AudioContextClass = window.AudioContext || window.webkitAudioContext;
      if (!AudioContextClass) return;

      const audioContext = new AudioContextClass();
      const masterGain = audioContext.createGain();
      masterGain.gain.setValueAtTime(0.5, audioContext.currentTime);
      masterGain.connect(audioContext.destination);

      const sequence = [392, 523.25, 659.25, 523.25];
      sequence.forEach((frequency, index) => {
        const oscillator = audioContext.createOscillator();
        const gain = audioContext.createGain();
        const startAt = audioContext.currentTime + index * 0.16;
        const stopAt = startAt + 0.14;

        oscillator.type = 'triangle';
        oscillator.frequency.setValueAtTime(frequency, startAt);

        gain.gain.setValueAtTime(0.0001, startAt);
        gain.gain.exponentialRampToValueAtTime(0.06, startAt + 0.03);
        gain.gain.exponentialRampToValueAtTime(0.0001, stopAt);

        oscillator.connect(gain);
        gain.connect(masterGain);
        oscillator.start(startAt);
        oscillator.stop(stopAt);
      });

      window.setTimeout(() => {
        audioContext.close().catch(() => {});
      }, 980);
    };

    const closeLightbox = () => {
      if (!lightbox || !lightbox.open) return;
      if (isClosingLightbox) return;

      isClosingLightbox = true;
      lightbox.classList.add('is-closing');

      window.setTimeout(() => {
        if (lightbox.open) {
          lightbox.close();
        }
      }, 210);
    };

    const lockPageScrollForLightbox = () => {
      rootElement.classList.add('lightbox-open-lock');
      document.body.classList.add('lightbox-open-lock');
    };

    const unlockPageScrollForLightbox = () => {
      rootElement.classList.remove('lightbox-open-lock');
      document.body.classList.remove('lightbox-open-lock');
    };

    const openLightboxFromTrigger = (trigger) => {
      if (!lightbox || !lightboxImage || !lightboxCaption) return;

      const src = trigger.getAttribute('data-lightbox-src') ?? '';
      const alt = trigger.getAttribute('data-lightbox-alt') ?? 'Fotografie eveniment';
      const caption = trigger.getAttribute('data-lightbox-caption') ?? '';
      const audioSrc = trigger.getAttribute('data-lightbox-audio') ?? '';

      lightboxImage.setAttribute('src', src);
      lightboxImage.setAttribute('alt', alt);
      lightboxCaption.textContent = caption;

      if (lightboxAudio instanceof HTMLAudioElement) {
        lightboxAudio.pause();
        lightboxAudio.removeAttribute('src');
        lightboxAudio.classList.add('hidden');
        lightboxAudio.load();

        if (audioSrc) {
          lightboxAudio.setAttribute('src', audioSrc);
          lightboxAudio.classList.remove('hidden');

          const playPromise = lightboxAudio.play();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(() => {});
          }
        }
      }

      if (lightboxAudioNote instanceof HTMLElement) {
        lightboxAudioNote.classList.toggle('hidden', !audioSrc);
      }

      isClosingLightbox = false;
      lightbox.classList.remove('is-closing');
      lockPageScrollForLightbox();
      lightbox.showModal();
    };

    const createAlbumCard = (photo, animationDelay = 0) => {
      const frame = document.createElement('article');
      frame.className = 'album-photo-frame gallery-stage-fade';
      frame.style.animationDelay = `${animationDelay}ms`;

      const trigger = document.createElement('button');
      trigger.type = 'button';
      trigger.className = 'moment-photo-trigger';
      trigger.setAttribute('data-lightbox-src', String(photo.image ?? ''));
      trigger.setAttribute('data-lightbox-alt', String(photo.title ?? 'Fotografie eveniment'));
      trigger.setAttribute('data-lightbox-caption', String(photo.caption ?? ''));
      trigger.setAttribute('data-lightbox-audio', String(photo.audio ?? ''));
      trigger.setAttribute('aria-label', `Deschide fotografia ${String(photo.title ?? 'eveniment')}`);

      const image = document.createElement('img');
      image.src = String(photo.image ?? '');
      image.alt = String(photo.title ?? 'Fotografie eveniment');
      image.loading = 'lazy';
      image.className = 'album-photo';

      const label = document.createElement('p');
      label.className = 'album-photo-label';
      label.textContent = String(photo.title ?? 'Moment special');

      trigger.append(image);
      frame.append(trigger, label);
      return frame;
    };

    const normalizeSearchText = (value) =>
      String(value ?? '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .trim();

    const updateSearchResultText = () => {
      if (!(albumSearchResult instanceof HTMLElement)) return;

      if (!currentSearchTerm) {
        albumSearchResult.textContent = `Se afișează toate fotografiile (${albumPhotos.length}).`;
        return;
      }

      albumSearchResult.textContent = `Rezultate pentru „${currentSearchTerm}”: ${albumPhotos.length}`;
    };

    const applyAlbumSearch = () => {
      const needle = normalizeSearchText(currentSearchTerm);

      if (!needle) {
        albumPhotos = [...allAlbumPhotos];
      } else {
        albumPhotos = allAlbumPhotos.filter((photo) => {
          const title = normalizeSearchText(photo?.title);
          const caption = normalizeSearchText(photo?.caption);
          return title.includes(needle) || caption.includes(needle);
        });
      }

      currentSpread = 0;
      renderSpread('next');
      updateSearchResultText();
    };

    const totalSpreads = () => Math.max(1, Math.ceil(albumPhotos.length / photosPerSpread));

    const updateAlbumControls = () => {
      const spreads = totalSpreads();

      if (albumIndicator) {
        if (albumPhotos.length === 0) {
          albumIndicator.textContent = 'Nu există rezultate pentru filtrul curent';
          return;
        }

        albumIndicator.textContent = `Pagini ${currentSpread * 2 + 1}-${Math.min(currentSpread * 2 + 2, spreads * 2)} din ${spreads * 2}`;
      }

      if (albumPrevButton instanceof HTMLButtonElement) {
        albumPrevButton.disabled = currentSpread <= 0 || isTurningPage;
      }

      if (albumNextButton instanceof HTMLButtonElement) {
        albumNextButton.disabled = currentSpread >= spreads - 1 || isTurningPage;
      }
    };

    const renderSpread = (direction = 'next') => {
      if (!(albumLeftPage instanceof HTMLElement) || !(albumRightPage instanceof HTMLElement)) return;

      const start = currentSpread * photosPerSpread;
      const leftPhotos = albumPhotos.slice(start, start + photosPerPage);
      const rightPhotos = albumPhotos.slice(start + photosPerPage, start + photosPerSpread);

      albumLeftPage.classList.remove('is-flipping-forward', 'is-flipping-backward');
      albumRightPage.classList.remove('is-flipping-forward', 'is-flipping-backward');

      if (direction === 'next') {
        albumRightPage.classList.add('is-flipping-forward');
      } else if (direction === 'prev') {
        albumLeftPage.classList.add('is-flipping-backward');
      }

      albumLeftPage.innerHTML = '';
      albumRightPage.innerHTML = '';

      if (albumPhotos.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'm-auto max-w-xs rounded-xl border border-white/20 bg-white/10 px-3 py-2 text-center text-sm font-semibold text-white/90';
        empty.textContent = 'Nu am găsit fotografii pentru această căutare.';
        albumLeftPage.appendChild(empty);
        updateAlbumControls();
        return;
      }

      leftPhotos.forEach((photo, index) => {
        albumLeftPage.appendChild(createAlbumCard(photo, index * 70));
      });

      rightPhotos.forEach((photo, index) => {
        albumRightPage.appendChild(createAlbumCard(photo, (index + photosPerPage) * 70));
      });

      updateAlbumControls();
    };

    renderSpread('next');
    updateSearchResultText();

    const runSearchFromInput = () => {
      if (!(albumSearchInput instanceof HTMLInputElement)) return;
      currentSearchTerm = albumSearchInput.value.trim();
      applyAlbumSearch();
    };

    albumSearchButton?.addEventListener('click', runSearchFromInput);

    albumSearchInput?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        runSearchFromInput();
      }
    });

    albumSearchInput?.addEventListener('input', () => {
      if (searchDebounceTimer) {
        window.clearTimeout(searchDebounceTimer);
      }

      searchDebounceTimer = window.setTimeout(() => {
        runSearchFromInput();
      }, 220);
    });

    albumSearchClearButton?.addEventListener('click', () => {
      if (albumSearchInput instanceof HTMLInputElement) {
        albumSearchInput.value = '';
      }
      currentSearchTerm = '';
      applyAlbumSearch();
    });

    const turnAlbumPage = (direction, onHalfTurn) => {
      if (!(cinematicAlbum instanceof HTMLElement) || isTurningPage) return;

      isTurningPage = true;
      updateAlbumControls();
      playPageFlipSound();

      cinematicAlbum.classList.remove('is-turning-next', 'is-turning-prev');
      cinematicAlbum.classList.add(direction === 'next' ? 'is-turning-next' : 'is-turning-prev');

      if (albumRoot instanceof HTMLElement) {
        albumRoot.classList.add('is-turning');
      }

      window.setTimeout(() => {
        onHalfTurn();
      }, pageTurnMidpointMs);

      window.setTimeout(() => {
        cinematicAlbum.classList.remove('is-turning-next', 'is-turning-prev');
        albumRoot?.classList.remove('is-turning');
        isTurningPage = false;
        updateAlbumControls();
      }, pageTurnDurationMs);
    };

    albumSoundToggle?.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      window.localStorage.setItem(soundStorageKey, soundEnabled ? '1' : '0');
      updateSoundToggleUi();
    });

    albumPrevButton?.addEventListener('click', () => {
      if (currentSpread <= 0) return;
      turnAlbumPage('prev', () => {
        currentSpread -= 1;
        renderSpread('prev');
      });
    });

    albumNextButton?.addEventListener('click', () => {
      if (currentSpread >= totalSpreads() - 1) return;
      turnAlbumPage('next', () => {
        currentSpread += 1;
        renderSpread('next');
      });
    });

    albumRoot?.addEventListener('click', (event) => {
      const trigger = event.target instanceof Element ? event.target.closest('[data-lightbox-src]') : null;
      if (!trigger) return;
      openLightboxFromTrigger(trigger);
    });

    if (lightbox && lightboxImage && lightboxCaption) {
      // Keep exit click-only: prevent default ESC/cancel close behavior.
      lightbox.addEventListener('cancel', (event) => {
        event.preventDefault();
      });

      lightboxDemoSoundButton?.addEventListener('click', () => {
        playDemoSound();
      });

      lightboxSizeToggleButton?.addEventListener('click', () => {
        currentSizePreset = currentSizePreset === 'large' ? 'normal' : 'large';
        window.localStorage.setItem(sizePresetStorageKey, currentSizePreset);
        syncSizePresetUi();
      });

      frameThemeButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        button.addEventListener('click', () => {
          const theme = button.getAttribute('data-frame-theme-button') || 'gold';
          currentFrameTheme = theme;
          window.localStorage.setItem(frameThemeStorageKey, currentFrameTheme);
          syncFrameThemeUi();
        });
      });

      lightbox.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (
          target?.closest('.lightbox-frame-selector') ||
          target?.closest('.lightbox-size-selector') ||
          target?.closest('.lightbox-demo-sound-wrap') ||
          target?.closest('.lightbox-audio-wrap')
        ) {
          return;
        }

        closeLightbox();
      });

      lightbox.addEventListener('close', () => {
        isClosingLightbox = false;
        lightbox.classList.remove('is-closing');
        unlockPageScrollForLightbox();
        lightboxImage.setAttribute('src', '');
        lightboxImage.setAttribute('alt', '');
        lightboxCaption.textContent = '';

        if (lightboxAudio instanceof HTMLAudioElement) {
          lightboxAudio.pause();
          lightboxAudio.removeAttribute('src');
          lightboxAudio.classList.add('hidden');
          lightboxAudio.load();
        }

        if (lightboxAudioNote instanceof HTMLElement) {
          lightboxAudioNote.classList.add('hidden');
        }
      });
    }

    const homeGalleryUploadForm = document.querySelector('[data-home-gallery-upload-form]');
    const homeGalleryDropzone = document.querySelector('[data-home-gallery-dropzone]');
    const homeGalleryDropzoneTrigger = document.querySelector('[data-home-gallery-dropzone-trigger]');
    const homeAudioDropzone = document.querySelector('[data-home-audio-dropzone]');
    const homeAudioDropzoneTrigger = document.querySelector('[data-home-audio-dropzone-trigger]');
    const homeAudioFileName = document.querySelector('[data-home-audio-file-name]');
    const homeGalleryFileInput = document.getElementById('home-gallery-photo-input');
    const homeGalleryAudioInput = document.getElementById('home-gallery-audio-input');
    const homeGalleryTitleInput = document.querySelector('[data-home-gallery-title]');
    const homeGalleryPreview = document.querySelector('[data-home-gallery-preview]');
    const homeGalleryStatus = document.querySelector('[data-home-gallery-status]');
    const homeGalleryUrlInput = document.querySelector('[data-home-gallery-url]');
    const homeGallerySubmitButton = document.querySelector('[data-home-gallery-submit]');

    let selectedHomeGalleryFile = null;
    let selectedHomeGalleryAudioFile = null;

    const showHomeGalleryStatus = (message, type = 'info') => {
      if (!homeGalleryStatus) return;

      homeGalleryStatus.textContent = message;
      homeGalleryStatus.classList.remove('hidden', 'border-red-300/50', 'bg-red-500/10', 'text-red-100', 'border-lime-300/50', 'bg-lime-500/10', 'text-lime-100', 'border-white/30', 'bg-white/10', 'text-white');

      if (type === 'error') {
        homeGalleryStatus.classList.add('border-red-300/50', 'bg-red-500/10', 'text-red-100');
        return;
      }

      if (type === 'success') {
        homeGalleryStatus.classList.add('border-lime-300/50', 'bg-lime-500/10', 'text-lime-100');
        return;
      }

      homeGalleryStatus.classList.add('border-white/30', 'bg-white/10', 'text-white');
    };

    const validateHomeGalleryFile = (file) => {
      const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
      if (!allowedTypes.includes((file.type || '').toLowerCase())) {
        return 'Sunt permise doar fișiere JPG, PNG și WebP.';
      }

      if (file.size > 5 * 1024 * 1024) {
        return 'Fișierul este prea mare. Limita este 5MB.';
      }

      return '';
    };

    const validateHomeGalleryAudioFile = (file) => {
      const mime = (file.type || '').toLowerCase();
      const ext = (file.name || '').toLowerCase().split('.').pop() ?? '';
      const isMp3 = mime === 'audio/mpeg' || mime === 'audio/mp3' || ext === 'mp3';

      if (!isMp3) {
        return 'Fișierul audio trebuie să fie MP3.';
      }

      if (file.size > 4 * 1024 * 1024) {
        return 'Fișierul audio este prea mare. Limita este 4MB.';
      }

      return '';
    };

    const setHomeGalleryPreview = (file) => {
      if (!(homeGalleryPreview instanceof HTMLImageElement)) return;

      const objectUrl = URL.createObjectURL(file);
      homeGalleryPreview.src = objectUrl;
      homeGalleryPreview.classList.remove('hidden');
      homeGalleryPreview.onload = () => {
        URL.revokeObjectURL(objectUrl);
      };
    };

    const resizeHomeGalleryFile = async (file) => {
      const imageUrl = URL.createObjectURL(file);

      try {
        const imageElement = await new Promise((resolve, reject) => {
          const image = new Image();
          image.onload = () => resolve(image);
          image.onerror = () => reject(new Error('Nu s-a putut procesa imaginea.'));
          image.src = imageUrl;
        });

        const maxWidth = 1400;
        const maxHeight = 1400;
        const scale = Math.min(maxWidth / imageElement.width, maxHeight / imageElement.height, 1);
        const targetWidth = Math.max(1, Math.round(imageElement.width * scale));
        const targetHeight = Math.max(1, Math.round(imageElement.height * scale));

        const canvas = document.createElement('canvas');
        canvas.width = targetWidth;
        canvas.height = targetHeight;

        const context = canvas.getContext('2d');
        if (!context) return file;

        context.drawImage(imageElement, 0, 0, targetWidth, targetHeight);

        const blob = await new Promise((resolve) => {
          canvas.toBlob((result) => resolve(result), 'image/webp', 0.86);
        });

        if (!(blob instanceof Blob)) return file;
        const optimizedName = file.name.replace(/\.[^.]+$/, '') + '.webp';
        return new File([blob], optimizedName, { type: 'image/webp' });
      } finally {
        URL.revokeObjectURL(imageUrl);
      }
    };

    const handleHomeGalleryFile = async (file) => {
      const error = validateHomeGalleryFile(file);
      if (error) {
        selectedHomeGalleryFile = null;
        showHomeGalleryStatus(error, 'error');
        return;
      }

      showHomeGalleryStatus('Optimizăm fotografia înainte de upload...', 'info');

      try {
        const optimizedFile = await resizeHomeGalleryFile(file);
        selectedHomeGalleryFile = optimizedFile;
        setHomeGalleryPreview(optimizedFile);
        showHomeGalleryStatus(`Fișier pregătit: ${optimizedFile.name}`, 'info');
      } catch {
        selectedHomeGalleryFile = file;
        setHomeGalleryPreview(file);
        showHomeGalleryStatus(`Fișier pregătit: ${file.name}`, 'info');
      }
    };

    const handleHomeGalleryAudioFile = (file) => {
      const error = validateHomeGalleryAudioFile(file);
      if (error) {
        selectedHomeGalleryAudioFile = null;
        if (homeAudioFileName instanceof HTMLElement) {
          homeAudioFileName.textContent = 'Nu ai selectat audio.';
        }
        showHomeGalleryStatus(error, 'error');
        return;
      }

      selectedHomeGalleryAudioFile = file;
      if (homeAudioFileName instanceof HTMLElement) {
        homeAudioFileName.textContent = `Audio pregătit: ${file.name}`;
      }
      showHomeGalleryStatus('Fișier audio pregătit pentru upload.', 'info');
    };

    if (homeGalleryDropzone && homeGalleryFileInput instanceof HTMLInputElement) {
      homeGalleryDropzone.addEventListener('click', () => homeGalleryFileInput.click());

      homeGalleryDropzone.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          homeGalleryFileInput.click();
        }
      });

      homeGalleryFileInput.addEventListener('change', () => {
        const file = homeGalleryFileInput.files?.[0];
        if (!file) return;
        handleHomeGalleryFile(file);
      });

      homeGalleryDropzone.addEventListener('dragover', (event) => {
        event.preventDefault();
        homeGalleryDropzone.classList.add('border-lime-300', 'bg-lime-500/15');
      });

      homeGalleryDropzone.addEventListener('dragleave', () => {
        homeGalleryDropzone.classList.remove('border-lime-300', 'bg-lime-500/15');
      });

      homeGalleryDropzone.addEventListener('drop', (event) => {
        event.preventDefault();
        homeGalleryDropzone.classList.remove('border-lime-300', 'bg-lime-500/15');

        const file = event.dataTransfer?.files?.[0];
        if (!file) return;
        handleHomeGalleryFile(file);
      });
    }

    homeGalleryDropzoneTrigger?.addEventListener('click', () => {
      if (homeGalleryFileInput instanceof HTMLInputElement) {
        homeGalleryFileInput.click();
      }
    });

    if (homeAudioDropzone && homeGalleryAudioInput instanceof HTMLInputElement) {
      homeAudioDropzone.addEventListener('click', () => homeGalleryAudioInput.click());

      homeAudioDropzone.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          homeGalleryAudioInput.click();
        }
      });

      homeGalleryAudioInput.addEventListener('change', () => {
        const file = homeGalleryAudioInput.files?.[0];
        if (!file) return;
        handleHomeGalleryAudioFile(file);
      });

      homeAudioDropzone.addEventListener('dragover', (event) => {
        event.preventDefault();
        homeAudioDropzone.classList.add('border-cyan-200', 'bg-cyan-500/20');
      });

      homeAudioDropzone.addEventListener('dragleave', () => {
        homeAudioDropzone.classList.remove('border-cyan-200', 'bg-cyan-500/20');
      });

      homeAudioDropzone.addEventListener('drop', (event) => {
        event.preventDefault();
        homeAudioDropzone.classList.remove('border-cyan-200', 'bg-cyan-500/20');

        const file = event.dataTransfer?.files?.[0];
        if (!file) return;
        handleHomeGalleryAudioFile(file);
      });
    }

    homeAudioDropzoneTrigger?.addEventListener('click', () => {
      if (homeGalleryAudioInput instanceof HTMLInputElement) {
        homeGalleryAudioInput.click();
      }
    });

    homeGalleryUploadForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const photoTitle =
        homeGalleryTitleInput instanceof HTMLInputElement
          ? homeGalleryTitleInput.value.trim()
          : '';

      if (photoTitle.length < 2 || photoTitle.length > 180) {
        showHomeGalleryStatus('Titlul fotografiei trebuie să aibă între 2 și 180 de caractere.', 'error');
        return;
      }

      if (!(selectedHomeGalleryFile instanceof File)) {
        showHomeGalleryStatus('Selectează mai întâi o imagine validă.', 'error');
        return;
      }

      if (homeGallerySubmitButton instanceof HTMLButtonElement) {
        homeGallerySubmitButton.disabled = true;
        homeGallerySubmitButton.textContent = 'Se procesează...';
      }

      try {
        const formData = new FormData();
        formData.append('photo', selectedHomeGalleryFile);
        formData.append('title', photoTitle);
        if (selectedHomeGalleryAudioFile instanceof File) {
          formData.append('audio', selectedHomeGalleryAudioFile);
        }

        const response = await fetch('/api/upload-photo', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(data.error || 'Upload-ul a eșuat.');
        }

        if (homeGalleryUrlInput instanceof HTMLInputElement) {
          homeGalleryUrlInput.value = data.url || '';
        }

        if (albumRoot && data.url) {
          if (albumRoot.getAttribute('data-home-gallery-source') === 'fallback') {
            window.location.reload();
            return;
          }

          const safeTitle = String(data.title || photoTitle);
          const newPhoto = {
            title: safeTitle,
            image: String(data.url),
            caption: `${safeTitle} • ${new Date().toLocaleDateString('ro-RO')}`,
            audio: String(data.audioUrl || `/uploads/audio/${String(data.url).split('/').pop()?.replace(/\.[^.]+$/, '') || ''}.mp3`),
          };

          allAlbumPhotos.unshift(newPhoto);

          const normalizedNeedle = normalizeSearchText(currentSearchTerm);
          const matchesFilter =
            !normalizedNeedle ||
            normalizeSearchText(newPhoto.title).includes(normalizedNeedle) ||
            normalizeSearchText(newPhoto.caption).includes(normalizedNeedle);

          if (matchesFilter) {
            albumPhotos.unshift(newPhoto);
          }

          currentSpread = 0;
          renderSpread('next');
          updateSearchResultText();
        }

        showHomeGalleryStatus('Imagine încărcată cu succes în galerie.', 'success');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Eroare la upload.';
        showHomeGalleryStatus(message, 'error');
      } finally {
        if (homeGallerySubmitButton instanceof HTMLButtonElement) {
          homeGallerySubmitButton.disabled = false;
          homeGallerySubmitButton.textContent = 'Optimizează și încarcă';
        }
      }
    });
  </script>

