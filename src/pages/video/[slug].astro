---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteContent from '../../data/siteContent.json';
import BackButton from '../../components/BackButton.astro';
import { sanitizeUrl } from '../../lib/sanitize-url';

export function getStaticPaths() {
  const slugify = (value: string) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');

  return siteContent.videos.map((video) => {
    const baseSlug = slugify(video.title);
    const slug = `${baseSlug}-${video.youtubeId.toLowerCase()}`;

    return {
      params: { slug },
      props: { video },
    };
  });
}

const { video } = Astro.props as {
  video: {
    title: string;
    youtubeId: string;
    youtubeUrl?: string;
    category?: string;
  };
};

const pageTitle = `${video.title} | Video live | Formația Florentina Pană`;
const pageDescription = `Urmărește ${video.title}, moment live din repertoriul Formația Florentina Pană. Vezi clipul complet și distribuie pagina.`;
const ogImage = `https://img.youtube.com/vi/${video.youtubeId}/maxresdefault.jpg`;
const youtubeUrl = sanitizeUrl(video.youtubeUrl ?? `https://www.youtube.com/watch?v=${video.youtubeId}`);

const videoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: video.title,
  description: pageDescription,
  thumbnailUrl: ogImage,
  embedUrl: `https://www.youtube.com/embed/${video.youtubeId}`,
  contentUrl: youtubeUrl,
  publisher: {
    '@type': 'Organization',
    name: siteContent.brand.name,
    url: 'https://florentinapanaofficial.ro',
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage={ogImage} ogType="video.other">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(videoJsonLd)} />
  </Fragment>
  <section class="section-container py-16">
    <div class="mb-8"><BackButton href="/galerie-video" label="Galerie Video" /></div>

    <header class="section-head mx-auto text-center">
      <p class="kicker">Video individual</p>
      <h1 class="section-title">{video.title}</h1>
      <p class="section-copy max-w-3xl mx-auto">
        Pagină optimizată SEO pentru acest clip. Poți viziona momentul live direct mai jos sau pe YouTube.
      </p>
    </header>

    <article class="glass-card mx-auto mt-8 max-w-4xl">
      <div class="video-embed-shell">
        <iframe
          class="aspect-video w-full rounded-xl"
          src={`https://www.youtube.com/embed/${video.youtubeId}`}
          title={video.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        />
        <div class="video-embed-overlay" aria-hidden="true"></div>
      </div>

      <div class="mt-4 flex flex-wrap gap-3">
        {video.category && (
          <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-cyan-100">
            {video.category}
          </span>
        )}
        <a
          href={youtubeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-cyan-100 transition hover:-translate-y-0.5 hover:border-cyan-200/50 hover:bg-cyan-300/10"
        >
          Vezi pe YouTube
        </a>
      </div>
    </article>
  </section>
</BaseLayout>
