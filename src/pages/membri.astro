---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';
import BackButton from '../components/BackButton.astro';

const { brand, team } = siteContent;
const vocalists = (team as any)?.vocalists ?? [];
const instrumentalists = (team as any)?.instrumentalists ?? [];
const collaborators = (team as any)?.collaborators ?? [];
---

<BaseLayout
  title={`Membrii formației | ${brand.name}`}
  description={`Cunoaște echipa Formației Florentina Pană — vocaliști, instrumentiști și colaboratori invitați.`}
>
  <section class="mb-section section-container py-16">
    <div class="mb-8"><BackButton href="/" label="Acasă" /></div>

    <div class="mb-header">
      <span class="mb-kicker">Echipa noastră</span>
      <h1 class="mb-title">Membrii Formației</h1>
      <p class="mb-lead">Muzicieni profesioniști cu experiență pe sute de scene din România</p>
    </div>

    {/* ── Vocaliști ── */}
    {vocalists.length > 0 && (
      <div class="mb-group">
        <h2 class="mb-group-title">Vocaliști</h2>
        <div class="mb-grid">
          {vocalists.map((member: any) => (
            <div class="mb-card">
              <div class="mb-photo-wrap">
                {member.image && member.image.trim() !== '' ? (
                  <img
                    src={member.image}
                    alt={member.name}
                    class="mb-photo"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                  />
                ) : (
                  <div class="mb-photo mb-photo--placeholder" aria-hidden="true">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  </div>
                )}
              </div>
              <div class="mb-info">
                <span class="mb-name">{member.name}</span>
                <span class="mb-role">{member.role}</span>
                {member.description && (
                  <p class="mb-desc">{member.description}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ── Instrumentiști ── */}
    {instrumentalists.length > 0 && (
      <div class="mb-group">
        <h2 class="mb-group-title">Instrumentiști</h2>
        <div class="mb-grid">
          {instrumentalists.map((member: any) => (
            <div class="mb-card">
              <div class="mb-photo-wrap">
                {member.image && member.image.trim() !== '' ? (
                  <img
                    src={member.image}
                    alt={member.name}
                    class="mb-photo"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                  />
                ) : (
                  <div class="mb-photo mb-photo--placeholder" aria-hidden="true">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  </div>
                )}
              </div>
              <div class="mb-info">
                <span class="mb-name">{member.name}</span>
                <span class="mb-role">{member.role}</span>
                {member.description && (
                  <p class="mb-desc">{member.description}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ── Colaboratori ── */}
    {collaborators.length > 0 && (
      <div class="mb-group">
        <h2 class="mb-group-title">Colaboratori invitați</h2>
        <div class="mb-grid mb-grid--collab">
          {collaborators.map((member: any) => (
            <div class="mb-card">
              <div class="mb-photo-wrap">
                {member.image && member.image.trim() !== '' ? (
                  <img
                    src={member.image}
                    alt={member.name}
                    class="mb-photo"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                  />
                ) : (
                  <div class="mb-photo mb-photo--placeholder" aria-hidden="true">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  </div>
                )}
              </div>
              <div class="mb-info">
                <span class="mb-name">{member.name}</span>
                <span class="mb-role">{member.role}</span>
                {member.description && (
                  <p class="mb-desc">{member.description}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </section>
</BaseLayout>

<style>
  .mb-section {
    max-width: 72rem;
  }

  .mb-header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .mb-kicker {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(241, 229, 172, 0.52);
    margin-bottom: 0.6rem;
  }

  .mb-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    margin: 0 0 0.85rem;
    line-height: 1.1;
  }

  .mb-lead {
    font-size: 0.95rem;
    color: rgba(200, 210, 230, 0.65);
    margin: 0 auto;
    max-width: 50ch;
    line-height: 1.6;
  }

  .mb-group {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .mb-group-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(241, 229, 172, 0.60);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 0.65rem;
    margin-bottom: 1.5rem;
  }

  .mb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .mb-grid--collab {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .mb-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 1.25rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 250ms ease, box-shadow 250ms ease, transform 250ms ease;
  }

  .mb-card:hover {
    border-color: rgba(160, 90, 255, 0.40);
    box-shadow: 0 12px 36px rgba(100, 40, 200, 0.20);
    transform: translateY(-3px);
  }

  .mb-photo-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }

  .mb-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 350ms ease;
  }

  .mb-card:hover .mb-photo {
    transform: scale(1.05);
  }

  .mb-photo--placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.18);
  }

  .mb-info {
    padding: 1.2rem 1.35rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .mb-name {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #fff;
    line-height: 1.2;
  }

  .mb-role {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(241, 229, 172, 0.55);
    margin-bottom: 0.35rem;
  }

  .mb-desc {
    font-size: 0.86rem;
    color: rgba(200, 215, 240, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .mb-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 400px) {
    .mb-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
