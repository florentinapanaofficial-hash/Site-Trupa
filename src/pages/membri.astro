---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';
import BackButton from '../components/BackButton.astro';

const { membri, colaboratori: colaboratoriData } = siteContent as any;
const allMembri: any[] = membri ?? [];
const solisti        = allMembri.filter((m: any) => m.categorie === 'solisti');
const instrumentisti = allMembri.filter((m: any) => m.categorie === 'instrumentisti');
const colaboratori: any[] = colaboratoriData ?? [];

function initiale(name: string): string {
  return name.split(' ').filter(Boolean).map((w) => w[0]).join('').slice(0, 2).toUpperCase();
}
---

<BaseLayout
  title="Membrii Formației Florentina Pană | Muzicieni Profesioniști Pitești România"
  description="Cunoaște echipa formației Florentina Pană — soliști vocali și instrumentiști cu experiență de peste 20 ani pe scenele din România. Disponibili pentru nunți, botezuri și evenimente corporate în Pitești și toată țara."
>
  <!-- ═══ SOLIȘTI VOCALI ═══ -->
  <section class="mem-section" aria-labelledby="sec-solisti">
    <div class="mem-sec-head">
      <h2 class="mem-sec-title" id="sec-solisti">Soliști Vocali</h2>
      <div class="mem-sec-line" aria-hidden="true"></div>
    </div>

    {solisti.map((m: any, i: number) => (
      <div class="member-card-wrap" data-index={i}>
        <article class="member-card">
          <!-- FOTO -->
          <div class="mc-photo-col">
            {m.imagine && m.imagine.trim() !== '' ? (
              <img
                src={m.imagine}
                alt={`${m.nume} - ${m.rol} - Formația Florentina Pană Pitești`}
                class="mc-photo-img"
                loading="lazy"
                decoding="async"
                width="400"
                height="800"
              />
            ) : (
              <div class="mc-photo-ph" aria-hidden="true">
                <span class="mc-initials">{initiale(m.nume)}</span>
                <span class="mc-ph-label">Foto în curând</span>
              </div>
            )}
          </div>

          <!-- CONȚINUT -->
          <div class="mc-content-col">
            <span class="mc-cat-badge mc-cat-badge--solist">Solist Vocal</span>
            <h3 class="mc-name">{m.nume}</h3>
            <p class="mc-spec">{m.specialitate}</p>
            {m.experienta && m.experienta.trim() !== '' && (
              <p class="mc-exp">⭐ {m.experienta}</p>
            )}

            <!-- Galerie placeholder -->
            <div class="mc-gallery" role="list" aria-label={`Galerie foto ${m.nume}`}>
              {[1,2,3,4,5,6].map((n) => (
                <div
                  class="mc-gallery-ph gallery-thumb"
                  role="listitem"
                  data-fx={String(n)}
                  data-src={`https://placehold.co/800x600/0f2545/e8c85b?text=${encodeURIComponent(m.nume)}`}
                  data-alt={`${m.nume} la eveniment - Formația Florentina Pană`}
                  tabindex="0"
                  title="Click pentru previzualizare"
                >
                  <span class="mc-gal-icon" aria-hidden="true">📷</span>
                  <small class="mc-gal-label">{m.nume} la eveniment</small>
                  <span class="mc-gal-overlay" aria-hidden="true">🔍</span>
                </div>
              ))}
            </div>

            <!-- Buton BIO circular -->
            <button
              class="bio-btn"
              type="button"
              aria-expanded="false"
              aria-controls={`bio-panel-s${i}`}
              aria-label={`Biografie ${m.nume}`}
            >
              <span class="bio-btn-text">BIO</span>
            </button>
          </div>
        </article>

        <!-- Panel biografie -->
        <div class="bio-panel" id={`bio-panel-s${i}`} aria-hidden="true">
          {m.citat && (
            <blockquote class="bio-quote">
              <p>{m.citat}</p>
            </blockquote>
          )}
          <p class="bio-text">{m.bio}</p>
          {m.taguri && m.taguri.length > 0 && (
            <div class="bio-tags" aria-label="Specializări">
              {m.taguri.map((tag: string) => (
                <span class="bio-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══ DIVIDER ═══ -->
  <div class="mem-divider" aria-hidden="true"></div>

  <!-- ═══ INSTRUMENTIȘTI ═══ -->
  <section class="mem-section" aria-labelledby="sec-instr">
    <div class="mem-sec-head">
      <h2 class="mem-sec-title" id="sec-instr">Instrumentiști</h2>
      <div class="mem-sec-line" aria-hidden="true"></div>
    </div>

    {instrumentisti.map((m: any, i: number) => (
      <div class="member-card-wrap" data-index={i}>
        <article class="member-card">
          <!-- FOTO -->
          <div class="mc-photo-col">
            {m.imagine && m.imagine.trim() !== '' ? (
              <img
                src={m.imagine}
                alt={`${m.nume} - ${m.rol} - ${m.specialitate} - Formația Florentina Pană Pitești`}
                class="mc-photo-img"
                loading="lazy"
                decoding="async"
                width="400"
                height="800"
              />
            ) : (
              <div class="mc-photo-ph" aria-hidden="true">
                <span class="mc-initials">{initiale(m.nume)}</span>
                <span class="mc-ph-label">Foto în curând</span>
              </div>
            )}
          </div>

          <!-- CONȚINUT -->
          <div class="mc-content-col">
            <span class="mc-cat-badge mc-cat-badge--instr">Instrumentist</span>
            <h3 class="mc-name">{m.nume}</h3>
            <p class="mc-spec">{m.specialitate}</p>

            <!-- Galerie placeholder -->
            <div class="mc-gallery" role="list" aria-label={`Galerie foto ${m.nume}`}>
              {[1,2,3,4,5,6].map((n) => (
                <div
                  class="mc-gallery-ph gallery-thumb"
                  role="listitem"
                  data-fx={String(n)}
                  data-src={`https://placehold.co/800x600/0f2545/e8c85b?text=${encodeURIComponent(m.nume)}`}
                  data-alt={`${m.nume} la eveniment - Formația Florentina Pană`}
                  tabindex="0"
                  title="Click pentru previzualizare"
                >
                  <span class="mc-gal-icon" aria-hidden="true">📷</span>
                  <small class="mc-gal-label">{m.nume} la eveniment</small>
                  <span class="mc-gal-overlay" aria-hidden="true">🔍</span>
                </div>
              ))}
            </div>

            <!-- Buton BIO circular -->
            <button
              class="bio-btn"
              type="button"
              aria-expanded="false"
              aria-controls={`bio-panel-in${i}`}
              aria-label={`Biografie ${m.nume}`}
            >
              <span class="bio-btn-text">BIO</span>
            </button>
          </div>
        </article>

        <!-- Panel biografie -->
        <div class="bio-panel" id={`bio-panel-in${i}`} aria-hidden="true">
          {m.citat && (
            <blockquote class="bio-quote">
              <p>{m.citat}</p>
            </blockquote>
          )}
          <p class="bio-text">{m.bio}</p>
          {m.taguri && m.taguri.length > 0 && (
            <div class="bio-tags" aria-label="Specializări">
              {m.taguri.map((tag: string) => (
                <span class="bio-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══ DIVIDER ═══ -->
  <div class="mem-divider" aria-hidden="true"></div>

  <!-- ═══ COLABORATORI ═══ -->
  <section class="mem-section" aria-labelledby="sec-colab">
    <div class="mem-sec-head">
      <h2 class="mem-sec-title" id="sec-colab">Colaboratori</h2>
      <div class="mem-sec-line" aria-hidden="true"></div>
    </div>
    {colaboratori.map((m: any, i: number) => (
      <div class="member-card-wrap" data-index={i}>
        <article class="member-card">
          <!-- FOTO -->
          <div class="mc-photo-col">
            {m.imagine && m.imagine.trim() !== '' ? (
              <img
                src={m.imagine}
                alt={`${m.nume} - ${m.specialitate} - Formația Florentina Pană Pitești`}
                class="mc-photo-img"
                loading="lazy"
                decoding="async"
                width="400"
                height="800"
              />
            ) : (
              <div class="mc-photo-ph" aria-hidden="true">
                <span class="mc-initials">{initiale(m.nume)}</span>
                <span class="mc-ph-label">Foto în curând</span>
              </div>
            )}
          </div>

          <!-- CONȚINUT -->
          <div class="mc-content-col">
            <span class="mc-cat-badge mc-cat-badge--colab">Colaborator</span>
            <h3 class="mc-name">{m.nume}</h3>
            <p class="mc-spec">{m.specialitate}</p>
            {m.experienta && m.experienta.trim() !== '' && (
              <p class="mc-exp">⭐ {m.experienta}</p>
            )}

            <!-- Galerie placeholder -->
            <div class="mc-gallery" role="list" aria-label={`Galerie foto ${m.nume}`}>
              {[1,2,3,4,5,6].map((n) => (
                <div
                  class="mc-gallery-ph gallery-thumb"
                  role="listitem"
                  data-fx={String(n)}
                  data-src={`https://placehold.co/800x600/0f2545/e8c85b?text=${encodeURIComponent(m.nume)}`}
                  data-alt={`${m.nume} la eveniment - Formația Florentina Pană`}
                  tabindex="0"
                  title="Click pentru previzualizare"
                >
                  <span class="mc-gal-icon" aria-hidden="true">📷</span>
                  <small class="mc-gal-label">{m.nume} la eveniment</small>
                  <span class="mc-gal-overlay" aria-hidden="true">🔍</span>
                </div>
              ))}
            </div>

            <!-- Buton BIO circular -->
            <button
              class="bio-btn"
              type="button"
              aria-expanded="false"
              aria-controls={`bio-panel-co${i}`}
              aria-label={`Biografie ${m.nume}`}
            >
              <span class="bio-btn-text">BIO</span>
            </button>
          </div>
        </article>

        <!-- Panel biografie -->
        <div class="bio-panel" id={`bio-panel-co${i}`} aria-hidden="true">
          {m.citat && (
            <blockquote class="bio-quote">
              <p>{m.citat}</p>
            </blockquote>
          )}
          <p class="bio-text">{m.bio}</p>
          {m.taguri && m.taguri.length > 0 && (
            <div class="bio-tags" aria-label="Specializări">
              {m.taguri.map((tag: string) => (
                <span class="bio-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══ GALLERY POPUP OVERLAY ═══ -->
  <div id="gallery-popup" role="dialog" aria-modal="true" aria-label="Foto mărit">
    <div id="gallery-popup-inner">
      <img id="gallery-popup-img" src="" alt="" />
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('.bio-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const wrap = btn.closest<HTMLElement>('.member-card-wrap');
      if (!wrap) return;
      const panel = wrap.querySelector<HTMLElement>('.bio-panel');
      if (!panel) return;
      const isOpen = panel.classList.contains('open');

      // Închide toate celelalte paneluri
      document.querySelectorAll<HTMLElement>('.bio-panel.open').forEach((p) => {
        p.classList.remove('open');
        p.setAttribute('aria-hidden', 'true');
      });
      document.querySelectorAll<HTMLElement>('.bio-btn.active').forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        panel.classList.add('open');
        panel.setAttribute('aria-hidden', 'false');
        btn.classList.add('active');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Click în afara închide panelul
  document.addEventListener('click', () => {
    document.querySelectorAll<HTMLElement>('.bio-panel.open').forEach((p) => {
      p.classList.remove('open');
      p.setAttribute('aria-hidden', 'true');
    });
    document.querySelectorAll<HTMLElement>('.bio-btn.active').forEach((b) => {
      b.classList.remove('active');
      b.setAttribute('aria-expanded', 'false');
    });
  });

  // ═══ GALLERY POPUP FX ═══
  const fxMap: Record<string, { enter: string; leave: string }> = {
    '1': { enter: 'fx-pop-in',      leave: 'fx-pop-out'      },
    '2': { enter: 'fx-warp-in',     leave: 'fx-warp-out'     },
    '3': { enter: 'fx-rubber-in',   leave: 'fx-rubber-out'   },
    '4': { enter: 'fx-flip-in',     leave: 'fx-flip-out'     },
    '5': { enter: 'fx-splat-in',    leave: 'fx-splat-out'    },
    '6': { enter: 'fx-spindrop-in', leave: 'fx-spindrop-out' },
  };

  const popup    = document.getElementById('gallery-popup')!;
  const popupImg = document.getElementById('gallery-popup-img') as HTMLImageElement;
  let currentFx  = '1';

  function openPopup(src: string, alt: string, fx: string) {
    const anim = fxMap[fx] ?? fxMap['1'];
    popupImg.src = src;
    popupImg.alt = alt;
    popupImg.classList.remove(...Object.values(fxMap).flatMap((v) => [v.enter, v.leave]));
    popup.classList.add('active');
    popupImg.classList.add(anim.enter);
  }

  function closePopup(fx: string = currentFx) {
    const anim = fxMap[fx] ?? fxMap['1'];
    popupImg.classList.remove(...Object.values(fxMap).flatMap((v) => [v.enter, v.leave]));
    popupImg.classList.add(anim.leave);
    popupImg.addEventListener('animationend', () => {
      popup.classList.remove('active');
      popupImg.src = '';
      popupImg.alt = '';
      popupImg.classList.remove(anim.leave);
    }, { once: true });
  }

  document.querySelectorAll<HTMLElement>('.gallery-thumb').forEach((thumb) => {
    thumb.addEventListener('click', (e) => {
      e.stopPropagation();
      const fx  = thumb.dataset.fx  ?? '1';
      const src = thumb.dataset.src ?? '';
      const alt = thumb.dataset.alt ?? '';
      currentFx = fx;
      openPopup(src, alt, fx);
    });
  });

  popup.addEventListener('click', () => closePopup(currentFx));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup.classList.contains('active')) closePopup(currentFx);
  });
</script>

<style>
  /* ══════════════════════════════════════════
     SECȚIUNI PAGINĂ
  ══════════════════════════════════════════ */
  .mem-section {
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2rem);
    max-width: 900px;
    margin-inline: auto;
  }

  .mem-sec-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .mem-sec-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(0, 200, 255, 0.85);
    white-space: nowrap;
    margin: 0;
  }

  .mem-sec-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(0,200,255,0.35), transparent);
  }

  /* ── Divider entre secțiuni ── */
  .mem-divider {
    height: 1px;
    background: rgba(255,255,255,0.05);
    max-width: 900px;
    margin: 0 auto clamp(1.5rem, 3vw, 2.5rem);
  }

  /* ══════════════════════════════════════════
     WRAPPER CARD COMPLET (card + bio panel)
  ══════════════════════════════════════════ */
  .member-card-wrap {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 1.25rem;
    overflow: visible;
  }

  /* ══════════════════════════════════════════
     CARD — 2 coloane desktop
  ══════════════════════════════════════════ */
  .member-card {
    position: relative;
    display: grid;
    grid-template-columns: 35% 65%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-bottom: none;
    border-radius: 1.25rem 1.25rem 0 0;
    overflow: hidden;
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 300ms ease,
      border-color 300ms ease;
  }

  /* hover doar pe dispozitive cu pointer precis — evită sticky-hover pe touch */
  @media (hover: hover) and (pointer: fine) {
    .member-card-wrap:hover .member-card {
      transform: translateY(-4px);
      border-color: rgba(0, 200, 255, 0.40);
      box-shadow:
        0 0 0 1px rgba(0, 200, 255, 0.22),
        0 0 28px rgba(0, 200, 255, 0.14),
        0 12px 40px rgba(0, 80, 160, 0.30);
    }
  }

  .member-card-wrap:focus-within .member-card {
    transform: translateY(-4px);
    border-color: rgba(0, 200, 255, 0.40);
    box-shadow:
      0 0 0 1px rgba(0, 200, 255, 0.22),
      0 0 28px rgba(0, 200, 255, 0.14),
      0 12px 40px rgba(0, 80, 160, 0.30);
  }

  /* ── Coloana foto ── */
  .mc-photo-col {
    position: relative;
    overflow: hidden;
    min-height: 500px;
    background: linear-gradient(160deg, #0f2545 0%, #142f5a 60%, #0a1a35 100%);
  }

  .mc-photo-img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 2;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 400ms ease;
  }

  .member-card-wrap:hover .mc-photo-img {
    transform: scale(1.05);
  }

  /* Placeholder foto */
  .mc-photo-ph {
    width: 100%;
    height: 100%;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: linear-gradient(160deg, #0f2545 0%, #1d3f78 45%, #0f2545 100%);
  }

  .mc-initials {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #e8c85b 0%, #ffeaa0 50%, #e8c85b 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: brightness(1.2);
    line-height: 1;
  }

  .mc-ph-label {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
  }

  /* ── Coloana conținut ── */
  .mc-content-col {
    position: relative;
    padding: 1.5rem 4rem 1.5rem 1.5rem; /* dreapta: spațiu pentru buton BIO */
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  /* Badge categorie */
  .mc-cat-badge {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.28em 0.85em;
    border-radius: 9999px;
    align-self: flex-start;
  }

  .mc-cat-badge--solist {
    background: rgba(220, 160, 40, 0.12);
    color: rgba(241, 220, 140, 0.92);
    border: 1px solid rgba(220, 175, 80, 0.30);
  }

  .mc-cat-badge--instr {
    background: rgba(0, 200, 255, 0.10);
    color: rgba(0, 220, 255, 0.88);
    border: 1px solid rgba(0, 200, 255, 0.25);
  }

  .mc-cat-badge--colab {
    background: rgba(168, 85, 247, 0.12);
    color: rgba(210, 160, 255, 0.92);
    border: 1px solid rgba(168, 85, 247, 0.28);
  }

  /* Nume */
  .mc-name {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #ffffff;
    margin: 0;
    line-height: 1.1;
  }

  /* Specialitate */
  .mc-spec {
    font-size: 0.82rem;
    color: rgba(180, 200, 235, 0.72);
    margin: 0;
    font-style: italic;
  }

  /* Experiență */
  .mc-exp {
    font-size: 0.75rem;
    color: rgba(200, 215, 240, 0.58);
    margin: 0;
  }

  /* ── Mini galerie (3 placeholder-e 4/3) ── */
  .mc-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
    margin-top: auto;
  }

  .mc-gallery-ph {
    position: relative;
    aspect-ratio: 4 / 3;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .mc-gallery-ph.gallery-thumb:hover,
  .mc-gallery-ph.gallery-thumb:focus {
    border-color: rgba(232, 200, 91, 0.5);
    box-shadow: 0 0 8px rgba(232, 200, 91, 0.35);
    outline: none;
  }

  .mc-gal-icon { font-size: 1rem; line-height: 1; }

  .mc-gal-label {
    font-size: 0.44rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.20);
    text-align: center;
    padding: 0 0.25rem;
    line-height: 1.2;
  }

  .mc-gal-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    background: rgba(0, 0, 0, 0.38);
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.18s;
    pointer-events: none;
  }

  .mc-gallery-ph:hover .mc-gal-overlay,
  .mc-gallery-ph:focus .mc-gal-overlay {
    opacity: 1;
  }

  /* ══════════════════════════════════════════
     BUTON BIO CIRCULAR PULSANT
  ══════════════════════════════════════════ */
  @keyframes bio-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,200,255,0.60); }
    50%       { box-shadow: 0 0 0 10px rgba(0,200,255,0.00); }
  }

  .bio-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00c8ff 0%, #0066ff 100%);
    border: none;
