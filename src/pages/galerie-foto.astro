---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';

const { seo, gallery } = siteContent;
---

<BaseLayout title={`Galerie Foto | ${seo.title}`} description="Galerie foto cu momente din evenimentele Formației Florentina Pană.">
  <section class="section-container py-16">
    <header class="section-head mx-auto text-center">
      <p class="kicker">Galerie Foto</p>
      <h1 class="section-title">Cadre din evenimente reale</h1>
      <p class="section-copy">Selectăm constant fotografii reprezentative pentru atmosferă, energie și eleganță.</p>
    </header>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {gallery.map((item) => (
        item.image ? (
          <article class="gallery-img-card">
            <img src={item.image} alt={item.alt} class="gallery-img" loading="lazy" decoding="async" />
          </article>
        ) : (
          <article class="gallery-placeholder-card" role="img" aria-label={item.alt}>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--gold);opacity:0.45"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <span class="gallery-placeholder-text">{item.alt}</span>
          </article>
        )
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <a href="/comunitatea-noastra#galerie" class="btn-outline">Galeria extinsă din comunitate</a>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-img-card {
    aspect-ratio: 4/3;
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--line);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }
  .gallery-img-card:hover {
    transform: scale(1.02);
    box-shadow: 0 16px 36px rgba(245,166,35,0.16);
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .gallery-placeholder-card {
    aspect-ratio: 4/3;
    border-radius: 1.25rem;
    border: 1px dashed var(--line);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem;
    transition: border-color 220ms ease;
  }
  .gallery-placeholder-card:hover {
    border-color: rgba(245,166,35,0.4);
  }
  .gallery-placeholder-text {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: center;
  }
</style>
