---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';

const { seo, contact, team, videos, gallery } = siteContent;
const hasRealPhoto = (imageUrl) => typeof imageUrl === 'string' && imageUrl.trim() !== '' && !imageUrl.includes('placehold.co');
const hasRealGalleryImage = (imageUrl) =>
  typeof imageUrl === 'string' && imageUrl.trim() !== '' && !imageUrl.includes('placehold.co');
const getInitials = (fullName) =>
  String(fullName || '')
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((chunk) => chunk[0]?.toUpperCase() ?? '')
    .join('');
const homepageVideos = (videos || [])
  .filter((item) => typeof item?.youtubeId === 'string' && item.youtubeId.trim() !== '' && !item.youtubeId.startsWith('ID_'))
  .slice(0, 3);
---

<BaseLayout title={seo.title} description={seo.description} ogImage={seo.ogImage}>

  {/* ═══════════════════════════════════════════
      HERO — Scenă, titlu mare, CTA-uri
  ═══════════════════════════════════════════ */}
  <section id="acasa" class="hero-stage" aria-label="Secțiunea principală">
    <div class="hero-stage-inner">

      <span class="kicker-badge" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.38Z"/></svg>
        Muzică live — România
      </span>

      <h1 class="hero-title-xl">
        Formația<br/>
        <span class="hero-title-gold">Florentina Pană</span>
      </h1>

      <p class="hero-lead">
        Energie, emoție și profesionalism pe orice scenă.<br/>
        De la nunți și botezuri la evenimente corporate și concerte.
      </p>

      <div class="hero-ctas">
        <a href={`tel:${contact.phoneRaw}`} class="btn-solid">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.6a16 16 0 0 0 6.07 6.07l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          Sună acum
        </a>
        <a href="#video" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Vezi videoclipuri
        </a>
      </div>

      {/* Stat pills */}
      <div class="hero-stats" aria-label="Statistici formație">
        <div class="hero-stat-pill">
          <span class="hero-stat-num">10+</span>
          <span class="hero-stat-label">ani experiență</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">500+</span>
          <span class="hero-stat-label">evenimente</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">100%</span>
          <span class="hero-stat-label">live</span>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      VIDEO
  ═══════════════════════════════════════════ */}
  <section id="video" class="concert-section">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Scena noastră</span>
        <h2 class="section-title">Videoclipuri live &amp; cover-uri</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Momente live, energie pură și interpretări care ridică publicul în picioare.
        </p>
      </header>

      {homepageVideos.length > 0 ? (
        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {homepageVideos.map((item) => (
            <article class="video-concert-card">
              <div class="video-concert-frame">
                <iframe
                  src={`https://www.youtube.com/embed/${item.youtubeId}`}
                  title={item.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="video-concert-label">{item.title}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-2xl border border-[rgba(245,166,35,0.2)] bg-[rgba(255,255,255,0.03)] p-8 text-center">
          <p class="text-sm" style="color:var(--muted)">Videoclipurile vor apărea aici după completarea conținutului.</p>
        </div>
      )}

      <div class="mt-10 text-center">
        <a href="/video" class="btn-outline">Toate videoclipurile</a>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      DESPRE NOI
  ═══════════════════════════════════════════ */}
  <section id="despre" class="concert-section-alt">
    <div class="concert-section-inner grid md:grid-cols-2 gap-14 items-center">
      <div class="space-y-6">
        <span class="section-kicker-pill">Povestea noastră</span>
        <h2 class="section-title" style="text-align:left">Despre noi</h2>

        <p style="color:var(--body); line-height:1.75">
          Formația <strong style="color:var(--gold)">Florentina Pană</strong> este o trupă de muzică live
          cu experiență vastă în evenimente private, nunți, botezuri și petreceri corporate.
          Punem accent pe energie, emoție și profesionalism, oferind un spectacol complet
          care ridică publicul în picioare.
        </p>
        <p style="color:var(--muted); line-height:1.75">
          Repertoriul acoperă muzică populară românească, ușoară, cover-uri internaționale,
          muzică de petrecere și momente speciale personalizate pentru fiecare eveniment.
        </p>

        <a href="#contact" class="btn-solid" style="display:inline-flex">Rezervă o dată</a>
      </div>

      {/* Imagine / placeholder formație */}
      <div class="despre-photo-frame" aria-label="Fotografie formație">
        <div class="despre-photo-inner">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--gold); opacity:0.5"><path d="m9 18 6-6-6-6"/></svg>
          <p style="color:var(--muted); font-size:0.85rem; margin-top:0.5rem">Foto formație — în curând</p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      SERVICII
  ═══════════════════════════════════════════ */}
  <section id="servicii" class="concert-section">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Ce oferim</span>
        <h2 class="section-title">Servicii muzicale live</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Pachete complete, adaptate la orice tip de eveniment.
        </p>
      </header>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <article class="service-card">
          <div class="service-icon" aria-hidden="true">💍</div>
          <h3 class="service-title">Nuntă</h3>
          <p class="service-desc">Program complet de la primire până la petrecere, momente speciale și atmosferă garantată.</p>
        </article>
        <article class="service-card">
          <div class="service-icon" aria-hidden="true">🍼</div>
          <h3 class="service-title">Botez</h3>
          <p class="service-desc">Muzică live caldă, repertoriu special, emoție autentică pentru cel mai important prim pas.</p>
        </article>
        <article class="service-card">
          <div class="service-icon" aria-hidden="true">🏢</div>
          <h3 class="service-title">Corporate</h3>
          <p class="service-desc">Show profesionist, rafinat, perfect pentru gale, team-building-uri și lansări de produse.</p>
        </article>
        <article class="service-card">
          <div class="service-icon" aria-hidden="true">🎸</div>
          <h3 class="service-title">Concert</h3>
          <p class="service-desc">Set-uri complete de concert live, cu repertoriu adaptat publicului și logistică proprie.</p>
        </article>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      MEMBRI
  ═══════════════════════════════════════════ */}
  <section id="membri" class="concert-section-alt">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Echipa</span>
        <h2 class="section-title">Membrii formației</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Soliști vocali, instrumentiști și colaboratori speciali — o echipă completă pentru evenimente memorabile.
        </p>
      </header>

      {/* Grid carduri principale */}
      <div class="members-cards-grid">
        {team.vocalists.map((member) => (
          <article class="member-card member-card--gold">
            <div class="member-card-photo">
              {hasRealPhoto(member.image) ? (
                <img src={member.image} alt={`Portret ${member.name}`} loading="lazy" decoding="async" />
              ) : (
                <div class="member-card-initials member-card-initials--gold" aria-hidden="true">
                  {getInitials(member.name)}
                </div>
              )}
              <span class="member-card-badge member-card-badge--gold">Solistă vocală</span>
            </div>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--gold">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
            </div>
          </article>
        ))}
        {team.instrumentalists.map((member) => (
          <article class="member-card member-card--teal">
            <div class="member-card-photo">
              {hasRealPhoto(member.image) ? (
                <img src={member.image} alt={`Portret ${member.name}`} loading="lazy" decoding="async" />
              ) : (
                <div class="member-card-initials member-card-initials--teal" aria-hidden="true">
                  {getInitials(member.name)}
                </div>
              )}
              <span class="member-card-badge member-card-badge--teal">Instrumentist</span>
            </div>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--teal">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
            </div>
          </article>
        ))}
        {team.collaborators.map((member) => (
          <article class="member-card member-card--rose">
            <div class="member-card-photo">
              <div class="member-card-initials member-card-initials--rose" aria-hidden="true">
                {member.instrument === 'Saxofon' ? '🎷' : '🥁'}
              </div>
              <span class="member-card-badge member-card-badge--rose">Colaborator invitat</span>
            </div>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--rose">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
              {member.instrument === 'Saxofon' && (
                <a href="/colaboratori/saxofon" class="member-card-link">Prezentare completă →</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      REPERTORIU
  ═══════════════════════════════════════════ */}
  <section id="repertoriu" class="concert-section">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Ce cântăm</span>
        <h2 class="section-title">Repertoriu muzical</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Un mix echilibrat care acoperă toate gusturile — de la tradițional la internațional.
        </p>
      </header>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="repertoire-card">
          <span class="repertoire-icon" aria-hidden="true">🎻</span>
          <h3 class="repertoire-title">Muzică populară</h3>
          <p class="repertoire-desc">Folclor autentic românesc, interpretări vii și pasionale.</p>
        </div>
        <div class="repertoire-card">
          <span class="repertoire-icon" aria-hidden="true">🌍</span>
          <h3 class="repertoire-title">Cover-uri internaționale</h3>
          <p class="repertoire-desc">Hiturile momentului și clasicii evergreen în aranjamente live.</p>
        </div>
        <div class="repertoire-card">
          <span class="repertoire-icon" aria-hidden="true">🎵</span>
          <h3 class="repertoire-title">Muzică ușoară</h3>
          <p class="repertoire-desc">Povești muzicale românești interpretate cu suflet.</p>
        </div>
        <div class="repertoire-card">
          <span class="repertoire-icon" aria-hidden="true">🎉</span>
          <h3 class="repertoire-title">Muzică de petrecere</h3>
          <p class="repertoire-desc">Energy nonstop — ritmuri care țin publicul pe ringul de dans.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      GALERIE
  ═══════════════════════════════════════════ */}
  <section id="galerie" class="concert-section-alt">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Momente live</span>
        <h2 class="section-title">Galerie foto</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Imagini surprinse pe scenă, energie reală, publicul nostru.
        </p>
      </header>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {(gallery || []).slice(0, 6).map((item) => (
          hasRealGalleryImage(item.image) ? (
            <article class="gallery-concert-card">
              <img
                src={item.image}
                alt={item.alt}
                loading="lazy"
                decoding="async"
                class="gallery-concert-img"
              />
            </article>
          ) : (
            <article class="gallery-concert-placeholder" aria-label={`Slot foto: ${item.alt}`}>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--gold); opacity:0.4"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              <p class="gallery-placeholder-label">{item.alt || 'Foto în curând'}</p>
            </article>
          )
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/galerie-foto" class="btn-outline">Galerie completă</a>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      FAQ
  ═══════════════════════════════════════════ */}
  <section id="faq" class="concert-section">
    <div class="concert-section-inner" style="max-width:52rem">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">FAQ</span>
        <h2 class="section-title">Întrebări frecvente</h2>
      </header>

      <div class="mt-12 faq-list" role="list">

        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>Vă deplasați în toată România?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <p class="faq-answer">Da, ne deplasăm oriunde în România. Costurile de transport sunt incluse sau negociate separat, în funcție de distanță.</p>
        </details>

        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>Putem personaliza repertoriul?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <p class="faq-answer">Desigur. Adaptăm programul muzical în funcție de preferințele voastre — trimiteți-ne lista de piese favorite la rezervare.</p>
        </details>

        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>Cu cât timp înainte trebuie să rezervăm?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <p class="faq-answer">Recomandăm să ne contactați cu cel puțin 3-6 luni înainte pentru evenimente mari (nunți, botezuri). Pentru corporate sau concerte mai mici, 4-6 săptămâni sunt suficiente.</p>
        </details>

        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>Aveți echipament propriu de sonorizare?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <p class="faq-answer">Da, dispunem de echipament profesional complet — sistem de sunet, lumini și tot ce este necesar pentru un show de calitate.</p>
        </details>

        <details class="faq-item" role="listitem">
          <summary class="faq-question">
            <span>Care este durata unui program live?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <p class="faq-answer">Un program standard cuprinde 4-6 ore de muzică live cu pauze, adaptat la tipul și durata evenimentului vostru.</p>
        </details>

      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      CONTACT
  ═══════════════════════════════════════════ */}
  <section id="contact" class="concert-section-alt">
    <div class="concert-section-inner grid md:grid-cols-2 gap-14 items-start">

      {/* Info contact */}
      <div class="space-y-8">
        <div>
          <span class="section-kicker-pill">Scrie-ne</span>
          <h2 class="section-title" style="text-align:left; margin-top:0.75rem">Hai să discutăm</h2>
          <p class="section-copy" style="margin-top:0.6rem">
            Suntem gata să facem evenimentul tău de neuitat. Trimite-ne un mesaj și îți răspundem în maxim 24h.
          </p>
        </div>

        <div class="contact-info-list">
          <a href={`tel:${contact.phoneRaw}`} class="contact-info-row" aria-label={`Sună la ${contact.phoneDisplay}`}>
            <span class="contact-info-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" ><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.6a16 16 0 0 0 6.07 6.07l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            </span>
            <div>
              <span class="contact-info-label">Telefon</span>
              <span class="contact-info-value">{contact.phoneDisplay}</span>
            </div>
          </a>

          <a href={`mailto:${contact.email}`} class="contact-info-row" aria-label={`Trimite email la ${contact.email}`}>
            <span class="contact-info-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <div>
              <span class="contact-info-label">Email</span>
              <span class="contact-info-value">{contact.email}</span>
            </div>
          </a>
        </div>
      </div>

      {/* Formular */}
      <form
        class="contact-form"
        action="/api/comentarii"
        method="POST"
        name="contact-formatie"
        aria-label="Formular de contact"
      >
        <div class="contact-form-grid">
          <div class="contact-field">
            <label for="cf-name" class="contact-label">Nume complet <span aria-hidden="true" style="color:var(--rose)">*</span></label>
            <input id="cf-name" name="name" type="text" required autocomplete="name"
              placeholder="Ex: Maria Ionescu" class="input-glass w-full" />
          </div>

          <div class="contact-field">
            <label for="cf-phone" class="contact-label">Telefon <span aria-hidden="true" style="color:var(--rose)">*</span></label>
            <input id="cf-phone" name="phone" type="tel" required autocomplete="tel"
              placeholder="07xx xxx xxx" class="input-glass w-full" />
          </div>

          <div class="contact-field contact-field-full">
            <label for="cf-email" class="contact-label">Email</label>
            <input id="cf-email" name="email" type="email" autocomplete="email"
              placeholder="email@exemplu.ro" class="input-glass w-full" />
          </div>

          <div class="contact-field contact-field-full">
            <label for="cf-event" class="contact-label">Tipul evenimentului <span aria-hidden="true" style="color:var(--rose)">*</span></label>
            <select id="cf-event" name="eventType" required class="input-glass w-full">
              <option value="" disabled selected>Selectează...</option>
              <option value="nunta">Nuntă</option>
              <option value="botez">Botez</option>
              <option value="corporate">Eveniment corporate</option>
              <option value="concert">Concert</option>
              <option value="altul">Alt tip de eveniment</option>
            </select>
          </div>

          <div class="contact-field contact-field-full">
            <label for="cf-date" class="contact-label">Data evenimentului (aproximativ)</label>
