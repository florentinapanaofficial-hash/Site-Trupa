---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';

const { seo, contact, team, videos, gallery, faq } = siteContent;
import { sanitizeUrl } from '../lib/sanitize-url';

const socialLinks = {
  youtube:   sanitizeUrl(siteContent.socialLinks?.youtube),
  facebook:  sanitizeUrl(siteContent.socialLinks?.facebook),
  instagram: sanitizeUrl(siteContent.socialLinks?.instagram),
  tiktok:    sanitizeUrl(siteContent.socialLinks?.tiktok),
};
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: (faq as Array<{ question: string; answer: string }>).map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
const hasRealPhoto = (imageUrl) => typeof imageUrl === 'string' && imageUrl.trim() !== '' && !imageUrl.includes('placehold.co');
const hasRealGalleryImage = (imageUrl) =>
  typeof imageUrl === 'string' && imageUrl.trim() !== '' && !imageUrl.includes('placehold.co');
const getInitials = (fullName) =>
  String(fullName || '')
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((chunk) => chunk[0]?.toUpperCase() ?? '')
    .join('');
const homepageVideos = (videos || [])
  .filter((item) => typeof item?.youtubeId === 'string' && item.youtubeId.trim() !== '' && !item.youtubeId.startsWith('ID_'))
  .slice(0, 3);
---

<BaseLayout title={seo.title} description={seo.description} ogImage={seo.ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </Fragment>

  {/* ═══════════════════════════════════════════
      HERO — Scenă, titlu mare, CTA-uri
  ═══════════════════════════════════════════ */}
  <section id="acasa" class="hero-stage" aria-label="Secțiunea principală">
    <div class="astral-orb" aria-hidden="true"></div>
    <div class="hero-stars" aria-hidden="true"></div>
    <div class="hero-stage-inner">

      <span class="kicker-badge" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.38Z"/></svg>
        Muzică live — România
      </span>

      {/* Card foto — vizibil doar pe mobil, colțuri rotunjite */}
      <div class="hero-photo-card">
        <img
          src="/images/hero-photo.jpg"
          alt="Formația Florentina Pană"
          class="hero-photo-img"
          loading="eager"
          width="320"
          height="213"
        />
      </div>

      <h1 class="hero-title-xl">
        <span class="hero-kicker-text">Formația</span><br/>
        <span class="hero-title-gold">Florentina Pană</span>
      </h1>

      <p class="hero-lead">
        Energie, emoție și profesionalism pe orice scenă.<br/>
        De la nunți și botezuri la evenimente corporate și concerte.
      </p>

      <div class="hero-ctas">
        <a href={`tel:${contact.phoneRaw}`} class="btn-solid">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.6a16 16 0 0 0 6.07 6.07l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          Sună acum
        </a>
        <a href="/galerie-video" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Galerie video
        </a>
        <a href="https://wa.me/40767369658?text=Bun%C4%83%20ziua!%20A%C8%99%20dori%20s%C4%83%20rezerv%20Forma%C8%9Bia%20Florentina%20Pan%C4%83%20pentru%20evenimentul%20meu." class="btn-outline" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.556 4.122 1.528 5.854L0 24l6.335-1.508A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 0 1-4.964-1.342l-.356-.211-3.765.896.953-3.671-.232-.376A9.785 9.785 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
          Rezervă pe WhatsApp
        </a>
      </div>

      {/* Stat pills */}
      <div class="hero-stats" aria-label="Statistici formație">
        <div class="hero-stat-pill">
          <span class="hero-stat-num">10+</span>
          <span class="hero-stat-label">ani experiență</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">500+</span>
          <span class="hero-stat-label">evenimente</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">100%</span>
          <span class="hero-stat-label">live</span>
        </div>
      </div>

      {/* Social media icons — vizibile doar pe mobil, umplu spațiul gol */}
      <div class="hero-social-row" aria-label="Rețele sociale">
        <span class="hero-social-label">Urmărește-ne</span>
        <div class="hero-social-icons">
          {socialLinks.youtube && (
            <a href={socialLinks.youtube} class="hero-social-btn hero-social-btn--yt"
              target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="6" width="20" height="13" rx="4" fill="#fff"/>
                <polygon points="9.5,9.5 9.5,15.5 16.5,12.5" fill="#FF0000"/>
              </svg>
              <span>YouTube</span>
            </a>
          )}
          {socialLinks.facebook && (
            <a href={socialLinks.facebook} class="hero-social-btn hero-social-btn--fb"
              target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#1877F2"/>
                <path d="M13.5 21V14.3H16l.4-2.85H13.5V9.7c0-.82.38-1.2 1.38-1.2H16.5V5.85C16.05 5.77 15.1 5.7 14 5.7c-2.65 0-4.05 1.4-4.05 4.15v1.6H8v2.85h1.95V21H13.5z" fill="#fff"/>
              </svg>
              <span>Facebook</span>
            </a>
          )}
          {socialLinks.instagram && (
            <a href={socialLinks.instagram} class="hero-social-btn hero-social-btn--ig"
              target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5.5"
                  fill="url(#ig-grad-hero)"/>
                <defs>
                  <radialGradient id="ig-grad-hero" cx="30%" cy="110%" r="140%">
                    <stop offset="0%" stop-color="#ffd676"/>
                    <stop offset="25%" stop-color="#f46f30"/>
                    <stop offset="55%" stop-color="#e1306c"/>
                    <stop offset="80%" stop-color="#833ab4"/>
                    <stop offset="100%" stop-color="#405de6"/>
                  </radialGradient>
                </defs>
                <rect x="2.5" y="2.5" width="19" height="19" rx="5" stroke="#fff" stroke-width="2"/>
                <circle cx="12" cy="12" r="4.3" stroke="#fff" stroke-width="2"/>
                <circle cx="17.5" cy="6.6" r="1.4" fill="#fff"/>
              </svg>
              <span>Instagram</span>
            </a>
          )}
          {socialLinks.tiktok && (
            <a href={socialLinks.tiktok} class="hero-social-btn hero-social-btn--tt"
              target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#010101"/>
                <path transform="translate(-0.5,-0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#25f4ee"/>
                <path transform="translate(0.5,0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fe2c55"/>
                <path d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fff"/>
              </svg>
              <span>TikTok</span>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      VIDEO
  ═══════════════════════════════════════════ */}
  <section id="video" class="concert-section">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Scena noastră</span>
        <h2 class="section-title">Videoclipuri live &amp; cover-uri</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Momente live, energie pură și interpretări care ridică publicul în picioare.
        </p>
      </header>

      {homepageVideos.length > 0 ? (
        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
          {homepageVideos.map((item) => (
            <article class="video-concert-card">
              <div class="video-concert-frame">
                <iframe
                  src={`https://www.youtube.com/embed/${item.youtubeId}`}
                  title={item.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="video-concert-label">{item.title}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-2xl border border-[rgba(245,166,35,0.2)] bg-[rgba(255,255,255,0.03)] p-8 text-center">
          <p class="text-sm" style="color:var(--muted)">Videoclipurile vor apărea aici după completarea conținutului.</p>
        </div>
      )}

      <div class="mt-10 text-center">
        <a href="/galerie-video" class="btn-outline">Toate videoclipurile</a>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      GALERIE
  ═══════════════════════════════════════════ */}
  <section id="galerie" class="concert-section-alt">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Momente live</span>
        <h2 class="section-title">Galerie foto</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Imagini surprinse pe scenă, energie reală, publicul nostru.
        </p>
      </header>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {(gallery || []).slice(0, 6).map((item) => (
          hasRealGalleryImage(item.image) ? (
            <article class="gallery-concert-card">
              <img
                src={item.image}
                alt={item.alt}
                loading="lazy"
                decoding="async"
                class="gallery-concert-img"
              />
            </article>
          ) : (
            <article class="gallery-concert-placeholder" aria-label={`Slot foto: ${item.alt}`}>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="color:var(--gold); opacity:0.4"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              <p class="gallery-placeholder-label">{item.alt || 'Foto în curând'}</p>
            </article>
          )
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/galerie-foto" class="btn-outline">Galerie completă</a>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      MEMBRI
  ═══════════════════════════════════════════ */}
  <section id="membri" class="concert-section-alt">
    <div class="concert-section-inner">
      <header class="section-head text-center mx-auto">
        <span class="section-kicker-pill">Echipa</span>
        <h2 class="section-title">Membrii formației</h2>
        <p class="section-copy mx-auto" style="max-width:52ch">
          Soliști vocali, instrumentiști și colaboratori speciali — o echipă completă pentru evenimente memorabile.
        </p>
      </header>

      {/* Grid carduri principale */}
      <div class="members-cards-grid">
        {team.vocalists.map((member) => (
          <article class="member-card member-card--gold">
            <button
              type="button"
              class="member-card-photo member-card-photo--clickable"
              data-member-name={member.name}
              data-member-role={member.role}
              data-member-photos={JSON.stringify((member as any).photos || [])}
              aria-label={`Deschide galeria foto pentru ${member.name}`}
            >
              {hasRealPhoto(member.image) ? (
                <img src={member.image} alt={`Portret ${member.name}`} loading="lazy" decoding="async" />
              ) : (
                <div class="member-card-initials member-card-initials--gold" aria-hidden="true">
                  {getInitials(member.name)}
                </div>
              )}
              <span class="member-card-badge member-card-badge--gold">Solistă vocală</span>
              <span class="member-card-photo-overlay" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                <span>Galerie foto</span>
              </span>
            </button>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--gold">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
            </div>
          </article>
        ))}
        {team.instrumentalists.map((member) => (
          <article class="member-card member-card--teal">
            <button
              type="button"
              class="member-card-photo member-card-photo--clickable"
              data-member-name={member.name}
              data-member-role={member.role}
              data-member-photos={JSON.stringify((member as any).photos || [])}
              aria-label={`Deschide galeria foto pentru ${member.name}`}
            >
              {hasRealPhoto(member.image) ? (
                <img src={member.image} alt={`Portret ${member.name}`} loading="lazy" decoding="async" />
              ) : (
                <div class="member-card-initials member-card-initials--teal" aria-hidden="true">
                  {getInitials(member.name)}
                </div>
              )}
              <span class="member-card-badge member-card-badge--teal">Instrumentist</span>
              <span class="member-card-photo-overlay" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                <span>Galerie foto</span>
              </span>
            </button>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--teal">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
            </div>
          </article>
        ))}
        {team.collaborators.map((member) => (
          <article class="member-card member-card--rose">
            <div class="member-card-photo">
              <div class="member-card-initials member-card-initials--rose" aria-hidden="true">
                {member.instrument === 'Saxofon' ? '🎷' : '🎵'}
              </div>
              <span class="member-card-badge member-card-badge--rose">Colaborator invitat</span>
            </div>
            <div class="member-card-body">
              <h3 class="member-card-name">{member.name}</h3>
              <p class="member-card-role member-card-role--rose">{member.role}</p>
              <p class="member-card-bio">{member.description}</p>
              {member.instrument === 'Saxofon' && (
                <a href="/colaboratori/saxofon" class="member-card-link">Prezentare completă →</a>
              )}
              {member.instrument === 'Țambal' && (
                <a href="/colaboratori/tambal" class="member-card-link">Prezentare completă →</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      LIGHTBOX GALERIE MEMBRI
  ═══════════════════════════════════════════ */}
  <div id="member-gallery-modal" role="dialog" aria-modal="true" aria-labelledby="member-gallery-title" hidden>
    <div class="mgl-backdrop" id="member-gallery-backdrop"></div>
    <div class="mgl-dialog">
      <div class="mgl-header">
        <div>
          <p class="mgl-kicker">Galerie foto</p>
          <h2 class="mgl-title" id="member-gallery-title"></h2>
          <p class="mgl-role" id="member-gallery-role"></p>
        </div>
        <button type="button" class="mgl-close" id="member-gallery-close" aria-label="Închide galeria">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="mgl-grid" id="member-gallery-grid"></div>
      <div class="mgl-fullscreen-overlay" id="mgl-fullscreen-overlay" hidden>
        <button type="button" class="mgl-fs-close" id="mgl-fs-close" aria-label="Închide imaginea">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <button type="button" class="mgl-fs-nav mgl-fs-prev" id="mgl-fs-prev" aria-label="Înapoi">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <img class="mgl-fs-img" id="mgl-fs-img" src="" alt="" />
        <button type="button" class="mgl-fs-nav mgl-fs-next" id="mgl-fs-next" aria-label="Înainte">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  // ── Lightbox galerie membri ──
  (function () {
    const modal       = document.getElementById('member-gallery-modal') as HTMLElement | null;
    const backdrop    = document.getElementById('member-gallery-backdrop') as HTMLElement | null;
    const closeBtn    = document.getElementById('member-gallery-close') as HTMLButtonElement | null;
    const titleEl     = document.getElementById('member-gallery-title') as HTMLElement | null;
    const roleEl      = document.getElementById('member-gallery-role') as HTMLElement | null;
    const gridEl      = document.getElementById('member-gallery-grid') as HTMLElement | null;
    const fsOverlay   = document.getElementById('mgl-fullscreen-overlay') as HTMLElement | null;
    const fsImg       = document.getElementById('mgl-fs-img') as HTMLImageElement | null;
    const fsClose     = document.getElementById('mgl-fs-close') as HTMLButtonElement | null;
    const fsPrev      = document.getElementById('mgl-fs-prev') as HTMLButtonElement | null;
    const fsNext      = document.getElementById('mgl-fs-next') as HTMLButtonElement | null;

    if (!modal || !gridEl || !titleEl || !roleEl) return;

    let currentPhotos: string[] = [];
    let currentFsIndex = 0;

    function openModal(name: string, role: string, photos: string[]) {
      titleEl!.textContent = name;
      roleEl!.textContent  = role;
      gridEl!.innerHTML    = '';

      photos.forEach((src, i) => {
        const cell = document.createElement('div');
        cell.className = 'mgl-cell';

        if (src && src.trim()) {
          const img = document.createElement('img');
          img.src     = src.trim();
          img.alt     = `${name} — foto ${i + 1}`;
          img.loading = 'lazy';
          cell.appendChild(img);
          cell.addEventListener('click', () => openFullscreen(photos.filter(p => p.trim()), i));
        } else {
          cell.className += ' mgl-cell-empty';
          cell.setAttribute('aria-label', `Slot foto ${i + 1} — în curând`);
          cell.innerHTML = `
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="opacity:.35"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <span>Foto în curând</span>`;
        }

        gridEl!.appendChild(cell);
      });

      modal!.hidden = false;
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closeModal() {
      modal!.hidden = true;
      document.body.style.overflow = '';
    }

    function openFullscreen(photos: string[], startIndex: number) {
      if (!photos.length || !fsOverlay || !fsImg) return;
      currentPhotos   = photos;
      currentFsIndex  = startIndex;
      updateFsImage();
      fsOverlay.hidden = false;
    }

    function closeFsOverlay() {
      if (fsOverlay) fsOverlay.hidden = true;
    }

    function updateFsImage() {
      if (!fsImg) return;
      fsImg.src = currentPhotos[currentFsIndex];
      fsImg.alt = `Foto ${currentFsIndex + 1} din ${currentPhotos.length}`;
      if (fsPrev) fsPrev.style.display = currentFsIndex > 0 ? '' : 'none';
      if (fsNext) fsNext.style.display = currentFsIndex < currentPhotos.length - 1 ? '' : 'none';
    }

    // Attach click on all member photo buttons
    document.querySelectorAll<HTMLButtonElement>('button.member-card-photo[data-member-name]').forEach(btn => {
      btn.addEventListener('click', () => {
        const name   = btn.dataset.memberName   || '';
        const role   = btn.dataset.memberRole   || '';
        const photos = JSON.parse(btn.dataset.memberPhotos || '[]') as string[];
        openModal(name, role, photos);
      });
    });

    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    fsClose?.addEventListener('click',  closeFsOverlay);
    fsPrev?.addEventListener('click',   () => { currentFsIndex--; updateFsImage(); });
    fsNext?.addEventListener('click',   () => { currentFsIndex++; updateFsImage(); });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeFsOverlay(); if (!modal!.hidden) closeModal(); }
      if (fsOverlay && !fsOverlay.hidden) {
        if (e.key === 'ArrowLeft'  && currentFsIndex > 0) { currentFsIndex--; updateFsImage(); }
        if (e.key === 'ArrowRight' && currentFsIndex < currentPhotos.length - 1) { currentFsIndex++; updateFsImage(); }
      }
    });
  })();

  // Corp astral — apare ocazional, nu în fiecare ciclu
  (function () {
    const orb = document.querySelector<HTMLElement>('.astral-orb');
    if (!orb) return;

    // Pornire după o pauză inițială aleatorie (8–20s), apoi din când în când
    function scheduleNextTraversal() {
      // Pauză între traversări: 12–35 secunde
      const delay = 12000 + Math.random() * 23000;
      setTimeout(() => {
        orb.classList.remove('is-traveling');
        // Re-flow forțat, altfel animația nu repornește
        void orb.offsetWidth;
        orb.classList.add('is-traveling');

        // Curăță clasa la finalul animației și programează urmă
        const onEnd = () => {
          orb.classList.remove('is-traveling');
          orb.removeEventListener('animationend', onEnd);
          scheduleNextTraversal();
        };
        orb.addEventListener('animationend', onEnd);
      }, delay);
    }

    // Prima apariție după 6–14s de la încărcarea paginii
    const firstDelay = 6000 + Math.random() * 8000;
    setTimeout(() => scheduleNextTraversal(), firstDelay);
  })();

  // Stele ocazionale sus-stânga și sus-dreapta
  (function () {
    const container = document.querySelector<HTMLElement>('.hero-stars');
    if (!container) return;

    // Zonele de spawn: stânga sus și dreapta sus
    const zones = [
      { x: () => 4 + Math.random() * 18, y: () => 4 + Math.random() * 22 },   // sus-stânga
      { x: () => 78 + Math.random() * 18, y: () => 4 + Math.random() * 22 },  // sus-dreapta
    ];

    function spawnStar() {
      const zone = zones[Math.floor(Math.random() * zones.length)];
      const star = document.createElement('span');
      star.className = 'hero-star';

      // Dimensiune aleatorie — mai mari
      const size = 10 + Math.random() * 14;
      const x = zone.x();
      const y = zone.y();
      const dur = 2.2 + Math.random() * 1.6;

      star.style.left = x + '%';
      star.style.top  = y + '%';
      star.style.width  = size + 'px';
      star.style.height = size + 'px';
      star.style.animationDuration = dur + 's';

      container.appendChild(star);
      star.addEventListener('animationend', () => star.remove(), { once: true });
    }

    function scheduleStar() {
      // Între 1 și 4 stele pe rafală, cu mici întârzieri între ele
      const count = 1 + Math.floor(Math.random() * 3);
      for (let i = 0; i < count; i++) {
        setTimeout(spawnStar, i * (300 + Math.random() * 400));
      }
      // Pauză până la următoarea rafală: 5–18s
      const next = 5000 + Math.random() * 13000;
      setTimeout(scheduleStar, next);
    }

    // Prima rafală după 3–7s
    setTimeout(scheduleStar, 3000 + Math.random() * 4000);
  })();
</script>

