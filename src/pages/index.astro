---
---

<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Formația Florentina Pană</title>
  </head>

  <body class="bg-night text-white">

    <!-- NAVBAR -->
    <header class="bg-night/80 backdrop-blur-md border-b border-graphite sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto flex items-center justify-between py-4 px-6">
        <div class="text-electric font-bold text-xl">Florentina Pană</div>

        <ul class="hidden md:flex gap-6 text-gray-300">
          <li><a href="#acasa" class="hover:text-electric transition">Acasă</a></li>
          <li><a href="#despre" class="hover:text-electric transition">Despre noi</a></li>
          <li><a href="#servicii" class="hover:text-electric transition">Servicii</a></li>
          <li><a href="#repertoriu" class="hover:text-electric transition">Repertoriu</a></li>
          <li><a href="#galerie" class="hover:text-electric transition">Galerie foto</a></li>
          <li><a href="#faq" class="hover:text-electric transition">FAQ</a></li>
          <li><a href="#contact" class="hover:text-electric transition">Contact</a></li>
        </ul>

        <a href="tel:+40700000000"
           class="hidden md:block bg-neon text-night font-semibold px-5 py-2 rounded-lg shadow-neon hover:bg-cyanglow transition">
          Cere ofertă
        </a>
      </nav>
    </header>

    <!-- HERO -->
    <section id="acasa" class="bg-night text-white py-28">
      <div class="max-w-5xl mx-auto text-center px-6">

        <h1 class="text-5xl md:text-6xl font-extrabold text-electric tracking-tight animate-fade-up">
          Formația Florentina Pană
        </h1>

        <p class="mt-6 text-gray-300 text-lg md:text-xl max-w-3xl mx-auto animate-fade-up-delayed">
          Muzică live pentru evenimente memorabile. Energie, emoție și profesionalism pe fiecare scenă.
        </p>

        <div class="mt-10 flex justify-center gap-4 animate-fade-up-delayed">
          <a href="tel:+40700000000"
             class="bg-neon text-night font-semibold px-8 py-3 rounded-lg shadow-neon hover:bg-cyanglow transition">
            Sună acum
          </a>

          <a href="#video"
             class="border border-electric text-electric px-8 py-3 rounded-lg hover:bg-electric hover:text-night transition">
            Vezi video
          </a>
        </div>

      </div>
    </section>

    <!-- VIDEO SECTION (mutat sus) -->
    <section id="video" class="bg-graphite py-24">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl md:text-5xl font-bold text-electric text-center">
          Videoclipuri Live & Cover-uri
        </h2>

        <p class="mt-4 text-gray-300 text-center max-w-2xl mx-auto">
          Momente live, energie pură și interpretări care ridică publicul în picioare.
        </p>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

          <div class="rounded-xl overflow-hidden shadow-xl hover:shadow-neon transition">
            <iframe class="w-full h-64"
              src="https://www.youtube.com/embed/ID_VIDEO_1"
              title="Video YouTube"
              allowfullscreen></iframe>
          </div>

          <div class="rounded-xl overflow-hidden shadow-xl hover:shadow-neon transition">
            <iframe class="w-full h-64"
              src="https://www.youtube.com/embed/ID_VIDEO_2"
              title="Video YouTube"
              allowfullscreen></iframe>
          </div>

          <div class="rounded-xl overflow-hidden shadow-xl hover:shadow-neon transition">
            <iframe class="w-full h-64"
              src="https://www.youtube.com/embed/ID_VIDEO_3"
              title="Video YouTube"
              allowfullscreen></iframe>
          </div>

        </div>
      </div>
    </section>

    <!-- DESPRE NOI -->
    <section id="despre" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">

        <div class="space-y-6">
          <h2 class="text-4xl md:text-5xl font-bold text-electric">Despre noi</h2>

          <p class="text-gray-300 leading-relaxed">
            Formația <span class="text-electric font-semibold">Florentina Pană</span> este o trupă de muzică live
            cu experiență în evenimente private, nunți, botezuri și petreceri corporate.
            Punem accent pe energie, emoție și profesionalism, oferind un spectacol complet
            care ridică publicul în picioare.
          </p>

          <p class="text-gray-400 leading-relaxed">
            Repertoriul nostru acoperă muzică populară, ușoară, cover-uri internaționale,
            muzică de petrecere și momente speciale personalizate pentru fiecare eveniment.
          </p>

          <div class="pt-4">
            <a href="#contact"
               class="inline-block bg-neon text-night font-semibold px-8 py-3 rounded-lg shadow-neon hover:bg-cyanglow transition">
              Contactează-ne
            </a>
          </div>
        </div>

        <div class="rounded-xl overflow-hidden shadow-neon bg-graphite h-80 flex items-center justify-center">
          <span class="text-gray-500">Aici putem pune o poză cu formația</span>
        </div>

      </div>
    </section>

    <!-- SERVICII -->
    <section id="servicii" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-6xl mx-auto px-6 text-center">

        <h2 class="text-4xl md:text-5xl font-bold text-electric">Servicii</h2>
        <p class="mt-4 text-gray-300 max-w-2xl mx-auto">
          Oferim pachete complete pentru orice tip de eveniment.
        </p>

        <div class="mt-12 grid md:grid-cols-3 gap-10">

          <div class="bg-graphite p-8 rounded-xl shadow-soft hover:shadow-neon transition">
            <h3 class="text-xl font-semibold text-electric">Nuntă</h3>
            <p class="mt-3 text-gray-400">Program complet, momente speciale, atmosferă garantată.</p>
          </div>

          <div class="bg-graphite p-8 rounded-xl shadow-soft hover:shadow-neon transition">
            <h3 class="text-xl font-semibold text-electric">Botez</h3>
            <p class="mt-3 text-gray-400">Muzică live pentru un eveniment memorabil.</p>
          </div>

          <div class="bg-graphite p-8 rounded-xl shadow-soft hover:shadow-neon transition">
            <h3 class="text-xl font-semibold text-electric">Corporate</h3>
            <p class="mt-3 text-gray-400">Show profesionist pentru evenimente business.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- REPERTORIU -->
    <section id="repertoriu" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-6xl mx-auto px-6">

        <h2 class="text-4xl md:text-5xl font-bold text-electric text-center">Repertoriu</h2>
        <p class="mt-4 text-gray-300 text-center max-w-2xl mx-auto">
          Un mix echilibrat între tradițional, modern și internațional.
        </p>

        <ul class="mt-12 grid md:grid-cols-2 gap-6 text-gray-300">
          <li class="bg-graphite p-5 rounded-lg shadow-soft">Muzică populară</li>
          <li class="bg-graphite p-5 rounded-lg shadow-soft">Cover-uri internaționale</li>
          <li class="bg-graphite p-5 rounded-lg shadow-soft">Muzică ușoară românească</li>
          <li class="bg-graphite p-5 rounded-lg shadow-soft">Muzică de petrecere</li>
        </ul>

      </div>
    </section>

    <!-- GALERIE FOTO -->
    <section id="galerie" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-6xl mx-auto px-6 text-center">

        <h2 class="text-4xl md:text-5xl font-bold text-electric">Galerie foto</h2>
        <p class="mt-4 text-gray-300">Momente surprinse live în timpul evenimentelor.</p>

        <div class="mt-12 grid md:grid-cols-3 gap-6">
          <div class="bg-graphite h-48 rounded-xl shadow-soft"></div>
          <div class="bg-graphite h-48 rounded-xl shadow-soft"></div>
          <div class="bg-graphite h-48 rounded-xl shadow-soft"></div>
        </div>

      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-4xl mx-auto px-6">

        <h2 class="text-4xl md:text-5xl font-bold text-electric text-center">Întrebări frecvente</h2>

        <div class="mt-12 space-y-6">

          <div class="bg-graphite p-6 rounded-xl shadow-soft">
            <h3 class="text-electric font-semibold">Cântăm în toată țara?</h3>
            <p class="text-gray-300 mt-2">Da, ne deplasăm oriunde în România.</p>
          </div>

          <div class="bg-graphite p-6 rounded-xl shadow-soft">
            <h3 class="text-electric font-semibold">Putem personaliza repertoriul?</h3>
            <p class="text-gray-300 mt-2">Desigur, adaptăm programul în funcție de preferințele tale.</p>
          </div>

        </div>

      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="py-28 bg-night border-t border-graphite">
      <div class="max-w-4xl mx-auto px-6 text-center">

        <h2 class="text-4xl md:text-5xl font-bold text-electric">Contact</h2>
        <p class="mt-4 text-gray-300">Suntem gata să discutăm despre evenimentul tău.</p>

        <div class="mt-10 space-y-4 text-gray-300">
          <p><strong class="text-electric">Telefon:</strong> 07xx xxx xxx</p>
          <p><strong class="text-electric">Email:</strong> contact@formatia.ro</p>
        </div>

      </div>
    </section>
