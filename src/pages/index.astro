---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';

const { seo, contact, faq } = siteContent;
const faqItems = faq as Array<{ question: string; answer: string }>;
import { sanitizeUrl } from '../lib/sanitize-url';

const socialLinks = {
  youtube:   sanitizeUrl(siteContent.socialLinks?.youtube),
  facebook:  sanitizeUrl(siteContent.socialLinks?.facebook),
  instagram: sanitizeUrl(siteContent.socialLinks?.instagram),
  tiktok:    sanitizeUrl(siteContent.socialLinks?.tiktok),
};
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
const waHref = `https://wa.me/${contact.phoneRaw.replace('+', '')}?text=Bun%C4%83%20ziua!%20A%C8%99%20dori%20s%C4%83%20rezerv%20Forma%C8%9Bia%20Florentina%20Pan%C4%83%20pentru%20evenimentul%20meu.`;
---

<BaseLayout title={seo.title} description={seo.description} ogImage={seo.ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </Fragment>

  {/* ═══════════════════════════════════════════
      HERO — Scenă, titlu mare, CTA-uri
  ═══════════════════════════════════════════ */}
  <section id="acasa" class="hero-stage hero-fullscreen hp-hero-wrap" aria-label="Secțiunea principală">
    <div class="astral-orb" aria-hidden="true"></div>
    <div class="hero-stars" aria-hidden="true"></div>
    <div class="hero-stage-inner">

      <span class="kicker-badge" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.38Z"/></svg>
        Muzică live — România
      </span>

      {/* Card foto — vizibil doar pe mobil, colțuri rotunjite */}
      {/* TODO: înlocuiește hero-photo.jpg cu poza reală după ședința foto */}
      <div class="hero-photo-card">
        <img
          src="/images/hero-photo.jpg"
          alt="Formația Florentina Pană"
          class="hero-photo-img"
          loading="eager"
          width="320"
          height="213"
          onerror="this.style.display='none';this.parentElement.classList.add('hero-photo-card--placeholder')"
        />
      </div>

      <h1 class="hero-title-xl">
        <span class="hero-kicker-text">Formația</span><br/>
        <span class="hero-title-gold">Florentina Pană</span>
      </h1>

      <p class="hero-lead">
        Energie, emoție și profesionalism pe orice scenă.<br/>
        De la nunți și botezuri la evenimente corporate și concerte.
      </p>

      {/* Stat pills */}
      <div class="hero-stats" aria-label="Statistici formație">
        <div class="hero-stat-pill">
          <span class="hero-stat-num">10+</span>
          <span class="hero-stat-label">ani experiență</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">500+</span>
          <span class="hero-stat-label">evenimente</span>
        </div>
        <div class="hero-stat-pill">
          <span class="hero-stat-num">100%</span>
          <span class="hero-stat-label">live</span>
        </div>
      </div>

      {/* Social media icons — vizibile doar pe mobil, umplu spațiul gol */}
      <div class="hero-social-row" aria-label="Rețele sociale">
        <span class="hero-social-label">Urmărește-ne</span>
        <div class="hero-social-icons">
          {socialLinks.youtube && (
            <a href={socialLinks.youtube} class="hero-social-btn hero-social-btn--yt"
              target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="6" width="20" height="13" rx="4" fill="#fff"/>
                <polygon points="9.5,9.5 9.5,15.5 16.5,12.5" fill="#FF0000"/>
              </svg>
              <span>YouTube</span>
            </a>
          )}
          {socialLinks.facebook && (
            <a href={socialLinks.facebook} class="hero-social-btn hero-social-btn--fb"
              target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#1877F2"/>
                <path d="M13.5 21V14.3H16l.4-2.85H13.5V9.7c0-.82.38-1.2 1.38-1.2H16.5V5.85C16.05 5.77 15.1 5.7 14 5.7c-2.65 0-4.05 1.4-4.05 4.15v1.6H8v2.85h1.95V21H13.5z" fill="#fff"/>
              </svg>
              <span>Facebook</span>
            </a>
          )}
          {socialLinks.instagram && (
            <a href={socialLinks.instagram} class="hero-social-btn hero-social-btn--ig"
              target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5.5"
                  fill="url(#ig-grad-hero)"/>
                <defs>
                  <radialGradient id="ig-grad-hero" cx="30%" cy="110%" r="140%">
                    <stop offset="0%" stop-color="#ffd676"/>
                    <stop offset="25%" stop-color="#f46f30"/>
                    <stop offset="55%" stop-color="#e1306c"/>
                    <stop offset="80%" stop-color="#833ab4"/>
                    <stop offset="100%" stop-color="#405de6"/>
                  </radialGradient>
                </defs>
                <rect x="2.5" y="2.5" width="19" height="19" rx="5" stroke="#fff" stroke-width="2"/>
                <circle cx="12" cy="12" r="4.3" stroke="#fff" stroke-width="2"/>
                <circle cx="17.5" cy="6.6" r="1.4" fill="#fff"/>
              </svg>
              <span>Instagram</span>
            </a>
          )}
          {socialLinks.tiktok && (
            <a href={socialLinks.tiktok} class="hero-social-btn hero-social-btn--tt"
              target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="5" fill="#010101"/>
                <path transform="translate(-0.5,-0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#25f4ee"/>
                <path transform="translate(0.5,0.4)" d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fe2c55"/>
                <path d="M16.5 3h-2.3v11.6a2.8 2.8 0 0 1-2.8 2.8 2.8 2.8 0 0 1-2.8-2.8 2.8 2.8 0 0 1 2.8-2.8c.3 0 .55.05.8.12V9.45a6.2 6.2 0 0 0-.8-.05 6.1 6.1 0 0 0-6.1 6.1 6.1 6.1 0 0 0 6.1 6.1 6.1 6.1 0 0 0 6.1-6.1V8.35a8.5 8.5 0 0 0 4.8 1.5V7.3a6.1 6.1 0 0 1-4.5-4.3h-.3z" fill="#fff"/>
              </svg>
              <span>TikTok</span>
            </a>
          )}
        </div>
      </div>
    </div>
    <div class="hero-fade-bottom" aria-hidden="true"></div>
  </section>

  {/* ═══════════════════════════════════════════
      DESPRE FORMAȚIE — text SEO + H3 subtitluri
  ═══════════════════════════════════════════ */}
  <section id="despre-formatie" class="hp-seo-section" aria-label="Despre formația noastră">
    <h2 class="hp-seo-title">Despre formația noastră</h2>

    <div class="hp-seo-grid">
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Experiență pe scenă din 2014</h3>
        <p class="hp-seo-text">
          Formația Florentina Pană activează pe piața evenimentelor din România de peste 10 ani.
          Am început în Pitești, județul Argeș, iar astăzi ne deplasăm în toată țara pentru nunți,
          botezuri, aniversări și evenimente corporate. Fiecare spectacol este un show complet:
          soliști vocali cu experiență, instrumentiști profesioniști, sonorizare de calitate și
          un program muzical adaptat momentului.
        </p>
      </div>
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Repertoriu divers și personalizat</h3>
        <p class="hp-seo-text">
          Repertoriul nostru acoperă muzică populară românească, muzică ușoară, hituri
          pop românești și internaționale, dance, muzică de petrecere și momente speciale
          personalizate. De la dansul mirilor și valsul de deschidere până la ora de
          petrecere și momentele tradiționale — ne adaptăm stilului și dorințelor fiecărui cuplu.
        </p>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      DE CE SĂ NE ALEGEȚI — beneficii + H3
  ═══════════════════════════════════════════ */}
  <section id="de-ce-noi" class="hp-seo-section" aria-label="De ce să ne alegeți">
    <h2 class="hp-seo-title">De ce să ne alegeți</h2>

    <div class="hp-seo-grid">
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Profesionalism și punctualitate</h3>
        <p class="hp-seo-text">
          Comunicăm transparent din prima discuție, respectăm orarul convenit și venim
          pregătiți la fiecare eveniment. Echipamentul nostru de sunet și lumini este
          verificat înainte de orice spectacol, iar artiștii repetă programul stabilit
          cu fiecare client în parte.
        </p>
      </div>
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Program muzical adaptat evenimentului</h3>
        <p class="hp-seo-text">
          Nu avem un program standard pe care îl repetăm la fiecare nuntă. Stabilim
          împreună lista de piese, momentele speciale și ritmul serii. Fie că preferați
          muzică populară autentică, hituri moderne sau un mix echilibrat — programul
          muzical este construit în jurul viziunii voastre.
        </p>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      TIPURI DE EVENIMENTE — servicii + H3
  ═══════════════════════════════════════════ */}
  <section id="tipuri-evenimente" class="hp-seo-section" aria-label="Tipuri de evenimente">
    <h2 class="hp-seo-title">Tipuri de evenimente</h2>

    <div class="hp-seo-grid hp-seo-grid--3">
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Muzică live pentru nunți</h3>
        <p class="hp-seo-text">
          Program complet de nuntă: primirea invitaților, cina, dansul mirilor,
          momente dedicate părinților și petrecerea de noapte. Colaborăm cu
          fiecare cuplu pentru a crea o atmosferă unică.
        </p>
      </div>
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Animație botezuri și aniversări</h3>
        <p class="hp-seo-text">
          Muzică live caldă, piese populare și romanțe pentru generațiile mai în vârstă,
          ritmuri moderne pentru tineri. Repertoriul este echilibrat pentru invitați
          de toate vârstele.
        </p>
      </div>
      <div class="hp-seo-block">
        <h3 class="hp-seo-subtitle">Evenimente corporate și private</h3>
        <p class="hp-seo-text">
          Show profesionist pentru gale de premiere, seri de team-building, lansări
          de produse sau petreceri de Crăciun. Muzică de fundal elegantă în timpul
          cinei, moment live de show și repertoriu rafinat.
        </p>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      FAQ — Întrebări frecvente (vizibile pe pagină)
  ═══════════════════════════════════════════ */}
  <section id="intrebari-frecvente" class="hp-seo-section" aria-label="Întrebări frecvente">
    <h2 class="hp-seo-title">Întrebări frecvente</h2>

    <div class="hp-faq-list">
      {faqItems.map((item) => (
        <details class="hp-faq-item">
          <summary class="hp-faq-question">
            <h3 class="hp-faq-q-text">{item.question}</h3>
            <svg class="hp-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <p class="hp-faq-answer">{item.answer}</p>
        </details>
      ))}
      <details class="hp-faq-item">
        <summary class="hp-faq-question">
          <h3 class="hp-faq-q-text">Oferiți și sonorizare proprie?</h3>
          <svg class="hp-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="hp-faq-answer">Da, dispunem de echipament profesional de sunet și lumini, inclus în oferta noastră pentru un spectacol complet.</p>
      </details>
      <details class="hp-faq-item">
        <summary class="hp-faq-question">
          <h3 class="hp-faq-q-text">Cum putem rezerva formația?</h3>
          <svg class="hp-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="hp-faq-answer">Ne puteți contacta telefonic la 0767 369 658, pe WhatsApp sau prin formularul de contact de pe site. Verificăm disponibilitatea și revenim cu o ofertă personalizată.</p>
      </details>
    </div>
  </section>

  {/* ═══════════════════════════════════════════
      HIGHLIGHTS — 2 carduri clickabile
  ═══════════════════════════════════════════ */}
  <section id="highlights" class="hp-highlights" aria-label="Descoperă mai mult">

    <a href="/despre" class="hp-card hp-card--story">
      <div class="hp-card-overlay" aria-hidden="true"></div>
      <div class="hp-card-content">
        <span class="hp-card-kicker">Cine suntem</span>
        <h2 class="hp-card-title">Povestea noastră</h2>
        <p class="hp-card-text">10 ani de muzică, emoție și scenă</p>
        <span class="hp-card-cta">
          Descoperă
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    </a>

    <div class="hp-card hp-card--book">
      {/* Stretched link acoperă tot cardul — navigare spre /contact */}
      <a href="/contact" class="hp-card-link" aria-label="Rezervă acum — pagina de contact"></a>
      <div class="hp-card-overlay" aria-hidden="true"></div>
      <div class="hp-card-content">
        <span class="hp-card-kicker">Disponibilitate</span>
        <h2 class="hp-card-title">Rezervă acum</h2>
        <p class="hp-card-text">Suntem disponibili pentru evenimentul tău</p>
        <a
          href={waHref}
          class="hp-whatsapp-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Rezervă pe WhatsApp: ${contact.phoneDisplay}`}
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.556 4.122 1.528 5.854L0 24l6.335-1.508A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 0 1-4.964-1.342l-.356-.211-3.765.896.953-3.671-.232-.376A9.785 9.785 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
          {contact.phoneDisplay}
        </a>
        <span class="hp-card-cta">
          Contactează-ne
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    </div>

  </section>

</BaseLayout>

<script>
  // Corp astral — apare ocazional, nu în fiecare ciclu
  (function () {
    const orb = document.querySelector<HTMLElement>('.astral-orb');
    if (!orb) return;

    // Pornire după o pauză inițială aleatorie (8–20s), apoi din când în când
    function scheduleNextTraversal() {
      // Pauză între traversări: 12–35 secunde
      const delay = 12000 + Math.random() * 23000;
      setTimeout(() => {
        orb.classList.remove('is-traveling');
        // Re-flow forțat, altfel animația nu repornește
        void orb.offsetWidth;
        orb.classList.add('is-traveling');

        // Curăță clasa la finalul animației și programează urmă
        const onEnd = () => {
          orb.classList.remove('is-traveling');
          orb.removeEventListener('animationend', onEnd);
          scheduleNextTraversal();
        };
        orb.addEventListener('animationend', onEnd);
      }, delay);
    }

    // Prima apariție după 6–14s de la încărcarea paginii
    const firstDelay = 6000 + Math.random() * 8000;
    setTimeout(() => scheduleNextTraversal(), firstDelay);
  })();

  // Stele ocazionale sus-stânga și sus-dreapta
  (function () {
    const container = document.querySelector<HTMLElement>('.hero-stars');
    if (!container) return;

    // Zonele de spawn: stânga sus și dreapta sus
    const zones = [
      { x: () => 4 + Math.random() * 18, y: () => 4 + Math.random() * 22 },   // sus-stânga
      { x: () => 78 + Math.random() * 18, y: () => 4 + Math.random() * 22 },  // sus-dreapta
    ];

    function spawnStar() {
      const zone = zones[Math.floor(Math.random() * zones.length)];
      const star = document.createElement('span');
      star.className = 'hero-star';

      // Dimensiune aleatorie — mai mari
      const size = 10 + Math.random() * 14;
      const x = zone.x();
      const y = zone.y();
      const dur = 2.2 + Math.random() * 1.6;

      star.style.left = x + '%';
      star.style.top  = y + '%';
      star.style.width  = size + 'px';
      star.style.height = size + 'px';
      star.style.animationDuration = dur + 's';

      container.appendChild(star);
      star.addEventListener('animationend', () => star.remove(), { once: true });
    }

    function scheduleStar() {
      // Între 1 și 4 stele pe rafală, cu mici întârzieri între ele
      const count = 1 + Math.floor(Math.random() * 3);
      for (let i = 0; i < count; i++) {
        setTimeout(spawnStar, i * (300 + Math.random() * 400));
      }
      // Pauză până la următoarea rafală: 5–18s
      const next = 5000 + Math.random() * 13000;
      setTimeout(scheduleStar, next);
    }

    // Prima rafală după 3–7s
    setTimeout(scheduleStar, 3000 + Math.random() * 4000);
  })();
</script>

<style>
  /* ════════════════════════════════════════════════════════════════
     TIPOGRAFIE — import Cormorant Garamond (Serif subțire, elegant)
  ════════════════════════════════════════════════════════════════ */
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap');

  /* ════════════════════════════════════════════════════════════════
     HTML / BODY — transparent peste cerul Sirius
  ════════════════════════════════════════════════════════════════ */
  html, body {
    background: transparent !important;
    background-color: transparent !important;
    margin: 0; padding: 0; overflow-x: hidden;
  }

  /* ════════════════════════════════════════════════════════════════
     HERO STAGE — pagina de bun-venit, transparentă complet
  ════════════════════════════════════════════════════════════════ */
  .hero-stage {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: clamp(2rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem);
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 100%,
        rgba(180, 140, 60, 0.18) 0%,
        transparent 60%),
      radial-gradient(ellipse at 80% 20%,
        rgba(0, 80, 180, 0.3) 0%,
        transparent 50%),
      linear-gradient(160deg,
        #0a1628 0%,
        #0d1f3c 40%,
        #0a1628 100%);
  }

  /* Overlay eliminat complet */
  .hero-stage::before {
    display: none;
  }

  /* ════════════════════════════════════════════════════════════════
     CARDUL DE CRISTAL — singurul backdrop-filter din pagină
  ════════════════════════════════════════════════════════════════ */
  .hero-stage-inner {
    max-width: 680px;
    width: 100%;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 5;  /* deasupra fade-bottom (z:1), stelelor (z:2) și orbului (z:0) */
  }

  /* ════════════════════════════════════════════════════════════════
     TIPOGRAFIE HERO
  ════════════════════════════════════════════════════════════════ */
  /* Kicker badge */
  .kicker-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid rgba(241, 229, 172, 0.25);
    border-radius: 9999px;
    padding: 0.3rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.35);
  }

  /* Titlul principal */
  .hero-title-xl {
    margin: 0;
    line-height: 1.1;
    text-align: center;
  }

  /* "FORMAȚIA" — italic, alb clar */
  .hero-kicker-text {
    display: block;
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.18em;
    text-transform: none;
    color: rgba(255, 255, 255, 0.90);
    text-shadow:
      0 0 12px rgba(255, 220, 120, 0.55),
      0 2px 6px rgba(0, 0, 0, 0.80);
    margin-bottom: 0.05rem;
  }

  /* "Florentina Pană" — Hollywood gold shimmer */
  .hero-title-gold {
    display: block;
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: clamp(2.4rem, 6.5vw, 4.8rem);
    letter-spacing: 0.06em;
    text-transform: none;
    line-height: 1.0;
    position: relative;
    background: linear-gradient(
      135deg,
      #e8c85b 0%,
      #ffeaa0 30%,
      #ffffff 50%,
      #ffeaa0 70%,
      #e8c85b 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter:
      brightness(2.5) saturate(1.3)
      drop-shadow(0 0 12px rgba(255, 220, 100, 0.80))
      drop-shadow(0 0 30px rgba(255, 200, 50, 0.50))
      drop-shadow(0 2px 0 rgba(0,0,0,0.80))
      drop-shadow(0 4px 8px rgba(0,0,0,0.60));
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* ════════════════════════════════════════════════════════════════
     STELE OCAZIONALE — sus-stânga și sus-dreapta
  ════════════════════════════════════════════════════════════════ */
  .hero-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    overflow: visible;
  }

  .hero-star {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, #ffffff 0%, #fff8a0 30%, #ffd700 60%, transparent 80%);
    box-shadow:
      0 0 6px 3px rgba(255, 250, 180, 1),
      0 0 18px 7px rgba(255, 220, 60, 0.8),
      0 0 40px 14px rgba(255, 190, 0, 0.45);
    opacity: 0;
    animation-name: star-rise;
    animation-timing-function: ease-out;
    animation-fill-mode: forwards;
  }

  @keyframes star-rise {
    0%   { opacity: 0;   transform: scale(0.4) translateY(0px);    }
    12%  { opacity: 1;   transform: scale(1.6) translateY(-6px);   }
    35%  { opacity: 0.9; transform: scale(1.2) translateY(-18px);  }
    65%  { opacity: 0.6; transform: scale(0.7) translateY(-42px);  }
    100% { opacity: 0;   transform: scale(0.15) translateY(-90px); }
  }

  /* ════════════════════════════════════════════════════════════════
     CORP ASTRAL — sferă etereală care traversează cardul ocazional
  ════════════════════════════════════════════════════════════════ */
  .astral-orb {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    border-radius: inherit;
    z-index: 0;
  }

  .astral-orb::before {
    content: '';
    position: absolute;
    width: clamp(120px, 22vw, 220px);
    height: clamp(120px, 22vw, 220px);
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(200, 160, 255, 0.55) 0%,
      rgba(130, 80, 255, 0.28) 35%,
      rgba(60, 20, 180, 0.12) 60%,
      transparent 80%
    );
    filter: blur(18px);
    opacity: 0;
    top: 50%;
    left: -30%;
    transform: translateY(-50%);
    will-change: transform, opacity;
  }

  /* Clasa adăugată prin JS când orbul este activ */
  .astral-orb.is-traveling::before {
    animation: orb-travel 4.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes orb-travel {
    0%   { left: -30%;  top: 60%;  opacity: 0;    transform: translateY(-50%) scale(0.7); }
    8%   { opacity: 1; }
    30%  { top: 35%; }
    55%  { top: 55%; }
    80%  { top: 30%;  opacity: 0.85; }
    92%  { opacity: 0.3; }
    100% { left: 125%; top: 45%;  opacity: 0;    transform: translateY(-50%) scale(1.1); }
  }

  /* Lead text */
  .hero-lead {
    max-width: 46ch;
    margin: 0;
    font-size: clamp(0.78rem, 1.5vw, 0.9rem);
    line-height: 1.6;
    color: #ffffff !important;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.80);
    text-align: center;
  }

  /* ════════════════════════════════════════════════════════════════
     STAT PILLS
  ════════════════════════════════════════════════════════════════ */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }
  .hero-stat-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 0.85rem;
    padding: 0.35rem 0.85rem;
    background: rgba(255, 255, 255, 0.05);
    min-width: 60px;
  }
  .hero-stat-num {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff !important;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.80);
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85) !important;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.80);
    margin-top: 0.12rem;
  }

  /* ════════════════════════════════════════════════════════════════
     HERO PHOTO CARD — doar mobil (≤ 767px)
  ════════════════════════════════════════════════════════════════ */
  .hero-photo-card {
    display: none; /* ascuns pe desktop */
  }

  @media (max-width: 767px) {
    .hero-photo-card {
      display: block;
      width: 88%;
      max-width: 300px;
      margin: 0.9rem auto 0.25rem;
      border-radius: 1.25rem;
      overflow: hidden;
      box-shadow:
        0 0 0 1.5px rgba(212, 175, 55, 0.30),
        0 10px 36px rgba(0, 0, 0, 0.60);
      aspect-ratio: 3 / 2;
      background: rgba(255, 255, 255, 0.06);
    }

    .hero-photo-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 1.25rem;
      display: block;
    }
  }

  /* ════════════════════════════════════════════════════════════════
     SOCIAL MEDIA ROW — doar mobil (≤ 767px)
  ════════════════════════════════════════════════════════════════ */
  .hero-social-row {
    display: none; /* ascuns pe desktop */
  }

  @media (max-width: 767px) {
    .hero-social-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      margin-top: 0.5rem;
      width: 100%;
    }

    .hero-social-label {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(241, 229, 172, 0.40);
    }

    .hero-social-icons {
      display: flex;
      gap: 0.85rem;
      align-items: center;
      justify-content: center;
    }

    .hero-social-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      text-decoration: none;
      transition: transform 160ms ease, opacity 160ms ease;
    }

    .hero-social-btn:active {
      transform: scale(0.90);
      opacity: 0.75;
    }

    .hero-social-btn svg {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      /* Umbră colorată specifică fiecărei rețele */
    }

    .hero-social-btn span {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.55);
    }

    /* YouTube */
    .hero-social-btn--yt svg {
      background: #FF0000;
      box-shadow: 0 4px 18px rgba(255, 0, 0, 0.55), 0 2px 6px rgba(0,0,0,0.4);
    }
    .hero-social-btn--yt:hover svg { box-shadow: 0 6px 24px rgba(255, 0, 0, 0.75); }
    .hero-social-btn--yt span { color: rgba(255, 140, 140, 0.80); }

    /* Facebook */
    .hero-social-btn--fb svg {
      box-shadow: 0 4px 18px rgba(24, 119, 242, 0.55), 0 2px 6px rgba(0,0,0,0.4);
    }
    .hero-social-btn--fb:hover svg { box-shadow: 0 6px 24px rgba(24, 119, 242, 0.75); }
    .hero-social-btn--fb span { color: rgba(120, 180, 255, 0.80); }

    /* Instagram */
    .hero-social-btn--ig svg {
      box-shadow: 0 4px 18px rgba(225, 48, 108, 0.55), 0 2px 6px rgba(0,0,0,0.4);
    }
    .hero-social-btn--ig:hover svg { box-shadow: 0 6px 24px rgba(225, 48, 108, 0.75); }
    .hero-social-btn--ig span { color: rgba(255, 160, 200, 0.80); }

    /* TikTok */
    .hero-social-btn--tt svg {
      border: 1.5px solid rgba(255,255,255,0.20);
      box-shadow: 0 4px 18px rgba(254, 44, 85, 0.45), 0 2px 6px rgba(0,0,0,0.5);
    }
    .hero-social-btn--tt:hover svg { box-shadow: 0 6px 24px rgba(254, 44, 85, 0.65); }
    .hero-social-btn--tt span { color: rgba(255, 200, 210, 0.80); }
  }

  /* ════════════════════════════════════════════════════════════════
     HERO FULLSCREEN — override al cardului global din #continut>section
  ════════════════════════════════════════════════════════════════ */
  .hero-fullscreen {
    width: 100% !important;
    max-width: 900px !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    margin-left: auto !important;
    margin-right: auto !important;
    border-radius: 1.5rem !important;
    box-shadow:
      0 0 0 1.5px rgba(0, 200, 255, 0.4),
      0 0 24px rgba(0, 200, 255, 0.15),
      0 0 60px rgba(0, 150, 255, 0.08);
    /* min-height bazat pe conținut, nu 100vh — evită spațiul gol de jos */
    min-height: auto !important;
    /* padding-top >= 4rem → text "Formația" + badge vizibil sub header fix (~4rem înălțime) */
    padding-top: clamp(4rem, 5vw, 4.5rem) !important;
    /* padding-bottom redus — fără spațiu gol sub statistici */
    padding-bottom: 2rem !important;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    /* Tranziție identică cu .hp-card */
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 300ms ease,
      border-color 300ms ease;
  }

  /* Hover pe cardul hero — doar pe dispozitive cu pointer precis */
  @media (hover: hover) and (pointer: fine) {
    .hero-fullscreen:hover {
      transform: scale(1.02);
      box-shadow:
        0 0 0 1.5px rgba(0, 200, 255, 0.6),
        0 0 30px rgba(0, 200, 255, 0.3),
        0 0 80px rgba(0, 150, 255, 0.15);
    }
  }

  /* ════════════════════════════════════════════════════════════════
     HP-HERO-WRAP — container vizual simetric cu .hp-highlights
     Aceeași lățime max 900px, aceleași margini laterale auto,
     același border-radius 1.5rem, același padding lateral 2rem.
  ════════════════════════════════════════════════════════════════ */
  .hp-hero-wrap {
    max-width: 900px;         /* identic cu .hp-highlights */
    margin-inline: auto;      /* centrat orizontal */
    border-radius: 1.5rem;    /* identic cu .hp-card / .hp-highlights */
    padding-inline: 2rem;     /* identic cu .hp-highlights padding lateral (1.5rem 2rem) */
    /* padding top/bottom: gestionat de .hero-fullscreen cu !important */
    /* fundal: gradientul navy vine din #continut>#acasa (globals.css) */
  }

  /* Pe mobile mic: reduce padding suplimentar — secțiunea are deja 1.4rem */
  @media (max-width: 480px) {
    .hp-hero-wrap {
      padding-inline: 0.75rem;
    }
  }

  @media (max-width: 374px) {
    .hp-hero-wrap {
      padding-inline: 0.25rem;
    }
    .hero-title-gold {
      font-size: clamp(2rem, 8vw, 3rem);
    }
    .kicker-badge {
      font-size: 0.7rem;
      padding: 0.25rem 0.6rem;
    }
  }

  /* Gradient fade la baza hero-ului — sub conținut, nu deasupra */
  .hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 20rem;
    background: linear-gradient(to bottom,
      transparent 0%,
      rgba(12, 8, 15, 0.20) 25%,
      rgba(12, 8, 15, 0.55) 55%,
      rgba(12, 8, 15, 0.85) 80%,
      rgba(12, 8, 15, 0) 100%
    );
    pointer-events: none;
    z-index: 1;  /* SUB conținutul text (z-index: 5) */
  }

  /* ════════════════════════════════════════════════════════════════
     HIGHLIGHTS — 2 carduri side-by-side (desktop) / stacked (mobile)
  ════════════════════════════════════════════════════════════════ */
  .hp-highlights {
    display: grid;
    /* Side-by-side implicit — stivuit doar pe ecrane foarte mici */
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    /* margin-top negativ: cardurile urcă sub fade-ul hero-ului */
    margin-top: -5rem;
    padding: 1.5rem 2rem;
    max-width: 900px;
    margin-inline: auto;
    /* Suprascriem margin-inline auto cu un shorthand explicit */
    margin: -5rem auto clamp(2.5rem, 6vw, 4rem);
    position: relative;
    z-index: 4;
  }

  @media (max-width: 767px) {
    .hp-highlights {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1rem;
      margin-top: -3rem;
    }

    /* Reduce card min-height când stivuite — evită spațiu alb excesiv */
    .hp-card {
      min-height: 240px;
    }

    .hp-card--story {
      min-height: 220px;
    }

    /* Padding mai strâns în card-content pe mobil */
    .hp-card-content {
      padding: 1.75rem 1.5rem;
      gap: 0.45rem;
    }

    /* Titlu card proporțional pe ecran mic */
    .hp-card-title {
      font-size: clamp(1.5rem, 5.5vw, 1.9rem);
    }
  }

  /* Stretched link — acoperă întreg cardul, navigare la URL-ul cardului */
  .hp-card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
  }

  .hp-card {
    position: relative;
    min-height: 300px;
    border-radius: 1.5rem;
    overflow: hidden;
    display: flex;
    text-decoration: none;
    cursor: pointer;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 300ms ease,
                border-color 300ms ease;
  }

  @media (min-width: 1024px) {
    .hp-card { min-height: 340px; }
  }

  /* hover doar pe dispozitive cu pointer precis — evită sticky-hover pe touch */
  @media (hover: hover) and (pointer: fine) {
    .hp-card:hover {
      transform: scale(1.02);
    }
  }

  /* Card 1 — Povestea noastră */
  .hp-card--story {
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
    min-height: 280px;
    background:
      radial-gradient(ellipse at 70% 30%, #3d1a6e 0%, #1a0a3d 55%, #0a0520 100%);
    border: 1px solid rgba(160, 90, 255, 0.30);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45),
                inset 0 1px 0 rgba(200, 140, 255, 0.12);
  }

  @media (hover: hover) and (pointer: fine) {
    .hp-card--story:hover {
      border-color: rgba(180, 110, 255, 0.60);
      box-shadow: 0 20px 56px rgba(100, 40, 200, 0.35), 0 4px 16px rgba(0, 0, 0, 0.5),
                  inset 0 1px 0 rgba(200, 140, 255, 0.20);
    }
  }

  /* Conținut story-card: umple înălțimea cardului → centrare verticală garantată */
  .hp-card--story .hp-card-content {
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
  }

  /* Card 2 — Rezervă acum */
  .hp-card--book {
    background:
      radial-gradient(ellipse 65% 55% at 90% 80%, rgba(11, 188, 214, 0.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 10% 20%, rgba(4, 80, 100, 0.28) 0%, transparent 60%),
      linear-gradient(150deg, #021820 0%, #073028 40%, #031414 100%);
    border: 1px solid rgba(11, 188, 214, 0.22);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  @media (hover: hover) and (pointer: fine) {
    .hp-card--book:hover {
      border-color: rgba(11, 188, 214, 0.52);
      box-shadow: 0 20px 52px rgba(11, 188, 214, 0.18), 0 4px 16px rgba(0, 0, 0, 0.4);
    }
  }

  .hp-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.20) 45%,
      transparent 75%
    );
    pointer-events: none;
    z-index: 1;
  }

  .hp-card-content {
    position: relative;
    /* z-index: 3 — deasupra hp-card-link (z:2) și hp-card-overlay (z:1) */
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.55rem;
    padding: 2.25rem 2rem;
    width: 100%;
  }

  .hp-card-kicker {
    font-family: 'Oswald', sans-serif;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(241, 229, 172, 0.52);
  }

  .hp-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.7rem, 3.2vw, 2.2rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #fff;
    margin: 0;
    line-height: 1.1;
  }

  .hp-card--book .hp-card-title {
    color: rgba(190, 252, 255, 0.95);
  }

  .hp-card-text {
    font-size: 0.88rem;
    color: rgba(200, 210, 230, 0.68);
    margin: 0;
    line-height: 1.5;
  }

  .hp-whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(37, 211, 102, 0.13);
    border: 1px solid rgba(37, 211, 102, 0.40);
    border-radius: 0.65rem;
    padding: 0.5rem 1rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #25d366;
    text-decoration: none;
    width: fit-content;
    margin-top: 0.2rem;
    /* z-index: 4 — clickabil deasupra stretched link-ului (z:2) */
    position: relative;
    z-index: 4;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .hp-whatsapp-btn:hover {
    background: rgba(37, 211, 102, 0.26);
    border-color: rgba(37, 211, 102, 0.68);
    color: #4dff96;
  }

  .hp-whatsapp-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .hp-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.70rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(241, 229, 172, 0.65);
    margin-top: 0.3rem;
    transition: color 200ms ease, gap 200ms ease;
  }

  .hp-card:hover .hp-card-cta {
    color: #F1E5AC;
    gap: 0.6rem;
  }

  .hp-card--book .hp-card-cta {
    color: rgba(11, 188, 214, 0.72);
  }

  .hp-card--book:hover .hp-card-cta {
    color: var(--teal, #0BBCD6);
    gap: 0.6rem;
  }

  /* ════════════════════════════════════════════════════════════════
     SEO CONTENT SECTIONS — Despre, De ce noi, Evenimente, FAQ
  ════════════════════════════════════════════════════════════════ */
  .hp-seo-section {
    max-width: 900px;
    margin-inline: auto;
    padding: clamp(2rem, 4vw, 3rem) 2rem;
  }

  .hp-seo-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.4rem, 2.8vw, 1.8rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #fff;
    margin: 0 0 1.2rem;
    line-height: 1.2;
  }

  .hp-seo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .hp-seo-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 767px) {
