---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';
import communityPosts from '../data/communityPosts.json';
import BackButton from '../components/BackButton.astro';
import blogPosts from '../data/blogPosts.json';
import { query as dbQuery } from '../lib/db.js';

export const prerender = false;

const { brand, seo, videos, tvAppearances, contact, realMoments } = siteContent;

const getYoutubeId = (url: string) => {
  const match = url.match(/(?:v=|youtu\.be\/)([^&?/]+)/);
  return match?.[1] ?? '';
};

const getFeedType = (source: string) => (source.toLowerCase().includes('apari') ? 'tv' : 'gallery');

const whatsappNumber = contact.phoneRaw.replace(/\D/g, '');
const buildWhatsAppCta = (videoUrl: string) => {
  const message = encodeURIComponent(`Bună! Vreau ofertă pentru sezonul 2026-2027. Am văzut această postare: ${videoUrl}`);
  return `https://wa.me/${whatsappNumber}?text=${message}`;
};

const fallbackFeedPosts = [
  ...videos.map((item, index) => ({
    id: `video-${item.youtubeId}`,
    title: item.title,
    caption: `Atmosferă reală din evenimentele noastre. Dacă îți place vibe-ul, dă like, comentează și distribuie mai departe.`,
    youtubeId: item.youtubeId,
    youtubeUrl: item.youtubeUrl ?? `https://www.youtube.com/watch?v=${item.youtubeId}`,
    source: 'Galerie video',
    publishedLabel: `${index + 1} h`,
  })),
  ...tvAppearances
    .map((item, index) => {
      const youtubeId = getYoutubeId(item.videoUrl);
      if (!youtubeId) return null;

      return {
        id: `tv-${youtubeId}-${index + 1}`,
        title: item.show,
        caption: `Apariție TV ${item.year}. Susține-ne cu un like și un share ca să ajungem la cât mai mulți clienți noi.`,
        youtubeId,
        youtubeUrl: item.videoUrl,
        source: `Apariții TV ${item.year}`,
        publishedLabel: `${index + 2} h`,
      };
    })
    .filter(Boolean),
];

const adminFeedPosts = ((communityPosts as any).items ?? [])
  .map((item, index) => {
    const imageUrl = typeof item.imageUrl === 'string' ? item.imageUrl.trim() : '';
    const youtubeId = getYoutubeId(item.youtubeUrl ?? '');
    if (!youtubeId && !imageUrl) return null;

    return {
      id: item.id || `admin-post-${index + 1}`,
      title: item.title || `Postare ${index + 1}`,
      caption: item.caption || 'Postare comunitate.',
      youtubeId,
      youtubeUrl: item.youtubeUrl || '',
      imageUrl,
      source: item.source || 'Comunitate',
      publishedLabel: item.publishedLabel || `${index + 1} h`,
    };
  })
  .filter(Boolean);

const feedPosts = adminFeedPosts.length > 0 ? adminFeedPosts : fallbackFeedPosts;

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('ro-RO', { day: 'numeric', month: 'short', year: 'numeric' });

const accentBgMap: Record<string, string> = {
  rose: 'rgba(232,50,90,0.22)',
  gold: 'rgba(245,166,35,0.22)',
  teal: 'rgba(11,188,214,0.2)',
};
const accentColorMap: Record<string, string> = {
  rose: 'var(--rose)',
  gold: 'var(--gold)',
  teal: 'var(--teal)',
};

let galleryPhotos: Array<{
  id: number;
  titlu: string;
  imagine_url: string;
  data_upload: string;
}> = [];

try {
  const rows = (await dbQuery(
    `SELECT id, titlu, imagine_url, data_upload
     FROM gallery
     WHERE imagine_url LIKE '/uploads/%'
     ORDER BY data_upload DESC`,
  )) as Array<{ id: number; titlu: string; imagine_url: string; data_upload: string }>;

  galleryPhotos = rows.filter((row) => typeof row.imagine_url === 'string' && row.imagine_url.startsWith('/uploads/'));
} catch (error) {
  console.error('Nu s-a putut citi galeria foto din DB:', error);
}

const pageTitle = `Comunitatea noastră | ${brand.name}`;
const pageDescription = 'Distribuie videoclipurile preferate, interacționează cu comunitatea și susține formația prin like-uri și share-uri.';
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage={seo.ogImage}>
  <section class="section-container pt-8 pb-16 sm:pt-10 sm:pb-20">
    <div class="mb-6"><BackButton href="/" label="Acasă" /></div>
    <header class="section-head mx-auto text-center mb-10">
      <p class="kicker">Formația Florentina Pană</p>
      <h1 class="section-title">Recenzii și Testimoniale | Formația Florentina Pană</h1>
      <p class="section-copy">
        Fiecare nuntă e o poveste unică. Iată ce spun cuplurile care ne-au încredințat cele mai frumoase momente din viața lor.
      </p>
    </header>
    <!-- ─── Testimoniale ─────────────────────────────────────────────── -->
    <div class="testimonials-wrap mx-auto mb-14 max-w-5xl">
      <div class="testimonials-head mb-8 text-center">
        <p class="kicker mx-auto">Ce spun ei</p>
        <h2 class="section-title text-2xl md:text-3xl">Cuvintele lor valorează mai mult decât orice reclamă</h2>
      </div>
      <div class="testimonials-grid">
        {realMoments.events.map((event) => {
          const accentColor = (event as any).accentColor ?? '#f5a623';
          const blogSlug = (event as any).blogSlug ?? '';
          const initials = event.couple.split('&').map((n: string) => n.trim()[0] ?? '').join('');
          return (
            <article class="testimonial-card" style={`--tc:${accentColor}`}>
              <div class="tc-stars" aria-label="5 stele din 5">★★★★★</div>
              <blockquote class="tc-quote">{event.coupleQuote}</blockquote>
              <footer class="tc-footer">
                <div class="tc-avatar" aria-hidden="true">{initials}</div>
                <div class="tc-meta">
                  <p class="tc-name">{event.couple}</p>
                  <p class="tc-location">{event.city} &bull; {event.date}</p>
                </div>
                {blogSlug && (
                  <a class="tc-blog-link" href={`/blog/${blogSlug}`}>Povestea lor →</a>
                )}
              </footer>
            </article>
          );
        })}
      </div>
    </div>
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section class="community-gallery-wrap mx-auto mb-6 max-w-5xl rounded-2xl border border-white/20 bg-[#120a27d6] p-4 sm:p-5">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-extrabold text-white">Galerie Foto Comunitate</h2>
        <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white/90">
          {galleryPhotos.length} imagini
        </span>
      </div>

      {galleryPhotos.length > 0 ? (
        <div class="community-gallery-grid mt-4" data-db-gallery-grid>
          {galleryPhotos.map((photo) => (
            <article class="community-gallery-item" aria-label={photo.titlu}>
              <img src={photo.imagine_url} alt={photo.titlu} loading="lazy" />
              <div class="community-gallery-meta">
                <p class="community-gallery-title">{photo.titlu}</p>
                <p class="community-gallery-date">{new Date(photo.data_upload).toLocaleDateString('ro-RO')}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="mt-3 text-sm text-white/90">Nu există poze în galerie momentan.</p>
      )}
    </section>

    <div class="mx-auto max-w-5xl">
      <aside id="blog" class="community-editorial-column min-w-0" aria-label="Publicații și Vlog">
        <div class="blog-aside-header">
          <p class="blog-aside-kicker">Publicații &amp; Vlog</p>
          <h2 class="blog-aside-title">Articole &amp; povești</h2>
          <p class="blog-aside-sub">Muzică, culise și ghiduri utile pentru evenimentul tău — scrise de noi, pentru tine.</p>
        </div>

        <div class="blog-list">
          {((blogPosts as any).items as any[]).map((post) => {
            const bg = accentBgMap[post.categoryAccent] ?? 'rgba(245,166,35,0.22)';
            const color = accentColorMap[post.categoryAccent] ?? 'var(--gold)';
            return (
              <a href={`/blog/${post.slug}`} class="blog-card">
                <div
                  class="blog-card-thumb"
                  aria-hidden="true"
                  style={`background: radial-gradient(ellipse at 50% 50%, ${bg} 0%, var(--bg-mid) 100%);`}
                >
                  <span>{post.coverEmoji}</span>
                </div>
                <div class="blog-card-text">
                  <div class="blog-card-top">
                    <span
                      class="blog-cat-pill"
                      style={`color:${color}; border-color:${color}; background:${bg};`}
                    >
                      {post.category}
                    </span>
                    <span class="blog-card-time">{post.readTime}</span>
                  </div>
                  <p class="blog-card-title">{post.title}</p>
                  <p class="blog-card-excerpt">{post.excerpt}</p>
                  <span class="blog-card-date">{formatDate(post.date)}</span>
                </div>
              </a>
            );
          })}
        </div>

        <a href={`/blog/${((blogPosts as any).items as any[])[0]?.slug ?? ''}`} class="blog-aside-cta">
          Citește ultimul articol
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </aside>
    </div>

    <!-- ─── CTA rezervare ────────────────────────────────────────────── -->
    <div class="ctab-wrap mx-auto mt-14 max-w-3xl">
      <p class="ctab-kicker">Sezonul 2026–2027</p>
      <h2 class="ctab-title">Vrei să faci parte din familia noastră?</h2>
      <p class="ctab-sub">Locurile se ocupă rapid. Contactează-ne acum și asigură-ți data dorită.</p>
      <div class="ctab-actions">
        <a
          href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Bună! Vreau să rezerv o dată pentru evenimentul meu cu Formația Florentina Pană.')}`}
          class="ctab-btn ctab-btn--wa"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Scrie pe WhatsApp
        </a>
        <a href="/contact" class="ctab-btn ctab-btn--outline">Formular contact →</a>
      </div>
    </div>
    <!-- ─────────────────────────────────────────────────────────────── -->
  </section>

  <script>
    const communityStorageKey = 'fp-community-feed-v2';

    const readCommunityState = () => {
      try {
        const raw = window.localStorage.getItem(communityStorageKey);
        const parsed = raw ? JSON.parse(raw) : null;

        if (!parsed || typeof parsed !== 'object') {
          return { likes: {}, likedByMe: {}, comments: {} };
        }

        return {
          likes: parsed.likes && typeof parsed.likes === 'object' ? parsed.likes : {},
          likedByMe: parsed.likedByMe && typeof parsed.likedByMe === 'object' ? parsed.likedByMe : {},
          comments: parsed.comments && typeof parsed.comments === 'object' ? parsed.comments : {},
        };
      } catch {
        return { likes: {}, likedByMe: {}, comments: {} };
      }
    };

    const writeCommunityState = (state) => {
      window.localStorage.setItem(communityStorageKey, JSON.stringify(state));
    };

    const communityState = readCommunityState();
    const sortSelect = document.querySelector('[data-feed-sort]');
    const filterButtons = Array.from(document.querySelectorAll('[data-feed-filter]'));
    const feedContainer = document.querySelector('.community-feed');
    const createPostDemoButton = document.querySelector('[data-create-post-demo]');
    const cards = Array.from(document.querySelectorAll('[data-social-card]'));

    let activeFilter = 'all';

    const applyFeedSorting = (mode) => {
      if (!feedContainer) return;

      const sortedCards = [...cards].sort((a, b) => {
        const aId = a.getAttribute('data-video-id') ?? '';
        const bId = b.getAttribute('data-video-id') ?? '';
        const aLikes = Number(communityState.likes[aId] ?? 0);
        const bLikes = Number(communityState.likes[bId] ?? 0);
        const aOrder = Number(a.getAttribute('data-feed-order') ?? 0);
        const bOrder = Number(b.getAttribute('data-feed-order') ?? 0);

        if (mode === 'top') {
          if (bLikes !== aLikes) return bLikes - aLikes;
          return aOrder - bOrder;
        }

        return aOrder - bOrder;
      });

      sortedCards.forEach((card) => feedContainer.appendChild(card));
    };

    sortSelect?.addEventListener('change', () => {
      applyFeedSorting(sortSelect.value);
      applyFeedFilter(activeFilter);
    });

    const applyFeedFilter = (filter) => {
      activeFilter = filter;

      cards.forEach((card) => {
        const type = card.getAttribute('data-feed-type') ?? 'gallery';
        const shouldShow = filter === 'all' || type === filter;
        card.classList.toggle('community-post-hidden', !shouldShow);
      });

      filterButtons.forEach((button) => {
        const value = button.getAttribute('data-feed-filter') ?? '';
        const isActive = value === filter;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const value = button.getAttribute('data-feed-filter') ?? 'all';
        applyFeedFilter(value);
      });
    });

    createPostDemoButton?.addEventListener('click', () => {
      window.alert('Modul de publicare directă va fi conectat la un backend. Pentru moment, feed-ul afișează postările video active.');
    });

    const adminUploadForm = document.querySelector('[data-admin-upload-form]');
    const dropzone = document.querySelector('[data-dropzone]');
    const dropzoneTrigger = document.querySelector('[data-dropzone-trigger]');
    const fileInput = document.getElementById('admin-photo-input');
    const uploadTitleInput = document.querySelector('[data-upload-title]');
    const previewImage = document.querySelector('[data-upload-preview]');
    const uploadStatus = document.querySelector('[data-upload-status]');
    const uploadUrlInput = document.querySelector('[data-upload-url]');
    const uploadSubmitButton = document.querySelector('[data-upload-submit]');
    const dbGalleryGrid = document.querySelector('[data-db-gallery-grid]');

    let selectedFile = null;

    const showUploadStatus = (message, type = 'info') => {
      if (!uploadStatus) return;

      uploadStatus.textContent = message;
      uploadStatus.classList.remove('hidden', 'border-red-300/50', 'bg-red-500/10', 'text-red-100', 'border-lime-300/50', 'bg-lime-500/10', 'text-lime-100', 'border-white/30', 'bg-white/10', 'text-white');

      if (type === 'error') {
        uploadStatus.classList.add('border-red-300/50', 'bg-red-500/10', 'text-red-100');
        return;
      }

      if (type === 'success') {
        uploadStatus.classList.add('border-lime-300/50', 'bg-lime-500/10', 'text-lime-100');
        return;
      }

      uploadStatus.classList.add('border-white/30', 'bg-white/10', 'text-white');
    };

    const validateImageFile = (file) => {
      const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
      if (!allowedTypes.includes((file.type || '').toLowerCase())) {
        return 'Sunt permise doar fișiere JPG, PNG și WebP.';
      }

      if (file.size > 5 * 1024 * 1024) {
        return 'Fișierul este prea mare. Limita este 5MB.';
      }

      return '';
    };

    const setPreview = (file) => {
      if (!(previewImage instanceof HTMLImageElement)) return;

      const objectUrl = URL.createObjectURL(file);
      previewImage.src = objectUrl;
      previewImage.classList.remove('hidden');
      previewImage.onload = () => {
        URL.revokeObjectURL(objectUrl);
      };
    };

    const handleSelectedFile = (file) => {
      const error = validateImageFile(file);
      if (error) {
        selectedFile = null;
        showUploadStatus(error, 'error');
        return;
      }

      selectedFile = file;
      setPreview(file);
      showUploadStatus(`Fișier pregătit: ${file.name}`, 'info');
    };

    if (dropzone && fileInput instanceof HTMLInputElement) {
      dropzone.addEventListener('click', () => fileInput.click());

      dropzone.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          fileInput.click();
        }
      });

      fileInput.addEventListener('change', () => {
        const file = fileInput.files?.[0];
        if (!file) return;
        handleSelectedFile(file);
      });

      dropzone.addEventListener('dragover', (event) => {
        event.preventDefault();
        dropzone.classList.add('is-dragover');
      });

      dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('is-dragover');
      });

      dropzone.addEventListener('drop', (event) => {
        event.preventDefault();
        dropzone.classList.remove('is-dragover');

        const file = event.dataTransfer?.files?.[0];
        if (!file) return;
        handleSelectedFile(file);
      });
    }

    dropzoneTrigger?.addEventListener('click', () => {
      if (fileInput instanceof HTMLInputElement) {
        fileInput.click();
      }
    });

    adminUploadForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const photoTitle =
        uploadTitleInput instanceof HTMLInputElement
          ? uploadTitleInput.value.trim()
          : '';

      if (photoTitle.length < 2 || photoTitle.length > 180) {
        showUploadStatus('Titlul fotografiei trebuie sa aiba intre 2 si 180 de caractere.', 'error');
        return;
      }

      if (!(selectedFile instanceof File)) {
        showUploadStatus('Selectează mai întâi o imagine validă.', 'error');
        return;
      }

      if (uploadSubmitButton instanceof HTMLButtonElement) {
        uploadSubmitButton.disabled = true;
        uploadSubmitButton.textContent = 'Se procesează...';
      }

      try {
        const formData = new FormData();
        formData.append('photo', selectedFile);
        formData.append('title', photoTitle);

        const response = await fetch('/api/upload-photo', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(data.error || 'Upload-ul a eșuat.');
        }

        if (uploadUrlInput instanceof HTMLInputElement) {
          uploadUrlInput.value = data.url || '';
        }

        if (dbGalleryGrid && data.url) {
          const safeTitle = String(data.title || photoTitle);
          const card = document.createElement('article');
          card.className = 'community-gallery-item';
          card.setAttribute('aria-label', safeTitle);

          const image = document.createElement('img');
          image.src = String(data.url);
          image.alt = safeTitle;
          image.loading = 'lazy';

          const meta = document.createElement('div');
          meta.className = 'community-gallery-meta';

          const title = document.createElement('p');
          title.className = 'community-gallery-title';
          title.textContent = safeTitle;

          const date = document.createElement('p');
          date.className = 'community-gallery-date';
          date.textContent = new Date().toLocaleDateString('ro-RO');

          meta.append(title, date);
          card.append(image, meta);
          dbGalleryGrid.prepend(card);
        }

        showUploadStatus('Imagine încărcată cu succes. Copiază URL-ul și adaugă-l în imageUrl pentru postare.', 'success');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Eroare la upload.';
        showUploadStatus(message, 'error');
      } finally {
        if (uploadSubmitButton instanceof HTMLButtonElement) {
          uploadSubmitButton.disabled = false;
          uploadSubmitButton.textContent = 'Optimizează și încarcă';
        }
      }
    });

    const renderComments = (container, comments) => {
      if (!container) return;

      if (!Array.isArray(comments) || comments.length === 0) {
        container.innerHTML = '<p class="text-xs text-white/85">Nu există comentarii încă. Fii primul care scrie.</p>';
        return;
      }

      container.innerHTML = comments
        .map((item) => {
          const safeName = String(item.name ?? 'Anonim').slice(0, 60);
          const safeText = String(item.text ?? '').slice(0, 360);

          return `
            <article class="community-comment-item">
              <p class="community-comment-meta">${safeName}</p>
              <p class="community-comment-text">${safeText}</p>
            </article>
          `;
        })
        .join('');
    };

    cards.forEach((card) => {
      const id = card.getAttribute('data-video-id') ?? '';
      if (!id) return;

      const likeButton = card.querySelector('[data-like-button]');
      const likeCount = card.querySelector('[data-like-count]');
      const commentCount = card.querySelector('[data-comment-count]');
      const facebookButton = card.querySelector('[data-share-facebook]');
      const whatsappButton = card.querySelector('[data-share-whatsapp]');
      const copyButton = card.querySelector('[data-copy-link]');
      const commentForm = card.querySelector('[data-comment-form]');
      const commentList = card.querySelector('[data-comment-list]');

      if (!communityState.likes[id]) communityState.likes[id] = 0;
      if (!communityState.comments[id]) communityState.comments[id] = [];

      const isLikedByMe = Boolean(communityState.likedByMe[id]);
      const currentLikeCount = Math.max(0, Number(communityState.likes[id] ?? 0));
      const currentComments = communityState.comments[id];

      if (likeCount) likeCount.textContent = String(currentLikeCount);
      if (commentCount) commentCount.textContent = String(currentComments.length);
      renderComments(commentList, currentComments);

      if (likeButton) {
        likeButton.classList.toggle('community-like-active', isLikedByMe);
        likeButton.textContent = isLikedByMe ? 'Apreciat' : 'Like';
      }

      likeButton?.addEventListener('click', () => {
        const liked = Boolean(communityState.likedByMe[id]);
        const baseCount = Math.max(0, Number(communityState.likes[id] ?? 0));
        const nextCount = liked ? Math.max(0, baseCount - 1) : baseCount + 1;

        communityState.likedByMe[id] = !liked;
        communityState.likes[id] = nextCount;

        if (likeCount) likeCount.textContent = String(nextCount);
        likeButton.classList.toggle('community-like-active', !liked);
        likeButton.textContent = !liked ? 'Apreciat' : 'Like';
        writeCommunityState(communityState);
        applyFeedSorting(sortSelect?.value ?? 'newest');
        applyFeedFilter(activeFilter);
      });

      facebookButton?.addEventListener('click', () => {
        const url = facebookButton.getAttribute('data-share-facebook') ?? '';
        if (!url) return;
        const shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
        window.open(shareUrl, '_blank', 'noopener,noreferrer');
      });

      whatsappButton?.addEventListener('click', () => {
        const url = whatsappButton.getAttribute('data-share-whatsapp') ?? '';
        if (!url) return;
        const shareText = `Uite o postare nouă de la ${brand.name}: ${url}`;
        const shareUrl = `https://wa.me/?text=${encodeURIComponent(shareText)}`;
        window.open(shareUrl, '_blank', 'noopener,noreferrer');
      });

      copyButton?.addEventListener('click', async () => {
        const url = copyButton.getAttribute('data-copy-link') ?? '';
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          copyButton.textContent = 'Link copiat';
          window.setTimeout(() => {
            copyButton.textContent = 'Copiază link postare';
          }, 1400);
        } catch {
          window.prompt('Copiază manual linkul:', url);
        }
      });

      commentForm?.addEventListener('submit', (event) => {
        event.preventDefault();

        const nameInput = commentForm.querySelector('input[name="name"]');
        const commentInput = commentForm.querySelector('textarea[name="comment"]');

        const name = (nameInput?.value ?? '').trim();
        const text = (commentInput?.value ?? '').trim();

        if (name.length < 2 || text.length < 3) return;

        const nextComments = [
          { name, text, at: Date.now() },
          ...communityState.comments[id],
        ].slice(0, 60);

        communityState.comments[id] = nextComments;
        if (commentCount) commentCount.textContent = String(nextComments.length);
        renderComments(commentList, nextComments);
        writeCommunityState(communityState);

        commentForm.reset();
      });
    });

    applyFeedSorting(sortSelect?.value ?? 'newest');
    applyFeedFilter(activeFilter);
  </script>

