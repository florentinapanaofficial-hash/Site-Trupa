---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';

const { seo, tvAppearances } = siteContent;

const getYoutubeId = (url: string) => {
  const match = url.match(/(?:v=|youtu\.be\/)([^&?/]+)/);
  return match?.[1] ?? '';
};
---

<BaseLayout title={`Apariții TV | ${seo.title}`} description="Galerie video cu apariții TV ale Formației Florentina Pană.">
  <section class="section-container py-16">
    <header class="section-head mx-auto text-center">
      <p class="kicker">Credibilitate</p>
      <h1 class="section-title">Galerie Video Apariții TV</h1>
      <p class="section-copy">Selecție video cu momente din apariții TV, grupate în format card.</p>
    </header>

    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {tvAppearances.map((item, index) => {
        const youtubeId = getYoutubeId(item.videoUrl);

        return (
          <article class="glass-card group h-full transition-all duration-300 hover:-translate-y-1 hover:border-cyan-200/45 hover:shadow-[0_20px_45px_rgba(94,238,255,0.16)]">
            {youtubeId ? (
              <iframe
                class="aspect-video w-full rounded-xl"
                src={`https://www.youtube.com/embed/${youtubeId}`}
                title={`Apariție TV ${index + 1}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              />
            ) : (
              <div class="grid aspect-video w-full place-items-center rounded-xl border border-white/20 bg-white/10 text-xs font-semibold text-white/90">
                Link YouTube invalid
              </div>
            )}

            <p class="mt-3 text-sm font-semibold text-white">Apariție TV #{index + 1}</p>
            <a
              href={item.videoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-flex items-center rounded-full border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-cyan-100 transition hover:-translate-y-0.5 hover:border-cyan-200/50 hover:bg-cyan-300/10"
            >
              Vezi pe YouTube
            </a>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
