---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteContent from '../data/siteContent.json';
import BackButton from '../components/BackButton.astro';
import { sanitizeUrl } from '../lib/sanitize-url';
import YoutubeEmbed from '../components/YoutubeEmbed.astro';

const { seo, tvAppearances, brand } = siteContent;

const getYoutubeId = (url: string) => {
  const match = url.match(/(?:v=|youtu\.be\/)([^&?/]+)/);
  return match?.[1] ?? '';
};
---

<BaseLayout title={`Apariții TV | ${brand.name}`} description="Galerie video cu apariții TV ale Formației Florentina Pană.">
  <section class="section-container py-16">
    <div class="mb-8"><BackButton href="/" label="Acasă" /></div>
    <header class="section-head mx-auto text-center">
      <p class="kicker">Credibilitate</p>
      <h1 class="section-title">Apariții TV | Formația Florentina Pană</h1>
      <p class="section-copy">Selecție video cu momente din apariții TV, grupate în format card.</p>
    </header>

    <h2 class="mt-8 text-xl font-bold text-white/80">Clipuri video din emisiuni și gale TV</h2>

    <div class="mt-4 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {tvAppearances.map((item, index) => {
        const youtubeId = getYoutubeId(item.videoUrl);

        return (
          <article class="glass-card group h-full transition-all duration-300 hover:-translate-y-1 hover:border-[rgba(245,166,35,0.5)] hover:shadow-[0_20px_45px_rgba(245,166,35,0.16)]">
            {youtubeId ? (
              <YoutubeEmbed youtubeId={youtubeId} title={item.show || `Apariție TV ${index + 1}`} class="rounded-xl" />
            ) : (
              <div class="grid aspect-video w-full place-items-center rounded-xl border border-white/20 bg-white/10 text-xs font-semibold text-white/90">
                Link YouTube invalid
              </div>
            )}

            <p class="mt-3 text-sm font-semibold text-white">Apariție TV #{index + 1}</p>
            <a
              href={sanitizeUrl(item.videoUrl)}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 inline-flex items-center rounded-full border border-[rgba(245,166,35,0.3)] bg-[rgba(245,166,35,0.08)] px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-[#FFD166] transition hover:-translate-y-0.5 hover:border-[rgba(245,166,35,0.6)] hover:bg-[rgba(245,166,35,0.15)]"
            >
              Vezi pe YouTube
            </a>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
