{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "astro/client"
    ]
  },
  "include": [
    "src/**/*"
  ]
}